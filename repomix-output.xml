  const hitEnemy = gs.enemies.some(e => e.x === cx && e.y === cy) ||
    gs.bigEnemies.some(be => cx >= be.x && cx <= be.x + 1 && cy >= be.y && cy <= be.y + 1);
  if (hitEnemy) return "stop";
  return "continue";
});
```

```ts

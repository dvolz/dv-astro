				stroke 0.1s ease;
		}
		&.pressed,
		&:active {
			transform: scale(0.92);
			svg {
				fill: var(--highlight-secondary);
				stroke: var(--highlight-secondary);
			}
		}
	}
	.dpad-up {
		grid-column: 2;
		grid-row: 1;
	}
	.dpad-left {
		grid-column: 1;
		grid-row: 2;
	}
	.dpad-right {
		grid-column: 3;
		grid-row: 2;
	}
	.dpad-down {
		grid-column: 2;
		grid-row: 3;
	}
	.dpad-center {
		grid-column: 2;
		grid-row: 2;
		border: none;
		background: none;
		pointer-events: none;
	}
	.touch-hint {
		display: none;
	}
	@media (pointer: coarse) {
		.touch-hint {
			display: inline;
		}
	}
</style>


<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Turtle Shape Comparison</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #08161e; color: #c8e0ec; font-family: monospace; padding: 32px 24px; }
  h1 { font-size: 11px; letter-spacing: 4px; text-transform: uppercase; color: #4ac0d8; margin-bottom: 4px; }
  h2 { font-size: 10px; letter-spacing: 3px; text-transform: uppercase; color: #8ad8e8; margin-bottom: 10px; }
  .sub { font-size: 9px; color: #3a6070; margin-bottom: 32px; letter-spacing: 1px; }
  .desc { font-size: 9px; color: #406070; margin-bottom: 14px; }
  .lbl { font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: #506878; margin-top: 8px; text-align: center; }
  .row { display: flex; gap: 24px; align-items: flex-start; flex-wrap: wrap; margin-bottom: 40px; }
  .card { display: flex; flex-direction: column; align-items: center; }
  hr { border: none; border-top: 1px solid rgba(255,255,255,0.05); margin: 0 0 40px; }
  section { margin-bottom: 40px; }

  /* Comparison grid — ref left, render right, same pixel size */
  .compare { display: flex; gap: 32px; align-items: flex-start; flex-wrap: wrap; margin-bottom: 32px; }
  .compare-col { display: flex; flex-direction: column; align-items: center; gap: 8px; }
  .compare-col .lbl { min-width: 140px; text-align: center; }

  /* Ref image: 1×1 square, rotate 90° CW so turtle faces RIGHT (game orientation) */
  .ref-img {
    display: block;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    transform: rotate(90deg);
    /* transform-origin: center — default is fine */
  }

  /* Side-by-side overlay via a CSS grid */
  .overlay-wrap { position: relative; display: inline-block; }
  .overlay-wrap canvas { position: absolute; top: 0; left: 0; }
</style>
</head>
<body>
<h1>Turtle — shape comparison</h1>
<p class="sub">reference pixel art (rotated 90° CW to game orientation) · vs · canvas rendering</p>

<section id="comparison-section">
  <h2>Side-by-side — 3×3 cell size</h2>
  <p class="desc">Reference rotated to face RIGHT (= game orientation). Rendering at same pixel size. Compare silhouettes.</p>
  <div class="compare" id="compare-row"></div>
</section>

<hr>

<section>
  <h2>Rendering — all 3 palettes, 2×2 and 3×3</h2>
  <p class="desc">Redesigned flippers: 4-pt trapezoid paddles (wide, flat, straight up/down). Shell: 12-pt chamfered octagon. Head: 9-pt polygon with diamond snout.</p>
  <div id="palettes-row"></div>
</section>

<script>
// ════════════════════════════════════════════════════════════════════════
//  drawTurtle — shark-style pixel art
//
//  Changes vs previous version:
//    - Front flippers: 4-pt trapezoid (wide, flat, straight up/down)
//      matching reference pixel art paddle shape
//    - Rear flippers: 4-pt trapezoid tabs at tail side
//    - Shell: same 12-pt chamfered octagon
//    - Head: same 9-pt diamond-snout polygon
//
//  Faces RIGHT (head = high x, tail = low x). bw×bw bounding box.
// ════════════════════════════════════════════════════════════════════════

function drawTurtle(ctx, bx, by, bw, aggressive, pal) {
  const x = bx, y = by, w = bw, h = bw;

  const R = (fx, fy, fw, fh) =>
    ctx.fillRect(
      Math.round(x + fx * w), Math.round(y + fy * h),
      Math.max(1, Math.round(fw * w)), Math.max(1, Math.round(fh * h)),
    );

  const LW  = Math.max(1, Math.round(bw * 0.025));
  const EYE = aggressive ? '#e02010' : pal.eyeBg;

  // helper: 4-pt quadrilateral (outline or fill, caller sets fillStyle)
  function quad(ax, ay, bx2, by2, cx2, cy2, dx, dy) {
    ctx.beginPath();
    ctx.moveTo(Math.round(x + ax  * w), Math.round(y + ay  * h));
    ctx.lineTo(Math.round(x + bx2 * w), Math.round(y + by2 * h));
    ctx.lineTo(Math.round(x + cx2 * w), Math.round(y + cy2 * h));
    ctx.lineTo(Math.round(x + dx  * w), Math.round(y + dy  * h));
    ctx.closePath();
  }
  function shell12(ox, oy) {  // ox/oy are inset offsets (positive = inset)
    ctx.beginPath();
    ctx.moveTo(Math.round(x + (0.20+ox) * w), Math.round(y + (0.12+oy) * h));
    ctx.lineTo(Math.round(x + (0.62-ox) * w), Math.round(y + (0.12+oy) * h));
    ctx.lineTo(Math.round(x + (0.74-ox) * w), Math.round(y + (0.22+oy) * h));
    ctx.lineTo(Math.round(x + (0.76-ox) * w), Math.round(y + (0.38+oy) * h));
    ctx.lineTo(Math.round(x + (0.76-ox) * w), Math.round(y + (0.62-oy) * h));
    ctx.lineTo(Math.round(x + (0.74-ox) * w), Math.round(y + (0.78-oy) * h));
    ctx.lineTo(Math.round(x + (0.62-ox) * w), Math.round(y + (0.88-oy) * h));
    ctx.lineTo(Math.round(x + (0.20+ox) * w), Math.round(y + (0.88-oy) * h));
    ctx.lineTo(Math.round(x + (0.10+ox) * w), Math.round(y + (0.78-oy) * h));
    ctx.lineTo(Math.round(x + (0.08+ox) * w), Math.round(y + (0.62-oy) * h));
    ctx.lineTo(Math.round(x + (0.08+ox) * w), Math.round(y + (0.38+oy) * h));
    ctx.lineTo(Math.round(x + (0.10+ox) * w), Math.round(y + (0.22+oy) * h));
    ctx.closePath();
  }
  function head9(ox, oy) {
    ctx.beginPath();
    ctx.moveTo(Math.round(x + (0.70-ox) * w), Math.round(y + (0.42+oy) * h));
    ctx.lineTo(Math.round(x + (0.80-ox) * w), Math.round(y + (0.38+oy) * h));
    ctx.lineTo(Math.round(x + (0.88-ox) * w), Math.round(y + (0.38+oy) * h));
    ctx.lineTo(Math.round(x + (0.94+ox) * w), Math.round(y + (0.44+oy) * h));
    ctx.lineTo(Math.round(x + (0.98+ox) * w), Math.round(y + (0.50   ) * h));
    ctx.lineTo(Math.round(x + (0.94+ox) * w), Math.round(y + (0.56-oy) * h));
    ctx.lineTo(Math.round(x + (0.88-ox) * w), Math.round(y + (0.62-oy) * h));
    ctx.lineTo(Math.round(x + (0.80-ox) * w), Math.round(y + (0.62-oy) * h));
    ctx.lineTo(Math.round(x + (0.70-ox) * w), Math.round(y + (0.58-oy) * h));
    ctx.closePath();
  }

  // ── 1. OUTLINE FILL PASS ───────────────────────────────────────────────
  ctx.fillStyle = pal.outline;

  // Front flippers: wide flat paddle — 4-pt trapezoid, straight up/down
  // Root attaches to shell across wide span; tip is slightly narrower and beyond bounding box
  // Top flipper
  quad(0.42, 0.40, 0.68, 0.40, 0.64, -0.06, 0.38, -0.06); ctx.fill();
  // Bottom flipper (mirror around y=0.50)
  quad(0.42, 0.60, 0.68, 0.60, 0.64, 1.06, 0.38, 1.06);   ctx.fill();

  // Rear flippers: small rectangular tabs at tail side
  // Top rear
  quad(0.00, 0.24, 0.14, 0.24, 0.14, 0.44, 0.00, 0.40);   ctx.fill();
  // Bottom rear
  quad(0.00, 0.76, 0.14, 0.76, 0.14, 0.56, 0.00, 0.60);   ctx.fill();

  // Shell
  shell12(0, 0); ctx.fill();

  // Head
  head9(0, 0); ctx.fill();

  // ── 2. COLOUR FILL PASS ────────────────────────────────────────────────

  // Front flippers (inset 0.02 from outline)
  ctx.fillStyle = pal.flipper;
  quad(0.44, 0.42, 0.66, 0.42, 0.62, -0.04, 0.40, -0.04); ctx.fill();
  quad(0.44, 0.58, 0.66, 0.58, 0.62, 1.04, 0.40, 1.04);   ctx.fill();

  // Rear flippers
  quad(0.02, 0.26, 0.12, 0.26, 0.12, 0.42, 0.02, 0.38);   ctx.fill();
  quad(0.02, 0.74, 0.12, 0.74, 0.12, 0.58, 0.02, 0.62);   ctx.fill();

  // Shell body (inset 0.02)
  ctx.fillStyle = pal.shell;
  shell12(0.02, 0.02); ctx.fill();

  // Shell highlight — top-left catch light
  ctx.fillStyle = pal.shellHi;
  R(0.20, 0.22, 0.24, 0.08);

  // Scute marks
  ctx.fillStyle = pal.scute;
  R(0.36, 0.36, 0.10, 0.09);
  R(0.26, 0.28, 0.08, 0.07);
  R(0.48, 0.28, 0.08, 0.07);

  // Head body (inset)
  ctx.fillStyle = pal.head;
  head9(0.01, 0.01); ctx.fill();

  // Eye — outline block, colour fill, pupil + highlight
  ctx.fillStyle = pal.outline;
  R(0.76, 0.41, 0.10, 0.16);

  ctx.fillStyle = EYE;
  R(0.77, 0.42, 0.08, 0.14);

  if (!aggressive) {
    ctx.fillStyle = pal.outline;
    R(0.80, 0.46, 0.04, 0.07);
    ctx.fillStyle = '#ffffff';
    R(0.77, 0.42, 0.02, 0.03);
  } else {
    ctx.fillStyle = pal.outline;
    R(0.81, 0.44, 0.02, 0.10);  // slit pupil
  }

  // ── 3. STROKE PASS ─────────────────────────────────────────────────────
  ctx.strokeStyle = pal.outline;
  ctx.lineWidth = LW;

  // Shell stroke (inner polygon)
  shell12(0.02, 0.02); ctx.stroke();

  // Front flipper strokes
  quad(0.44, 0.42, 0.66, 0.42, 0.62, -0.04, 0.40, -0.04); ctx.stroke();
  quad(0.44, 0.58, 0.66, 0.58, 0.62, 1.04, 0.40, 1.04);   ctx.stroke();

  // Rear flipper strokes
  quad(0.02, 0.26, 0.12, 0.26, 0.12, 0.42, 0.02, 0.38);   ctx.stroke();
  quad(0.02, 0.74, 0.12, 0.74, 0.12, 0.58, 0.02, 0.62);   ctx.stroke();

  // Head stroke
  head9(0.01, 0.01); ctx.stroke();
}

// ════════════════════════════════════════════════════════════════════════
//  PALETTES
// ════════════════════════════════════════════════════════════════════════

const PALETTES = [
  {
    id: 'V1', name: 'Dark Olive',
    desc: 'Closest to reference — dark military green',
    outline: '#1a1a08', shell: '#3d4416', shellHi: '#545c1e',
    scute: '#2a2e0c', flipper: '#2e3412', head: '#3d4416', eyeBg: '#9eab6e',
  },
  {
    id: 'V2', name: 'Warm Brown',
    desc: 'Hawksbill amber — currently in game',
    outline: '#201208', shell: '#584820', shellHi: '#7a6230',
    scute: '#3a2e10', flipper: '#3c2e10', head: '#584820', eyeBg: '#c0a868',
  },
  {
    id: 'V3', name: 'Ocean Green',
    desc: 'Vivid sea green — tropical/brighter',
    outline: '#121a06', shell: '#3a5c14', shellHi: '#527c1e',
    scute: '#263c0a', flipper: '#283e0c', head: '#3a5c14', eyeBg: '#aecf6a',
  },
];

// ════════════════════════════════════════════════════════════════════════
//  HELPERS
// ════════════════════════════════════════════════════════════════════════

const BG   = '#0c2a3c';
const GRID = 'rgba(255,255,255,0.06)';

function makeCanvas(w, h) {
  const c = document.createElement('canvas');
  c.width = w; c.height = h;
  return [c, c.getContext('2d')];
}
function drawGrid(ctx, w, h, CELL) {
  ctx.strokeStyle = GRID; ctx.lineWidth = 0.5;
  for (let gx = 0; gx <= w; gx += CELL) { ctx.beginPath(); ctx.moveTo(gx, 0); ctx.lineTo(gx, h); ctx.stroke(); }
  for (let gy = 0; gy <= h; gy += CELL) { ctx.beginPath(); ctx.moveTo(0, gy); ctx.lineTo(w, gy); ctx.stroke(); }
}
function card(canvas, label) {
  const d = document.createElement('div');
  d.className = 'card';
  d.appendChild(canvas);
  const l = document.createElement('div');
  l.className = 'lbl'; l.textContent = label;
  d.appendChild(l);
  return d;
}

// ════════════════════════════════════════════════════════════════════════
//  SECTION 1 — side-by-side comparison at 3×3
// ════════════════════════════════════════════════════════════════════════

const COMPARE_CELL = 52;
const compareRow = document.getElementById('compare-row');

// Reference image column (rotated via CSS)
{
  const SIZE = COMPARE_CELL * 3;  // 156px

  const refCol = document.createElement('div');
  refCol.className = 'compare-col';

  const img = document.createElement('img');
  img.src = '/turtle-ref.png';
  img.className = 'ref-img';
  img.style.width  = SIZE + 'px';
  img.style.height = SIZE + 'px';
  refCol.appendChild(img);

  const l = document.createElement('div');
  l.className = 'lbl';
  l.textContent = 'reference (CSS rotate 90°)';
  refCol.appendChild(l);

  compareRow.appendChild(refCol);
}

// Rendering columns — V2 neutral + aggressive
for (const agg of [false, true]) {
  const CELL = COMPARE_CELL;
  const SIZE = CELL * 3;
  const PAD  = CELL;
  const cw   = SIZE + PAD * 2;
  const ch   = SIZE + PAD * 2;
  const [cnv, ctx] = makeCanvas(cw, ch);

  ctx.fillStyle = BG;
  ctx.fillRect(0, 0, cw, ch);
  drawGrid(ctx, cw, ch, CELL);
  drawTurtle(ctx, PAD, PAD, SIZE, agg, PALETTES[1]);  // V2 Warm Brown = currently in game

  const col = document.createElement('div');
  col.className = 'compare-col';
  col.appendChild(cnv);
  const l = document.createElement('div');
  l.className = 'lbl';
  l.textContent = `V2 Warm Brown · 3×3 · ${agg ? 'aggressive' : 'neutral'}`;
  col.appendChild(l);

  compareRow.appendChild(col);
}

// Add a 2×2 comparison too
{
  const CELL = COMPARE_CELL;
  const SIZE = CELL * 2;
  const PAD  = CELL;
  const cw   = SIZE + PAD * 2;
  const ch   = SIZE + PAD * 2;
  const [cnv, ctx] = makeCanvas(cw, ch);

  ctx.fillStyle = BG;
  ctx.fillRect(0, 0, cw, ch);
  drawGrid(ctx, cw, ch, CELL);
  drawTurtle(ctx, PAD, PAD, SIZE, false, PALETTES[1]);

  const col = document.createElement('div');
  col.className = 'compare-col';
  col.appendChild(cnv);
  const l = document.createElement('div');
  l.className = 'lbl';
  l.textContent = 'V2 Warm Brown · 2×2 · neutral';
  col.appendChild(l);

  compareRow.appendChild(col);
}

// ════════════════════════════════════════════════════════════════════════
//  SECTION 2 — all palettes at both sizes
// ════════════════════════════════════════════════════════════════════════

const palRoot = document.getElementById('palettes-row');
const CELL = 44;

for (const pal of PALETTES) {
  const block = document.createElement('div');
  block.style.marginBottom = '48px';

  const hdr = document.createElement('h2');
  hdr.textContent = `${pal.id} — ${pal.name}`;
  block.appendChild(hdr);

  const desc = document.createElement('p');
  desc.className = 'desc';
  desc.textContent = pal.desc;
  block.appendChild(desc);

  const row = document.createElement('div');
  row.className = 'row';

  for (const size of [2, 3]) {
    for (const agg of [false, true]) {
      const bw = size * CELL;
      const cw = bw + CELL * 2;
      const ch = bw + CELL * 2;
      const [cnv, ctx] = makeCanvas(cw, ch);

      ctx.fillStyle = BG;
      ctx.fillRect(0, 0, cw, ch);
      drawGrid(ctx, cw, ch, CELL);
      drawTurtle(ctx, CELL, CELL, bw, agg, pal);

      row.appendChild(card(cnv, `${size}×${size} · ${agg ? 'aggro' : 'neutral'}`));
    }
  }

  block.appendChild(row);
  palRoot.appendChild(block);
  palRoot.appendChild(Object.assign(document.createElement('hr')));
}
</script>
</body>
</html>
</file>


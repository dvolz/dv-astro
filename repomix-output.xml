</GameLayout>

<script>
  // ── Module imports ────────────────────────────────────────────────────────
  import { gs } from "../../game/shark-thief/state";
  import { drawSharkOnCtx } from "../../game/shark-thief/renderers";
  import { tickShimmer } from "../../game/shark-thief/animation";
  import { moveShark, initAtDepth } from "../../game/shark-thief/engine";
  import { clearSave } from "../../game/shark-thief/persistence";
  import { initNavigation } from "../../game/shark-thief/navigation";
  import { initScoreSubmission } from "../../game/shark-thief/leaderboard";
  import { initDepthInfoControls } from "../../game/shark-thief/depth-info/scenes";

  // ── Settings — read from localStorage before first render ────────────────
  gs.colorblindMode = localStorage.getItem("sharkColorblind") === "true";
  gs.shimmerMode    = localStorage.getItem("sharkShimmer") === "true";
  gs.speedRunMode   = localStorage.getItem("sharkSpeedRun") === "true";

  const settingsColorblind = document.getElementById("settingsColorblind") as HTMLInputElement;
  const settingsHaptics    = document.getElementById("settingsHaptics")    as HTMLInputElement;
  const settingsShimmer    = document.getElementById("settingsShimmer")    as HTMLInputElement;
  const settingsSpeedRun   = document.getElementById("settingsSpeedRun")   as HTMLInputElement;

  const hudTimeBlock   = document.getElementById("hudTime")!.closest(".hud-stat-block") as HTMLElement;
  const hudLvTimeBlock = document.getElementById("hudLvTime")!.closest(".hud-stat-block") as HTMLElement;
  const hudRow2        = hudTimeBlock.closest(".hud-row-2")!;
  const hudDividers    = Array.from(hudRow2.querySelectorAll<HTMLElement>(".hud-stat-divider"));

  function applySpeedRunMode() {
    const hidden = !gs.speedRunMode;
    hudTimeBlock.style.visibility   = hidden ? "hidden" : "";
    hudLvTimeBlock.style.visibility = hidden ? "hidden" : "";
    hudDividers.forEach(d => d.style.visibility = hidden ? "hidden" : "");
  }

  settingsColorblind.checked = gs.colorblindMode;
  settingsHaptics.checked    = localStorage.getItem("sharkHaptics") !== "false";
  settingsShimmer.checked    = gs.shimmerMode;
  settingsSpeedRun.checked   = gs.speedRunMode;
  applySpeedRunMode();

  settingsColorblind.addEventListener("change", () => {
    gs.colorblindMode = settingsColorblind.checked;
    localStorage.setItem("sharkColorblind", String(gs.colorblindMode));
  });
  settingsHaptics.addEventListener("change", () => {
    localStorage.setItem("sharkHaptics", String(settingsHaptics.checked));
  });
  settingsShimmer.addEventListener("change", () => {
    gs.shimmerMode = settingsShimmer.checked;
    localStorage.setItem("sharkShimmer", String(gs.shimmerMode));
    if (gs.shimmerMode && !gs.shimmerRafId && !gs.gameOver)
      gs.shimmerRafId = requestAnimationFrame(tickShimmer);
  });
  settingsSpeedRun.addEventListener("change", () => {
    gs.speedRunMode = settingsSpeedRun.checked;
    localStorage.setItem("sharkSpeedRun", String(gs.speedRunMode));
    applySpeedRunMode();
  });

  // ── Keyboard controls ─────────────────────────────────────────────────────
  document.addEventListener("keydown", (e) => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    switch (e.key) {
      case "ArrowUp":    case "w": case "W": e.preventDefault(); moveShark(0, -1);  break;
      case "ArrowDown":  case "s": case "S": e.preventDefault(); moveShark(0, 1);   break;
      case "ArrowLeft":  case "a": case "A": e.preventDefault(); moveShark(-1, 0);  break;
      case "ArrowRight": case "d": case "D": e.preventDefault(); moveShark(1, 0);   break;
    }
  });

  // ── DPad ─────────────────────────────────────────────────────────────────
  function vibrate(ms: number) {
    const enabled = localStorage.getItem("sharkHaptics") !== "false";
    if (enabled && navigator.vibrate) navigator.vibrate(ms);
  }

  function execDir(dir: string) {
    switch (dir) {
      case "up":    moveShark(0, -1); break;
      case "down":  moveShark(0, 1);  break;
      case "left":  moveShark(-1, 0); break;
      case "right": moveShark(1, 0);  break;
    }
  }

  document.querySelectorAll(".dpad-btn").forEach((btn) => {
    const el = btn as HTMLElement;
    let repeatTimer: ReturnType<typeof setInterval> | null = null;
    const press   = () => el.classList.add("pressed");
    const release = () => {
      el.classList.remove("pressed");
      if (repeatTimer) { clearInterval(repeatTimer); repeatTimer = null; }
    };
    const startMove = (e: Event) => {
      e.preventDefault();
      press();
      const dir = el.dataset.dir!;
      vibrate(12);
      execDir(dir);
      repeatTimer = setTimeout(() => {
        repeatTimer = setInterval(() => { vibrate(8); execDir(dir); }, 100);
      }, 200) as unknown as ReturnType<typeof setInterval>;
    };
    btn.addEventListener("touchstart", startMove, { passive: false });
    btn.addEventListener("touchend",   release);
    btn.addEventListener("touchcancel", release);
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      vibrate(12);
      execDir(el.dataset.dir!);
      press();
      setTimeout(release, 150);
    });
  });

  // ── Dev Panel ─────────────────────────────────────────────────────────────
  (function buildDevPanel() {
    const container = document.getElementById("devJumpBtns")!;
    const depths = [
      { label: "DEPTH 1", depth: 1, color: "#48cae4" },
      { label: "DEPTH 2", depth: 2, color: "#e06fa0" },
      { label: "DEPTH 3", depth: 3, color: "#6abf3a" },
      { label: "DEPTH 4", depth: 4, color: "#7fd8f0" },
      { label: "DEPTH 5", depth: 5, color: "#daa070" },
      { label: "DEPTH 6", depth: 6, color: "#48d4b8" },
      { label: "DEPTH 7", depth: 7, color: "#9d6fe0" },
    ];
    depths.forEach(({ label, depth, color }) => {
      const btn = document.createElement("button");
      btn.textContent = label;
      btn.style.borderColor = color;
      btn.style.color = color;
      btn.addEventListener("click", () => { clearSave(); initAtDepth(depth); });
      container.appendChild(btn);
    });
    const guideBtn = document.createElement("button");
    guideBtn.textContent = "GAME GUIDE";
    guideBtn.style.borderColor = "var(--gold)";
    guideBtn.style.color = "var(--gold)";
    guideBtn.addEventListener("click", () => {
      document.getElementById("gameGuideOverlay")!.classList.add("visible");
    });
    container.appendChild(guideBtn);
  })();

  document.getElementById("gameGuideClose")!.addEventListener("click", () => {
    document.getElementById("gameGuideOverlay")!.classList.remove("visible");
  });
  document.getElementById("gameGuideOverlay")!.addEventListener("click", (e) => {
    if (e.target === e.currentTarget) (e.currentTarget as HTMLElement).classList.remove("visible");
  });

  // ── Startup — splash & menu shark ────────────────────────────────────────
  const splashCanvas = document.getElementById("splashSharkCanvas") as HTMLCanvasElement;
  if (splashCanvas) drawSharkOnCtx(splashCanvas.getContext("2d")!, 0.30, 0.30, 160, "right");

  const menuSharkCanvas = document.getElementById("menuSharkCanvas") as HTMLCanvasElement;
  if (menuSharkCanvas) {
    const menuCtx = menuSharkCanvas.getContext("2d")!;
    const mw = menuSharkCanvas.width, mh = menuSharkCanvas.height;
    const mcs = 120; // shark cell size
    const mpad = Math.round(mcs * 0.30); // 36px — room for fin overflow
    const bodyCx = mpad + mcs / 2; // breathe pivot = body center
    const bodyCy = mpad + mcs / 2;
    let mt = 0;
    function menuSharkFrame() {
      mt += 0.032;
      menuCtx.clearRect(0, 0, mw, mh);
      menuCtx.save();
      const breathe = 1 + 0.028 * Math.sin(mt * 1.3);
      menuCtx.translate(bodyCx, bodyCy);
      menuCtx.scale(breathe, breathe);
      menuCtx.translate(-bodyCx, -bodyCy);
      menuCtx.translate(0, Math.sin(mt * 0.75) * 3);
      const tailWag = Math.sin(mt * 2.4) * 0.85;
      drawSharkOnCtx(menuCtx, mpad / mcs, mpad / mcs, mcs, "right", tailWag);
      menuCtx.restore();
      requestAnimationFrame(menuSharkFrame);
    }
    requestAnimationFrame(menuSharkFrame);
  }

  // ── Boot ─────────────────────────────────────────────────────────────────
  initNavigation();
  initScoreSubmission();
  initDepthInfoControls();
</script>

<script>
	const canvas = document.getElementById('gameCanvas') as HTMLCanvasElement
	const ctx = canvas.getContext('2d')!

	// ── Map config ──
	type MapSize = 'small' | 'medium'
	const MAP_GRIDS: Record<MapSize, number> = {
		small: 20,
		medium: 30,
	}
	let currentMap: MapSize = 'medium'
	let GRID = MAP_GRIDS[currentMap]
	let CELL = canvas.width / GRID

	const scoreEl = document.getElementById('score')!
	const highScoreEl = document.getElementById('highScore')!
	const finalScoreEl = document.getElementById('finalScore')!
	const overlay = document.getElementById('gameOverOverlay')!
	const playAgainBtn = document.getElementById('playAgainBtn')!
	const submitScoreBtn = document.getElementById(
		'submitScoreBtn'
	)! as HTMLButtonElement
	const playerNameInput = document.getElementById(
		'playerName'
	)! as HTMLInputElement
	const submitStatus = document.getElementById('submitStatus')!
	const nameInputRow = document.getElementById('nameInputRow')!
	const leaderboardBody = document.getElementById('leaderboardBody')!
	const leaderboardMapLabel = document.getElementById('leaderboardMapLabel')!
	const submitPrompt = document.getElementById('submitPrompt')!
	const wantToSubmitBtn = document.getElementById('wantToSubmitBtn')!

	function highScoreKey(): string {
		if (currentMap === 'medium') return 'sharkHighScore'
		return `sharkHighScore-${currentMap}`
	}

	let highScore = parseInt(localStorage.getItem(highScoreKey()) || '0', 10)
	highScoreEl.textContent = String(highScore)

	// ── State ──
	interface Enemy {
		x: number
		y: number
	}

	let colors: string[][] = []
	let pickups: boolean[][] = []
	let superPickups: boolean[][] = []
	let enemies: Enemy[] = []
	let bigEnemies: { x: number; y: number }[] = []
	let shark = { x: 0, y: 0 }
	let sharkDir = 'right' // tracks last movement direction
	let score = 0
	let moveCount = 0
	let gameOver = false

	// Smooth shark animation
	let sharkVisualX = 0
	let sharkVisualY = 0
	let sharkFromX = 0
	let sharkFromY = 0
	let animStartTime = 0
	const ANIM_DURATION = 80 // ms

	function startSharkAnim() {
		sharkFromX = sharkVisualX
		sharkFromY = sharkVisualY
		animStartTime = performance.now()
		requestAnimationFrame(tickAnim)
	}

	function tickAnim(now: number) {
		const t = Math.min(1, (now - animStartTime) / ANIM_DURATION)
		const ease = 1 - (1 - t) * (1 - t) // ease-out quad
		sharkVisualX = sharkFromX + (shark.x - sharkFromX) * ease
		sharkVisualY = sharkFromY + (shark.y - sharkFromY) * ease
		draw()
		if (t < 1) requestAnimationFrame(tickAnim)
	}

	// Curated palette — distinct hues with consistent lightness,
	// chosen so none clash with yellow pickups, black enemies, or the blue shark.
	const TILE_COLORS = [
		'#7ca6b3', // steel blue
		'#8fae7e', // sage green
		'#b58dac', // muted plum
		'#c49880', // warm tan
		'#6d9e9e', // teal
		'#a3887e', // mauve brown
		'#8e9fc0', // periwinkle
		'#9caa6c', // olive
		'#b08f9f', // dusty rose
		'#7b9a84', // fern
	]

	function randomTileColor(): string {
		return TILE_COLORS[Math.floor(Math.random() * TILE_COLORS.length)]
	}

	function init() {
		score = 0
		moveCount = 0
		gameOver = false
		scoreEl.textContent = '0'
		overlay.classList.remove('visible')

		// Random colors
		colors = Array.from({ length: GRID }, () =>
			Array.from({ length: GRID }, () => randomTileColor())
		)

		// Pickups — 5% on init
		pickups = Array.from({ length: GRID }, () =>
			Array.from({ length: GRID }, () => Math.random() < 0.05)
		)

		// 15-point coins: 1 in 40 of normal pickups become super pickups
		superPickups = Array.from({ length: GRID }, (_, r) =>
			Array.from({ length: GRID }, (_, c) => {
				if (pickups[r][c] && Math.random() < 1 / 40) {
					pickups[r][c] = false
					return true
				}
				return false
			})
		)

		bigEnemies = []

		// Shark starts at random spot
		shark.x = Math.floor(Math.random() * GRID)
		shark.y = Math.floor(Math.random() * GRID)

		// Make sure shark doesn't start on a pickup
		pickups[shark.y][shark.x] = false
		superPickups[shark.y][shark.x] = false

		// Snap visual position
		sharkVisualX = shark.x
		sharkVisualY = shark.y

		// One initial enemy
		enemies = [spawnEnemy()]

		draw()
	}

	function spawnEnemy(): Enemy {
		const MIN_DIST = 5
		let ex: number, ey: number
		do {
			ex = Math.floor(Math.random() * GRID)
			ey = Math.floor(Math.random() * GRID)
		} while (
			Math.abs(ex - shark.x) + Math.abs(ey - shark.y) < MIN_DIST ||
			enemies.some((e) => e.x === ex && e.y === ey)
		)
		return { x: ex, y: ey }
	}

	function bigEnemyOverlaps(
		ax: number,
		ay: number,
		bx: number,
		by: number
	): boolean {
		return ax < bx + 2 && ax + 2 > bx && ay < by + 2 && ay + 2 > by
	}

	function spawnBigEnemy(): { x: number; y: number } {
		const MIN_DIST = 5
		let ex: number, ey: number
		do {
			ex = Math.floor(Math.random() * (GRID - 1))
			ey = Math.floor(Math.random() * (GRID - 1))
		} while (
			Math.min(
				Math.abs(ex - shark.x) + Math.abs(ey - shark.y),
				Math.abs(ex + 1 - shark.x) + Math.abs(ey - shark.y),
				Math.abs(ex - shark.x) + Math.abs(ey + 1 - shark.y),
				Math.abs(ex + 1 - shark.x) + Math.abs(ey + 1 - shark.y)
			) < MIN_DIST ||
			bigEnemies.some((b) => bigEnemyOverlaps(ex, ey, b.x, b.y))
		)
		return { x: ex, y: ey }
	}

	// ── Drawing ──

	let colorblindMode = localStorage.getItem('sharkColorblind') === 'true'
	const colorblindBtn = document.getElementById(
		'colorblindBtn'
	)! as HTMLButtonElement
	if (colorblindMode) colorblindBtn.classList.add('active')

	colorblindBtn.addEventListener('click', () => {
		colorblindMode = !colorblindMode
		localStorage.setItem('sharkColorblind', String(colorblindMode))
		colorblindBtn.classList.toggle('active', colorblindMode)
		draw()
	})

	// Redraw when theme changes so colors update (grid lines, enemy colors)
	new MutationObserver(() => {
		draw()
	}).observe(document.documentElement, {
		attributes: true,
		attributeFilter: ['class'],
	})

	function draw() {
		if (colorblindMode) {
			// Clear to transparent, draw single grid lines using the theme text color
			ctx.clearRect(0, 0, canvas.width, canvas.height)
			const textColor = getComputedStyle(document.body)
				.getPropertyValue('--text-color')
				.trim()
			ctx.strokeStyle = textColor || '#332e2e'
			ctx.lineWidth = 1
			ctx.beginPath()
			for (let i = 0; i <= GRID; i++) {
				const pos = i === GRID ? canvas.width - 0.5 : Math.round(i * CELL) + 0.5
				ctx.moveTo(pos, 0)
				ctx.lineTo(pos, canvas.height)
				ctx.moveTo(0, pos)
				ctx.lineTo(canvas.width, pos)
			}
			ctx.stroke()
		} else {
			// Background fill — prevents white seams between cells on scaled displays
			ctx.fillStyle = '#5b7b7b'
			ctx.fillRect(0, 0, canvas.width, canvas.height)

			// Grid cells
			for (let r = 0; r < GRID; r++) {
				for (let c = 0; c < GRID; c++) {
					ctx.fillStyle = colors[r][c]
					ctx.fillRect(c * CELL, r * CELL, CELL, CELL)
				}
			}
		}

		// Pickups (smaller yellow squares with dark outline for contrast)
		const pad = CELL * 0.22
		for (let r = 0; r < GRID; r++) {
			for (let c = 0; c < GRID; c++) {
				if (pickups[r][c]) {
					const px = c * CELL + pad
					const py = r * CELL + pad
					const ps = CELL - pad * 2
					// Dark outline
					ctx.fillStyle = '#7a6200'
					ctx.fillRect(px - 1, py - 1, ps + 2, ps + 2)
					// Yellow fill
					ctx.fillStyle = '#f1c40f'
					ctx.fillRect(px, py, ps, ps)
				}
			}
		}

		// Super pickups (15-point coins — purple with label)
		for (let r = 0; r < GRID; r++) {
			for (let c = 0; c < GRID; c++) {
				if (superPickups[r][c]) {
					const px = c * CELL + pad
					const py = r * CELL + pad
					const ps = CELL - pad * 2
					// Dark outline
					ctx.fillStyle = '#4a0060'
					ctx.fillRect(px - 1, py - 1, ps + 2, ps + 2)
					// Purple fill
					ctx.fillStyle = '#9b59b6'
					ctx.fillRect(px, py, ps, ps)
					// "15" label when cells are large enough
					if (CELL >= 16) {
						ctx.fillStyle = '#fff'
						ctx.font = `bold ${Math.max(8, CELL * 0.35)}px sans-serif`
						ctx.textAlign = 'center'
						ctx.textBaseline = 'middle'
						ctx.fillText('15', c * CELL + CELL / 2, r * CELL + CELL / 2)
					}
				}
			}
		}

		// Enemies — white in colorblind+dark mode, black otherwise
		const enemyWhite =
			colorblindMode && document.documentElement.classList.contains('dark')
		for (const e of enemies) {
			ctx.fillStyle = enemyWhite ? '#8b3a3a' : '#c0392b'
			ctx.fillRect(e.x * CELL - 1, e.y * CELL - 1, CELL + 2, CELL + 2)
			ctx.fillStyle = enemyWhite ? '#fff7f2' : '#1a1a1a'
			ctx.fillRect(e.x * CELL, e.y * CELL, CELL, CELL)
		}

		// Big enemies (2×2 red squares)
		for (const be of bigEnemies) {
			const bx = be.x * CELL
			const by = be.y * CELL
			const bw = CELL * 2
			// Dark outline
			ctx.fillStyle = '#6b0000'
			ctx.fillRect(bx - 1, by - 1, bw + 2, bw + 2)
			// Red fill
			ctx.fillStyle = '#e74c3c'
			ctx.fillRect(bx, by, bw, bw)
		}

		// Shark 🦈 — draw a simple shark shape
		drawShark(sharkVisualX, sharkVisualY)
	}

	function drawShark(cx: number, cy: number) {
		const x = cx * CELL
		const y = cy * CELL
		const w = CELL
		const h = CELL

		ctx.save()

		// Flip/rotate shark to face movement direction
		const centerX = x + w / 2
		const centerY = y + h / 2
		ctx.translate(centerX, centerY)
		switch (sharkDir) {
			case 'right':
				// default orientation, no transform
				break
			case 'left':
				ctx.scale(-1, 1) // mirror horizontally
				break
			case 'down':
				ctx.rotate(Math.PI / 2)
				break
			case 'up':
				ctx.rotate(-Math.PI / 2)
				break
		}
		ctx.translate(-centerX, -centerY)

		// Glow / highlight behind the shark
		ctx.shadowColor = '#ffffff'
		ctx.shadowBlur = 12

		// White outline for contrast on any background
		ctx.strokeStyle = '#fff'
		ctx.lineWidth = 1

		// Body
		ctx.fillStyle = '#2980b9'
		ctx.beginPath()
		ctx.ellipse(x + w / 2, y + h / 2, w * 0.45, h * 0.35, 0, 0, Math.PI * 2)
		ctx.fill()
		ctx.stroke()

		// Reset shadow so fins/tail don't double-glow
		ctx.shadowBlur = 0

		// Dorsal fin
		ctx.fillStyle = '#1a5276'
		ctx.beginPath()
		ctx.moveTo(x + w * 0.4, y + h * 0.08)
		ctx.lineTo(x + w * 0.48, y + h * 0.38)
		ctx.lineTo(x + w * 0.62, y + h * 0.35)
		ctx.closePath()
		ctx.fill()
		ctx.stroke()

		// Tail
		ctx.fillStyle = '#1a5276'
		ctx.beginPath()
		ctx.moveTo(x + w * 0.05, y + h * 0.35)
		ctx.lineTo(x - w * 0.1, y + h * 0.15)
		ctx.lineTo(x - w * 0.1, y + h * 0.7)
		ctx.lineTo(x + w * 0.05, y + h * 0.55)
		ctx.closePath()
		ctx.fill()
		ctx.stroke()

		// Belly (lighter underside)
		ctx.fillStyle = '#d6eaf8'
		ctx.beginPath()
		ctx.ellipse(x + w / 2, y + h * 0.58, w * 0.32, h * 0.12, 0, 0, Math.PI)
		ctx.fill()

		// Mouth line
		ctx.strokeStyle = '#1a5276'
		ctx.lineWidth = 1
		ctx.beginPath()
		ctx.moveTo(x + w * 0.55, y + h * 0.58)
		ctx.lineTo(x + w * 0.85, y + h * 0.52)
		ctx.stroke()

		// Eye
		ctx.fillStyle = '#fff'
		ctx.beginPath()
		ctx.arc(x + w * 0.65, y + h * 0.38, w * 0.09, 0, Math.PI * 2)
		ctx.fill()
		ctx.strokeStyle = '#1a5276'
		ctx.lineWidth = 1
		ctx.stroke()
		ctx.fillStyle = '#000'
		ctx.beginPath()
		ctx.arc(x + w * 0.67, y + h * 0.38, w * 0.045, 0, Math.PI * 2)
		ctx.fill()

		ctx.restore()
	}

	// ── Game Logic ──

	function moveShark(dx: number, dy: number) {
		if (gameOver) return

		const nx = shark.x + dx
		const ny = shark.y + dy
		if (nx < 0 || nx >= GRID || ny < 0 || ny >= GRID) return

		shark.x = nx
		shark.y = ny
		moveCount++

		// Track facing direction
		if (dx === 1) sharkDir = 'right'
		else if (dx === -1) sharkDir = 'left'
		else if (dy === 1) sharkDir = 'down'
		else if (dy === -1) sharkDir = 'up'

		// Check pickup
		if (pickups[ny][nx]) {
			pickups[ny][nx] = false
			score++
			scoreEl.textContent = String(score)
			// Spawn a new enemy
			enemies.push(spawnEnemy())
		}

		// Check super pickup (15-point coin)
		if (superPickups[ny][nx]) {
			superPickups[ny][nx] = false
			score += 15
			scoreEl.textContent = String(score)
			// Spawn a 2×2 red enemy
			bigEnemies.push(spawnBigEnemy())
		}

		// Spawn new pickups — 1/4000 chance per cell
		for (let r = 0; r < GRID; r++) {
			for (let c = 0; c < GRID; c++) {
				if (!pickups[r][c] && !superPickups[r][c] && Math.random() < 0.00025) {
					if (Math.random() < 0.0175) {
						superPickups[r][c] = true
					} else {
						pickups[r][c] = true
					}
				}
			}
		}

		// Enemies move every 2 player moves
		if (moveCount % 2 === 0) {
			for (const e of enemies) {
				const diffX = shark.x - e.x
				const diffY = shark.y - e.y
				let nx = e.x
				let ny = e.y
				if (Math.abs(diffX) >= Math.abs(diffY)) {
					nx += Math.sign(diffX)
				} else {
					ny += Math.sign(diffY)
				}
				// Only move if no other enemy is already on that square
				const occupied = enemies.some(
					(other) => other !== e && other.x === nx && other.y === ny
				)
				if (!occupied) {
					e.x = nx
					e.y = ny
				}
			}

			// Big enemies also chase the shark
			for (const be of bigEnemies) {
				const diffX = shark.x - be.x
				const diffY = shark.y - be.y
				let nx = be.x
				let ny = be.y
				if (Math.abs(diffX) >= Math.abs(diffY)) {
					nx += Math.sign(diffX)
				} else {
					ny += Math.sign(diffY)
				}
				// Clamp so the 2×2 block stays on the grid
				nx = Math.max(0, Math.min(GRID - 2, nx))
				ny = Math.max(0, Math.min(GRID - 2, ny))
				// Only move if not overlapping another big enemy
				const blocked = bigEnemies.some(
					(other) => other !== be && bigEnemyOverlaps(nx, ny, other.x, other.y)
				)
				if (!blocked) {
					be.x = nx
					be.y = ny
				}
			}
		}

		// Check death
		for (const e of enemies) {
			if (e.x === shark.x && e.y === shark.y) {
				endGame()
				return
			}
		}
		for (const be of bigEnemies) {
			if (
				shark.x >= be.x &&
				shark.x <= be.x + 1 &&
				shark.y >= be.y &&
				shark.y <= be.y + 1
			) {
				endGame()
				return
			}
		}

		startSharkAnim()
	}

	function endGame() {
		gameOver = true
		sharkVisualX = shark.x
		sharkVisualY = shark.y
		draw()
		if (score > highScore) {
			highScore = score
			localStorage.setItem(highScoreKey(), String(highScore))
			highScoreEl.textContent = String(highScore)
		}
		finalScoreEl.textContent = String(score)

		// Reset submit UI — show prompt button, hide name input
		submitPrompt.style.display = score > 0 ? 'block' : 'none'
		nameInputRow.classList.remove('visible')
		submitScoreBtn.disabled = false
		submitStatus.textContent = ''
		const savedName = localStorage.getItem('sharkPlayerName') || ''
		playerNameInput.value = savedName

		overlay.classList.add('visible')
	}

	// Player opts in to submit
	wantToSubmitBtn.addEventListener('click', () => {
		submitPrompt.style.display = 'none'
		nameInputRow.classList.add('visible')
		playerNameInput.focus()
	})

	// ── Leaderboard ──

	const MOCK_SCORES = [
		{ name: 'SharkMaster', score: 18, date: '2026-03-14T09:23:00Z' },
		{ name: 'FinFrenzy', score: 14, date: '2026-03-13T22:15:00Z' },
		{ name: 'OceanKing', score: 11, date: '2026-03-14T14:02:00Z' },
		{ name: 'DeepDiver', score: 9, date: '2026-03-12T18:45:00Z' },
		{ name: 'WaveCatcher', score: 7, date: '2026-03-14T11:30:00Z' },
		{ name: 'CoralQueen', score: 5, date: '2026-03-11T20:10:00Z' },
		{ name: 'TideRunner', score: 4, date: '2026-03-13T16:55:00Z' },
		{ name: 'ReefRaider', score: 3, date: '2026-03-10T08:40:00Z' },
	]

	async function fetchLeaderboard() {
		try {
			const res = await fetch(`/api/scores?map=${currentMap}`)
			if (!res.ok) throw new Error('Failed to fetch')
			const scores = await res.json()
			renderLeaderboard(scores.length > 0 ? scores : MOCK_SCORES)
		} catch {
			renderLeaderboard(MOCK_SCORES)
		}
	}

	function formatDate(iso: string): string {
		try {
			const d = new Date(iso)
			const date = d.toLocaleDateString('en-US', {
				month: 'short',
				day: 'numeric',
				year: 'numeric',
			})
			const time = d.toLocaleTimeString('en-US', {
				hour: 'numeric',
				minute: '2-digit',
			})
			return `${date} · ${time}`
		} catch {
			return ''
		}
	}

	let lastSubmittedDate: string | null = null

	function renderLeaderboard(
		scores: { name: string; score: number; date?: string }[]
	) {
		if (scores.length === 0) {
			leaderboardBody.innerHTML =
				'<tr><td colspan="4" class="empty-board">No scores yet — be the first!</td></tr>'
			return
		}

		const esc = (str: string) =>
			str
				.replace(/&/g, '&amp;')
				.replace(/</g, '&lt;')
				.replace(/>/g, '&gt;')
				.replace(/"/g, '&quot;')

		leaderboardBody.innerHTML = scores
			.map((s, i) => {
				const isHighlight = lastSubmittedDate && s.date === lastSubmittedDate
				const cls = isHighlight ? ' class="highlight"' : ''
				const dateStr = s.date ? formatDate(s.date) : ''
				const medalClasses = ['medal-gold', 'medal-silver', 'medal-bronze']
				const rankDisplay =
					i < 3
						? `<span class="medal ${medalClasses[i]}">${i + 1}</span>`
						: `${i + 1}`
				return `<tr${cls}><td>${rankDisplay}</td><td>${esc(s.name)}</td><td>${s.score}</td><td>${dateStr}</td></tr>`
			})
			.join('')

		// Scroll the highlighted row into view
		if (lastSubmittedDate) {
			const row = leaderboardBody.querySelector('.highlight')
			row?.scrollIntoView({ behavior: 'smooth', block: 'center' })
		}
	}

	submitScoreBtn.addEventListener('click', async () => {
		const name = playerNameInput.value.trim()
		if (!name) {
			submitStatus.textContent = 'Enter your name first!'
			return
		}

		// Client-side bad word check
		const lower = name.toLowerCase()
		const stripped = lower.replace(/[^a-z]/g, '')
		const badWords = [
			'ass',
			'asshole',
			'bastard',
			'bitch',
			'bollocks',
			'bullshit',
			'cock',
			'crap',
			'cunt',
			'damn',
			'dick',
			'douche',
			'fag',
			'faggot',
			'fuck',
			'goddamn',
			'jackass',
			'motherfucker',
			'nigger',
			'nigga',
			'piss',
			'prick',
			'pussy',
			'shit',
			'slut',
			'twat',
			'whore',
			'wanker',
			'chink',
			'gook',
			'kike',
			'spic',
			'wetback',
			'retard',
			'tranny',
			'dyke',
			'blowjob',
			'dildo',
			'handjob',
			'jizz',
			'porn',
			'tits',
			'boobs',
			'penis',
			'vagina',
			'anal',
			'cum',
			'orgasm',
			'nazi',
			'hitler',
			'kkk',
			'rape',
			'molest',
			'pedo',
			'pedophile',
			'phuck',
			'phuk',
			'fuk',
			'fuc',
			'fuq',
			'sh1t',
			'b1tch',
			'kunt',
			'd1ck',
			'a55',
			'n1gga',
			'n1gger',
		]
		if (badWords.some((w) => lower.includes(w) || stripped.includes(w))) {
			submitStatus.textContent = 'Invalid name'
			return
		}

		submitScoreBtn.disabled = true
		submitStatus.textContent = 'Submitting…'
		localStorage.setItem('sharkPlayerName', name)

		try {
			const res = await fetch(`/api/scores?map=${currentMap}`, {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ name, score }),
			})
			if (!res.ok) {
				const msg = await res.text()
				const isHtml = msg.trimStart().startsWith('<')
				submitStatus.textContent = isHtml
					? 'Invalid name'
					: msg || 'Failed to submit — try again'
				submitScoreBtn.disabled = false
				return
			}
			const scores = await res.json()
			// Find the entry we just submitted (most recent with matching name/score)
			const submitted = scores.find(
				(s: { name: string; score: number; date?: string }) =>
					s.name === name && s.score === score && s.date
			)
			lastSubmittedDate = submitted?.date || null
			renderLeaderboard(scores)
			lastSubmittedDate = null
			submitStatus.textContent = 'Score submitted!'
			nameInputRow.classList.remove('visible')
		} catch {
			submitStatus.textContent = 'Failed to submit — try again'
			submitScoreBtn.disabled = false
		}
	})

	// Allow Enter key to submit
	playerNameInput.addEventListener('keydown', (e) => {
		if (e.key === 'Enter') submitScoreBtn.click()
	})

	// ── Controls ──

	document.addEventListener('keydown', (e) => {
		// Don't intercept keys when typing in an input
		if (
			e.target instanceof HTMLInputElement ||
			e.target instanceof HTMLTextAreaElement
		)
			return

		switch (e.key) {
			case 'ArrowUp':
			case 'w':
			case 'W':
				e.preventDefault()
				moveShark(0, -1)
				break
			case 'ArrowDown':
			case 's':
			case 'S':
				e.preventDefault()
				moveShark(0, 1)
				break
			case 'ArrowLeft':
			case 'a':
			case 'A':
				e.preventDefault()
				moveShark(-1, 0)
				break
			case 'ArrowRight':
			case 'd':
			case 'D':
				e.preventDefault()
				moveShark(1, 0)
				break
		}
	})

	// ── D-pad controls ──

	function execDir(dir: string) {
		switch (dir) {
			case 'up':
				moveShark(0, -1)
				break
			case 'down':
				moveShark(0, 1)
				break
			case 'left':
				moveShark(-1, 0)
				break
			case 'right':
				moveShark(1, 0)
				break
		}
	}

	document.querySelectorAll('.dpad-btn').forEach((btn) => {
		const el = btn as HTMLElement
		let repeatTimer: ReturnType<typeof setInterval> | null = null

		const press = () => el.classList.add('pressed')
		const release = () => {
			el.classList.remove('pressed')
			if (repeatTimer) {
				clearInterval(repeatTimer)
				repeatTimer = null
			}
		}

		const startMove = (e: Event) => {
			e.preventDefault()
			press()
			const dir = el.dataset.dir!
			// Haptic feedback
			if (navigator.vibrate) navigator.vibrate(12)
			execDir(dir)
			// Auto-repeat after 200ms delay, then every 100ms
			repeatTimer = setTimeout(() => {
				repeatTimer = setInterval(() => {
					if (navigator.vibrate) navigator.vibrate(8)
					execDir(dir)
				}, 100)
			}, 200) as unknown as ReturnType<typeof setInterval>
		}

		const stopMove = () => release()

		btn.addEventListener('touchstart', startMove, { passive: false })
		btn.addEventListener('touchend', stopMove)
		btn.addEventListener('touchcancel', stopMove)
		btn.addEventListener('click', (e) => {
			e.preventDefault()
			if (navigator.vibrate) navigator.vibrate(12)
			execDir(el.dataset.dir!)
			press()
			setTimeout(release, 150)
		})
	})

	playAgainBtn.addEventListener('click', () => init())

	// ── Map selector ──
	const mapBtns = document.querySelectorAll('.map-btn')
	const MAP_LABELS: Record<MapSize, string> = {
		small: 'Small',
		medium: 'Medium',
	}

	function switchMap(map: MapSize) {
		currentMap = map
		GRID = MAP_GRIDS[map]
		CELL = canvas.width / GRID

		// Update button active state
		mapBtns.forEach((b) => {
			b.classList.toggle('active', (b as HTMLElement).dataset.map === map)
		})

		// Update leaderboard label
		leaderboardMapLabel.textContent = MAP_LABELS[map]

		// Load high score for this map
		highScore = parseInt(localStorage.getItem(highScoreKey()) || '0', 10)
		highScoreEl.textContent = String(highScore)

		// Fetch this map's leaderboard
		fetchLeaderboard()

		// Restart game
		init()
	}

	mapBtns.forEach((btn) => {
		btn.addEventListener('click', () => {
			const map = (btn as HTMLElement).dataset.map as MapSize
			if (map !== currentMap) switchMap(map)
		})
	})

	// Go!
	fetchLeaderboard()
	init()

	// Auto-scroll game into view on touch devices
	if ('ontouchstart' in window) {
		setTimeout(() => {
			const hud = document.querySelector('.game-hud')
			if (hud) hud.scrollIntoView({ behavior: 'smooth', block: 'start' })
		}, 300)
	}
</script>

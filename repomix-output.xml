  :global(main):has(.shark-ios-app) {
    padding: 0;
    margin: 0;
    height: 100dvh;
    overflow: hidden;
    background: #0a1f2e;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .shark-ios-app {
    width: 100%;
    height: 100dvh;
    overflow: hidden;
    touch-action: manipulation;
    background: var(--ocean-abyss);
    color: var(--text-primary);
    position: relative;
  }

  /* ── Screens ── */
  .screen {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100dvh;
    overflow-y: auto;
    width: 100%;
    padding: 2rem 1.6rem;
    box-sizing: border-box;
    position: relative;

    &.active {
      display: flex;
    }
  }

  /* scanline overlay — all non-game screens */
  .screen:not(.game-screen)::after {
    content: "";

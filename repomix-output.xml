<file path="src/layouts/BaseLayout.astro">
---
import { Font } from 'astro:assets'
import Header from '../components/Header.astro'
import TypographyHero from '../components/TypographyHero.astro'
import Footer from '../components/Footer.astro'
import 'modern-normalize/modern-normalize.css'
import Variables from '../components/Variables.astro'
import '../styles/global/_variables.scss'
import '../styles/global.scss'
import '../styles/global/_typography.scss'
import '../styles/global/_header.scss'
import '../styles/global/_layout.scss'
import '../styles/global/_content.scss'
import '../styles/global/_button.scss'
import '../styles/global/_solo-line.scss'
import '../styles/global/_article.scss'
import '../styles/global/_external-links.scss'
import '../styles/global/_animation.scss'
const {
	pageTitle,
	subTitle,
	showSidebar,
	showTypographyHero = true,
	theme = '',
	fullWidthBody = false,
	pubDate,
	description = 'Sample Description',
} = Astro.props
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon-dv.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<Font cssVariable="--font-source-serif" preload />
		<Font cssVariable="--font-poppins" preload />

		<slot name="head" />
		<Variables />
	</head>
	<body class={`${fullWidthBody ? 'full-width-body' : ''} ${theme}`}>
		<a href="#main-content" class="skip-link">Skip to main content</a>
		<div
			class={[
				'site',
				showSidebar ? 'sidebar' : '',
				fullWidthBody ? 'full-width-body' : '',
			]
				.filter(Boolean)
				.join(' ')}>
			<Header />
			<main id="main-content">
				{
					showTypographyHero && (
						<TypographyHero
							pageTitle={pageTitle}
							subTitle={subTitle}
							theme={theme}
						/>
					)
				}
				<slot />
			</main>
			{
				showSidebar && (
					<aside>
						<div class="sidebar-item">
							<h3>Thoughts</h3>
						</div>
					</aside>
				)
			}
			<Footer />
		</div>
	</body>
</html>
</file>

<file path="src/layouts/MarkdownPostLayout.astro">
---
import BaseLayout from './BaseLayout.astro'
import BlogDetails from '../components/BlogDetails.astro'
import AstroImage from '../components/AstroImage.astro'

const { frontmatter } = Astro.props
---

<BaseLayout pageTitle={frontmatter.title} description={frontmatter.description}>
	<div class="article">
		<BlogDetails {...frontmatter} />
		<p>
			<em>{frontmatter.description}</em>
		</p>
		<AstroImage
			src={frontmatter.image.url}
			width="300"
			height="300"
			fit="cover"
			alt={frontmatter.image.alt}
		/>
		<div class="tags">
			{
				frontmatter.tags.map((tag) => (
					<p class="tag">
						<a href={`/tags/${tag}`}>{tag}</a>
					</p>
				))
			}
		</div>
		<slot />
	</div>
</BaseLayout>
<style>
	a {
		color: #00539f;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
	}

	.tag {
		margin: 0.25em;
		border: dotted 1px #a1a1a1;
		border-radius: 0.5em;
		padding: 0.5em 1em;
		font-size: 1.15em;
		background-color: #f8fcfd;
	}
</style>
</file>

<file path="src/pages/play/cat-background-slider.astro">
---
import BaseLayout from '../../layouts/BaseLayout.astro'
import BlogDetails from '../../components/BlogDetails.astro'
import CodeBlock from '../../components/CodeBlock.astro'
import CatSVGFile from '../../svgs/cat.svg?raw'
import '../../styles/module/_slider.scss'

import katex from 'katex'
import 'katex/dist/katex.min.css'

const mathExpressions = [
	{
		id: 'scaleFactor',
		expression: 's = 1 + \\frac{\\text{slider} - 100}{100}',
		description: 'Scale factor from slider value',
	},
	{
		id: 'scaleExample',
		expression: 's = 1 + \\frac{250 - 100}{100} = 2.5',
		description: 'Example with slider at 250',
	},
	{
		id: 'newWidth',
		expression: '\\text{newWidth} = 500 \\times 2.5 = 1250',
		description: 'New tile width',
	},
	{
		id: 'newHeight',
		expression: '\\text{newHeight} = 300 \\times 2.5 = 750',
		description: 'New tile height',
	},
	{
		id: 'centerX',
		expression: 'x = 75 - \\frac{1250 - 500}{2} = -300',
		description: 'Centering offset X',
	},
	{
		id: 'centerY',
		expression: 'y = 75 - \\frac{750 - 300}{2} = -150',
		description: 'Centering offset Y',
	},
	{
		id: 'bgSize',
		expression:
			'\\text{bgSize} = \\frac{1250}{5} \\times \\frac{750}{5} = 250 \\times 150 \\text{ px}',
		description: 'Background tile pixel size',
	},
]

const renderedMath = mathExpressions.map((item) => ({
	id: item.id,
	html: katex.renderToString(item.expression, {
		throwOnError: false,
		displayMode: true,
	}),
	description: item.description,
}))

export const blogData = {
	title: 'Cat Background Slider',
	author: 'David Volz',
	description: `How I built a tiled SVG background with adjustable spacing using vanilla JavaScript.`,
	image: {
		url: 'https://docs.astro.build/assets/arc.webp',
		alt: 'The Astro logo on a dark background with a purple gradient arc.',
	},
	pubDate: '2026-3-1',
	tags: ['javascript', 'svg', 'css', 'code'],
	featured: true,
	display: true,
}
const showTypographyHero = true
const fullWidthBody = true

const importCode = `---
import CatSVGFile from '../svgs/cat.svg?raw'
---

<div id="cat-svg" data-svg={CatSVGFile}>
  <Fragment set:html={CatSVGFile} />
</div>`

const encodeCode = `function encodeSVG(svg: string): string {
  return \`data:image/svg+xml,\${encodeURIComponent(svg)}\`
}`

const viewBoxCode = `const BASE_WIDTH = 500
const BASE_HEIGHT = 300
const BASE_X = 75
const BASE_Y = 75

function updateSVGViewBox(spacing: number): void {
  // Scale factor: slider 100 = 1x, slider 600 = 6x
  const scaleFactor = 1 + (spacing - 100) / 100

  // Expand viewBox to add transparent padding around cat
  const newWidth = BASE_WIDTH * scaleFactor
  const newHeight = BASE_HEIGHT * scaleFactor

  // Center the cat in the expanded viewBox
  const newX = BASE_X - (newWidth - BASE_WIDTH) / 2
  const newY = BASE_Y - (newHeight - BASE_HEIGHT) / 2

  const updatedViewBox = \`\${newX} \${newY} \${newWidth} \${newHeight}\`

  const updatedSVG = rawSVG.replace(
    /<svg[^>]+>/,
    \`<svg xmlns="http://www.w3.org/2000/svg"
      viewBox="\${updatedViewBox}" opacity="0.2">\`
  )

  body.style.backgroundImage = \`url('\${encodeSVG(updatedSVG)}')\`
  body.style.backgroundSize = \`\${newWidth / 5}px \${newHeight / 5}px\`
}`

const sliderCode = `<input id="spacing-slider" type="range"
  min="100" max="600" value="250" />

<script>
  slider.addEventListener('input', (event) => {
    const target = event.target as HTMLInputElement
    spacing = parseInt(target.value, 10)
    updateSVGViewBox(spacing)
    localStorage.setItem('backgroundSpacing',
      JSON.stringify(spacing))
  })
</script>`

const localStorageCode = `// Restore state on page load
let isBackgroundSet =
  JSON.parse(localStorage.getItem('isBackgroundSet')) || false
let spacing =
  JSON.parse(localStorage.getItem('backgroundSpacing')) || 250

// Save state on change
localStorage.setItem('isBackgroundSet',
  JSON.stringify(isBackgroundSet))
localStorage.setItem('backgroundSpacing',
  JSON.stringify(spacing))`
---

<BaseLayout
	pageTitle={blogData.title}
	{showTypographyHero}
	description={blogData.description}
	fullWidthBody={fullWidthBody}>
	<div class="details-width">
		<BlogDetails {...blogData} />
	</div>
	<div class="article">
		<p>
			If you have been on this site before, you may have noticed the little cat
			icon in the footer. All my life this cat has been my signature character
			that I have drawn consistently. Clicking it toggles a tiled cat pattern
			across the entire page background, and a slider appears to control the
			spacing between the cats. Here is how I built it.
		</p>

		<h3>Loading the SVG</h3>
		<p>
			The cat SVG is imported as a raw string using the <code>?raw</code> suffix.
			This gives us access to the full SVG markup at build time so we can manipulate
			it with JavaScript at runtime. The raw string is also stored in a <code
				>data-svg</code
			> attribute so the client-side script can access it.
		</p>
		<CodeBlock code={importCode} lang="astro" />
		<p>
			I use <code>Fragment</code> with <code>set:html</code> to render the SVG inline
			for the clickable cat icon. The <code>data-svg</code> attribute holds the same
			raw string that the JavaScript reads later to build the background.
		</p>

		<h3>Encoding for CSS</h3>
		<p>
			To use an SVG as a CSS <code>background-image</code>, it needs to be
			encoded as a data URI. Rather than base64, I use
			<code>encodeURIComponent</code> which keeps the string readable and is perfectly
			valid for inline SVGs.
		</p>
		<CodeBlock code={encodeCode} lang="typescript" />

		<h3>The ViewBox Trick</h3>
		<p>
			This is the core of how the spacing works. Instead of changing the
			background tile size or moving elements around, I expand the SVG's
			<code>viewBox</code>. A larger viewBox means more transparent space around
			the cat, and since the browser tiles the background, that transparent
			space becomes the gap between cats.
		</p>
		<CodeBlock code={viewBoxCode} lang="typescript" />
		<p>
			The key insight is that <code>background-size</code> scales proportionally with
			the viewBox. The formula <code>newWidth / 5</code> keeps each cat at a constant
			visual size. As the slider increases, the tile grows but the cat inside it stays
			the same size, so you only see more space between them.
		</p>

		<h3>The Math</h3>
		<p>
			The slider value (100–600) maps to a scale factor. At 100, the viewBox is
			the original size. At 600, it is 6× larger.
		</p>
		<h5>Scale Factor</h5>
		<div class="math">
			<p set:html={renderedMath.find(({ id }) => id === 'scaleFactor').html} />
		</div>
		<p>With the slider at its default of 250:</p>
		<div class="math">
			<p set:html={renderedMath.find(({ id }) => id === 'scaleExample').html} />
		</div>

		<h5>Expanding the ViewBox</h5>
		<p>
			The base viewBox is <code>75 75 500 300</code>. Multiply width and height
			by the scale factor:
		</p>
		<div class="math">
			<p set:html={renderedMath.find(({ id }) => id === 'newWidth').html} />
		</div>
		<div class="math">
			<p set:html={renderedMath.find(({ id }) => id === 'newHeight').html} />
		</div>

		<h5>Centering the Cat</h5>
		<p>Shift the origin back by half the growth so the cat stays centered:</p>
		<div class="math">
			<p set:html={renderedMath.find(({ id }) => id === 'centerX').html} />
		</div>
		<div class="math">
			<p set:html={renderedMath.find(({ id }) => id === 'centerY').html} />
		</div>
		<p>
			So the new viewBox becomes <code>-300 -150 1250 750</code>.
		</p>

		<h5>Background Size</h5>
		<p>Divide by 5 to get the CSS pixel size of each tile:</p>
		<div class="math">
			<p set:html={renderedMath.find(({ id }) => id === 'bgSize').html} />
		</div>
		<p>
			The cat stays the same visual size inside a bigger tile, which is why you
			see more space between the cats.
		</p>

		<h3>Try It</h3>
		<p>
			Here is a live demo. The dashed grid shows the tile boundaries. Drag the
			slider to see how the tile grows while the cat stays the same size.
		</p>
	</div>

	<div class="demo-container">
		<div class="demo-box" id="demo-box" data-svg={CatSVGFile}></div>
		<div class="demo-controls">
			<label for="demo-slider">Spacing</label>
			<input id="demo-slider" type="range" min="100" max="600" value="250" />
			<span id="demo-slider-value" class="demo-value">250</span>
		</div>
	</div>

	<div class="article">
		<h3>The Slider</h3>
		<p>
			The range input drives the spacing value from 100 to 600. On each input
			event, it recalculates the viewBox and updates the background. The slider
			value is also persisted to <code>localStorage</code> so it sticks across page
			loads.
		</p>
		<CodeBlock code={sliderCode} lang="astro" />

		<h3>Persisting State</h3>
		<p>
			Both the toggle state and the spacing value are saved to
			<code>localStorage</code>. When the page loads, the script checks for
			saved values and applies them immediately. This way, if you set your
			preferred cat density, it is still there when you come back.
		</p>
		<CodeBlock code={localStorageCode} lang="typescript" />

		<h3>Final Thoughts</h3>
		<p>
			This was a fun little feature to build. The viewBox approach turned out to
			be a clean way to handle tiled spacing without needing to regenerate the
			SVG on every slider tick. The cat stays the same size, the gaps grow, and
			the whole thing is just a few lines of vanilla JavaScript. Give it a try
			by clicking the cat in the footer.
		</p>
	</div>
</BaseLayout>

<style lang="scss">
	.demo-container {
		margin: 2rem auto 3rem;
		max-width: 1260px;
		padding: 0 2rem;
	}
	.demo-box {
		height: 30rem;
		border: 1px solid var(--text-color);

		@media screen and (min-width: 768px) {
			height: 50rem;
		}
		border-radius: 0.8rem;
		margin-bottom: 1.5rem;
		background-color: var(--background-color);
		background-repeat: repeat;
		position: relative;
		overflow: hidden;
	}
	.demo-controls {
		text-align: center;
		label {
			display: block;
			font-family: var(--a-font);
			margin-bottom: 1rem;
		}
	}
	.demo-value {
		font-family: var(--a-font);
		font-size: 3rem;
	}
	.math {
		margin: 0 0 2rem;
		text-align: center;
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const demoBox = document.getElementById('demo-box') as HTMLElement
		const demoSlider = document.getElementById(
			'demo-slider'
		) as HTMLInputElement
		const demoValue = document.getElementById(
			'demo-slider-value'
		) as HTMLSpanElement
		const rawSVG = demoBox.getAttribute('data-svg')
		if (!rawSVG) return

		const BASE_WIDTH = 500
		const BASE_HEIGHT = 300
		const BASE_X = 75
		const BASE_Y = 75
		const svgTagRegex = /<svg[^>]+>/

		// Get theme colors for the tile outlines
		const bodyStyles = getComputedStyle(document.body)
		const accentColor =
			bodyStyles.getPropertyValue('--accent-color').trim() || '#5bb598'
		const secondaryColor =
			bodyStyles.getPropertyValue('--secondary-color').trim() || '#568091'

		function encodeSVG(svg: string): string {
			return `data:image/svg+xml,${encodeURIComponent(svg)}`
		}

		function updateDemo(spacing: number): void {
			const scaleFactor = 1 + (spacing - 100) / 100
			const newWidth = BASE_WIDTH * scaleFactor
			const newHeight = BASE_HEIGHT * scaleFactor
			const newX = BASE_X - (newWidth - BASE_WIDTH) / 2
			const newY = BASE_Y - (newHeight - BASE_HEIGHT) / 2
			const updatedViewBox = `${newX} ${newY} ${newWidth} ${newHeight}`

			// Build cat SVG with double-line tile borders
			const inset = scaleFactor * 10
			const updatedSVG = rawSVG
				.replace(
					svgTagRegex,
					`<svg xmlns="http://www.w3.org/2000/svg" viewBox="${updatedViewBox}">` +
						// Outer border - accent colored dots
						`<rect x="${newX}" y="${newY}" width="${newWidth}" height="${newHeight}" ` +
						`fill="none" stroke="${accentColor}" stroke-width="${scaleFactor * 4}" ` +
						`stroke-linecap="round" stroke-dasharray="${scaleFactor} ${scaleFactor * 14}" opacity="0.5"/>` +
						// Inner border - secondary colored dots, offset inward
						`<rect x="${newX + inset}" y="${newY + inset}" width="${newWidth - inset * 2}" height="${newHeight - inset * 2}" ` +
						`fill="none" stroke="${secondaryColor}" stroke-width="${scaleFactor * 2}" ` +
						`stroke-linecap="round" stroke-dasharray="${scaleFactor * 0.5} ${scaleFactor * 10}" opacity="0.35"/>` +
						`<g opacity="0.2">`
				)
				.replace('</svg>', '</g></svg>')

			const bgWidth = newWidth / 5
			const bgHeight = newHeight / 5

			demoBox.style.backgroundImage = `url('${encodeSVG(updatedSVG)}')`
			demoBox.style.backgroundSize = `${bgWidth}px ${bgHeight}px`
		}

		// Initial render
		updateDemo(250)

		demoSlider.addEventListener('input', (event) => {
			const target = event.target as HTMLInputElement
			const spacing = parseInt(target.value, 10)
			demoValue.textContent = spacing.toString()
			updateDemo(spacing)
		})
	})
</script>
</file>

<file path="src/pages/play/resume.astro">
---
import BaseLayout from '../../layouts/BaseLayout.astro'
import BlogDetails from '../../components/BlogDetails.astro'
import resumeData from '../../data/resume.json'

export const blogData = {
	title: 'Resume',
	author: 'David Volz',
	description: 'A data-driven resume page built with Astro.',
	image: {
		url: 'https://docs.astro.build/assets/arc.webp',
		alt: 'The Astro logo on a dark background with a purple gradient arc.',
	},
	pubDate: '2026-3-14',
	tags: ['code', 'design'],
	featured: false,
	display: false,
}

const showTypographyHero = true
const fullWidthBody = false
---

<style lang="scss">
	/* ── Article Toggle ── */
	.article-toggle-wrapper {
		max-width: 55rem;
		margin: 0 auto 3rem;
		text-align: center;
	}
	.article-toggle {
		display: inline-flex;
		align-items: center;
		gap: 0.8rem;
		background: none;
		border: 1px solid var(--text-color);
		border-radius: 0.6rem;
		padding: 0.8rem 2rem;
		font-family: var(--a-font);
		font-size: 1.6rem;
		font-weight: 600;
		color: var(--text-color);
		cursor: pointer;
		transition: all 0.3s ease;
		&:hover {
			background: var(--text-color);
			color: var(--background-color);
		}
		.toggle-icon {
			display: inline-block;
			transition: transform 0.3s ease;
			font-size: 1.2rem;
		}
		&[aria-expanded='true'] .toggle-icon {
			transform: rotate(90deg);
		}
	}
	.article-content {
		max-height: 0;
		overflow: hidden;
		transition:
			max-height 0.5s ease,
			opacity 0.4s ease;
		opacity: 0;
		&.open {
			opacity: 1;
			max-height: 200rem;
		}
	}

	/* ── Resume ── */
	.resume {
		max-width: 80rem;
		margin: 0 auto;
		padding: 0 2rem;
	}

	.resume-header {
		text-align: center;
		margin-bottom: 3rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--text-color);
	}
	.resume-header h2 {
		font-family: var(--a-font);
		font-size: 3rem;
		margin: 0 0 0.3rem;
	}
	.resume-header .resume-title {
		font-size: 1.8rem;
		font-weight: 300;
		margin: 0 0 1.5rem;
		opacity: 0.85;
	}
	.contact-list {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 1rem 2rem;
		padding: 0;
		margin: 0;
		font-size: 1.5rem;
		a {
			color: var(--link-color);
			&:hover {
				color: var(--link-hover);
			}
		}
	}
	.contact-list li {
		white-space: nowrap;
	}

	/* ── Sections ── */
	.resume-section {
		margin-bottom: 3.5rem;
	}
	.resume-section h3 {
		font-family: var(--a-font);
		font-size: 2.2rem;
		font-weight: 700;
		margin: 0 0 1.5rem;
		padding-bottom: 0.6rem;
		border-bottom: 1px solid var(--text-color);
	}

	/* ── Summary ── */
	.resume-summary p {
		font-size: 1.7rem;
		line-height: 1.7;
		margin: 0;
	}

	/* ── Experience ── */
	.experience-item {
		margin-bottom: 2.5rem;
		&:last-child {
			margin-bottom: 0;
		}
	}
	.experience-item .role-line {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: 0.2rem;
	}
	.role-line h4 {
		font-family: var(--a-font);
		font-size: 1.9rem;
		font-weight: 600;
		margin: 0;
	}
	.role-line .dates {
		font-size: 1.4rem;
		font-weight: 300;
		opacity: 0.8;
		white-space: nowrap;
	}
	.experience-item .company-line {
		font-size: 1.5rem;
		font-weight: 400;
		margin: 0 0 0.8rem;
		opacity: 0.85;
	}
	.experience-item ul {
		padding-left: 2rem;
		margin: 0;
	}
	.experience-item li {
		margin-bottom: 0.5rem;
		font-size: 1.6rem;
		line-height: 1.5;
	}

	/* ── Skills ── */
	.skills-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
		gap: 2rem;
	}
	.skill-group h4 {
		font-family: var(--a-font);
		font-size: 1.7rem;
		font-weight: 600;
		margin: 0 0 0.6rem;
	}
	.skill-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.skill-tags li {
		padding: 0.4rem 1rem;
		border: 1px solid var(--text-color);
		border-radius: 0.4rem;
		font-size: 1.4rem;
		white-space: nowrap;
		transition: all 0.3s ease;
	}

	/* ── Education ── */
	.education-item {
		margin-bottom: 1.5rem;
		&:last-child {
			margin-bottom: 0;
		}
	}
	.education-item .degree-line {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: baseline;
	}
	.degree-line h4 {
		font-family: var(--a-font);
		font-size: 1.9rem;
		font-weight: 600;
		margin: 0;
	}
	.degree-line .year {
		font-size: 1.4rem;
		font-weight: 300;
		opacity: 0.8;
	}
	.education-item .institution {
		font-size: 1.5rem;
		margin: 0;
		opacity: 0.85;
	}

	/* ── Projects ── */
	.project-item {
		margin-bottom: 1.5rem;
		&:last-child {
			margin-bottom: 0;
		}
	}
	.project-item h4 {
		font-family: var(--a-font);
		font-size: 1.8rem;
		font-weight: 600;
		margin: 0 0 0.3rem;
	}
	.project-item p {
		font-size: 1.6rem;
		margin: 0;
		line-height: 1.5;
	}
</style>

<BaseLayout
	pageTitle={blogData.title}
	{showTypographyHero}
	description={blogData.description}
	fullWidthBody={fullWidthBody}>
	<div class="details-width">
		<BlogDetails {...blogData} />
	</div>

	<!-- Article toggle -->
	<div class="article-toggle-wrapper">
		<button
			class="article-toggle"
			aria-expanded="false"
			aria-controls="article-content">
			<span class="toggle-icon">▶</span> View Article
		</button>
	</div>

	<div id="article-content" class="article-content">
		<div class="article">
			<p>
				I wanted to build a resume page that lives right on my site instead of
				being a static PDF. The data lives in a single JSON file, which means I
				can update my experience, skills, and projects in one place and the page
				rebuilds itself.
			</p>
			<p>
				The JSON structure covers all the standard resume categories — contact
				info, summary, experience, skills, education, certifications, and
				projects. Astro reads it at build time and renders everything into
				semantic HTML with styles consistent with the rest of the site.
			</p>
			<h3>How It Works</h3>
			<p>
				The resume data is imported from <code>src/data/resume.json</code>. Each
				section maps to a block in the template. Experience entries loop out
				with role, company, dates, and bullet-point highlights. Skills are
				displayed in a responsive grid of tagged groups. Education and projects
				round it out.
			</p>
			<p>
				Since everything is data-driven, adding a new job or skill is just
				editing the JSON — no template changes needed.
			</p>
		</div>
	</div>

	<!-- Resume content -->
	<div class="resume">
		<div class="resume-header">
			<h2>{resumeData.name}</h2>
			<p class="resume-title">{resumeData.title}</p>
			<ul class="contact-list">
				{resumeData.contact.email && <li>{resumeData.contact.email}</li>}
				{resumeData.contact.location && <li>{resumeData.contact.location}</li>}
				{
					resumeData.contact.website && (
						<li>
							<a href={resumeData.contact.website} target="_blank">
								{resumeData.contact.website.replace('https://', '')}
							</a>
						</li>
					)
				}
				{
					resumeData.contact.linkedin && (
						<li>
							<a href={resumeData.contact.linkedin} target="_blank">
								LinkedIn
							</a>
						</li>
					)
				}
				{
					resumeData.contact.github && (
						<li>
							<a href={resumeData.contact.github} target="_blank">
								GitHub
							</a>
						</li>
					)
				}
			</ul>
		</div>

		{
			resumeData.summary && (
				<div class="resume-section resume-summary">
					<h3>Summary</h3>
					<p>{resumeData.summary}</p>
				</div>
			)
		}

		{
			resumeData.experience.length > 0 && (
				<div class="resume-section">
					<h3>Experience</h3>
					{resumeData.experience.map((job) => (
						<div class="experience-item">
							<div class="role-line">
								<h4>{job.role}</h4>
								<span class="dates">
									{job.startDate} — {job.endDate}
								</span>
							</div>
							<p class="company-line">
								{job.company} · {job.location}
							</p>
							{job.highlights.length > 0 && (
								<ul>
									{job.highlights.map((h) => (
										<li>{h}</li>
									))}
								</ul>
							)}
						</div>
					))}
				</div>
			)
		}

		{
			resumeData.skills.length > 0 && (
				<div class="resume-section">
					<h3>Skills</h3>
					<div class="skills-grid">
						{resumeData.skills.map((group) => (
							<div class="skill-group">
								<h4>{group.category}</h4>
								<ul class="skill-tags">
									{group.items.map((item) => (
										<li>{item}</li>
									))}
								</ul>
							</div>
						))}
					</div>
				</div>
			)
		}

		{
			resumeData.education.length > 0 && (
				<div class="resume-section">
					<h3>Education</h3>
					{resumeData.education.map((edu) => (
						<div class="education-item">
							<div class="degree-line">
								<h4>{edu.degree}</h4>
								<span class="year">{edu.graduationYear}</span>
							</div>
							<p class="institution">
								{edu.institution} · {edu.location}
							</p>
						</div>
					))}
				</div>
			)
		}

		{
			resumeData.certifications && resumeData.certifications.length > 0 && (
				<div class="resume-section">
					<h3>Certifications</h3>
					<ul>
						{resumeData.certifications.map((cert) => (
							<li>{cert}</li>
						))}
					</ul>
				</div>
			)
		}

		{
			resumeData.projects && resumeData.projects.length > 0 && (
				<div class="resume-section">
					<h3>Projects</h3>
					{resumeData.projects.map((proj) => (
						<div class="project-item">
							<h4>
								{proj.url ? (
									<a href={proj.url} target="_blank">
										{proj.name}
									</a>
								) : (
									proj.name
								)}
							</h4>
							<p>{proj.description}</p>
						</div>
					))}
				</div>
			)
		}
	</div>
</BaseLayout>

<script>
	const toggle = document.querySelector('.article-toggle')
	const content = document.getElementById('article-content')

	toggle?.addEventListener('click', () => {
		const isOpen = content?.classList.toggle('open')
		toggle.setAttribute('aria-expanded', String(isOpen))

		const label = toggle.querySelector('.toggle-icon')
		if (label) {
			// Icon rotation is handled by CSS via aria-expanded
		}
	})
</script>
</file>

<file path="src/pages/play/shapes-and-grids.astro">
---
import BaseLayout from '../../layouts/BaseLayout.astro'
import BlogDetails from '../../components/BlogDetails.astro'
import { Icon } from 'astro-icon/components'

export const blogData = {
	title: 'Shapes and Grids',
	author: 'David Volz',
	description: `Playing with some shapes and grids.`,
	image: {
		url: 'https://docs.astro.build/assets/arc.webp',
		alt: 'The Astro logo on a dark background with a purple gradient arc.',
	},
	display: true,
	pubDate: '2024-11-22',
	tags: ['css', 'code', 'design', 'fluff'],
	featured: true,
}
const showTypographyHero = true
const theme = 'inverted'
const fullWidthBody = true
import '../../styles/themes/_inverted.scss'
import '../../styles/module/_slider.scss'

// Math
import katex from 'katex'
import 'katex/dist/katex.min.css'

// Define the math expressions and their corresponding descriptions
const mathExpressions = [
	{ id: 'w', expression: 'w = 60\\%', description: 'Width percentage' },
	{
		id: 'smallColumnWidth',
		expression: 'smallColumnWidth = 100 - w',
		description: 'Small column width',
	},
	{
		id: 'boxWidth',
		expression: 'boxWidth = 100 - (smallColumnWidth \\times 2)',
		description: 'Box width',
	},
	{
		id: 'gaussianIntegral',
		expression: '\\int_{-\\infty}^\\infty e^{-x^2} \\, dx = \\sqrt{\\pi}',
		description: 'Integral of a Gaussian',
	},
	{
		id: 'seriesSum',
		expression: '\\sum_{n=1}^\\infty \\frac{1}{n^2} = \\frac{\\pi^2}{6}',
		description: 'Sum of the Basel problem',
	},
]

// Render all math expressions using KaTeX
const renderedMath = mathExpressions.map((item) => ({
	id: item.id,
	html: katex.renderToString(item.expression, { throwOnError: false }),
	description: item.description,
}))
---

<style lang="scss">
	.example-box {
		display: flex;
		flex-flow: row wrap;
		position: relative;
		width: calc(100vw - 4rem);
		margin-left: calc(-50vw + 50%); /* Center align the figure */
		transform: translateX(2rem);
		margin-bottom: 3rem;

		.column {
			flex: 1 1 0px;
			border: 0.1rem solid var(--text-color);
			height: 25vw;
			display: flex;
			justify-content: center;
			align-items: center;
			text-align: center;
			// Top and Bottom
			&:nth-child(1),
			&:nth-child(2) {
				border-bottom: none;
			}

			// Left
			&:nth-child(1),
			&:nth-child(3) {
				border-right: none;
			}

			// 56
			--width-a: 60%;
			&:nth-child(1),
			&:nth-child(4) {
				flex: 0 0 var(--width-a);
			}
			// 44
			--width-b: 40%;
			&:nth-child(2),
			&:nth-child(3) {
				flex: 0 0 var(--width-b);
			}
		}
		.box {
			position: absolute;
			left: 50%;
			top: 50%;
			transform: translate(-50%, -50%);
			width: 20.1%;
			padding-bottom: 20%;
			border: 0.1rem solid var(--text-color);
			background: var(--background-color);
		}
	}
	.result {
		font:
			normal 2rem KaTeX_Main,
			Times New Roman,
			serif;
	}
	.math {
		margin: 0 0 3rem;
	}

	// Resize
	.resize-handle {
		width: 3rem;
		height: 3rem;
		background-color: var(--background-color);
		border: 0.1rem solid var(--text-color);
		position: absolute;
		top: 0;
		right: 0;
		cursor: col-resize;
		display: flex;
		justify-content: center;
		align-items: center;
	}
</style>

<script>
	const resizeHandle = document.querySelector('.resize-handle')
	const resizableBox = document.querySelector('.example-box')
	const body = document.body

	let isResizing = false

	// Add both mouse and touch event listeners
	resizeHandle.addEventListener('mousedown', startResize)
	resizeHandle.addEventListener('touchstart', startResize, { passive: false })

	function startResize(e) {
		e.preventDefault() // Prevent default touch actions on mobile
		isResizing = true

		// Add mouse and touch move/up listeners to the document
		document.addEventListener('mousemove', onMouseMove)
		document.addEventListener('mouseup', onMouseUp)
		document.addEventListener('touchmove', onTouchMove, { passive: false })
		document.addEventListener('touchend', onMouseUp)
	}

	function onMouseMove(e) {
		handleResize(e.clientX)
	}

	function onTouchMove(e) {
		// Use the first touch point for resizing
		const touch = e.touches[0]
		handleResize(touch.clientX)
	}

	function handleResize(clientX) {
		if (isResizing) {
			// Calculate the new width
			const width = clientX - resizableBox.offsetLeft

			// Prevent the box from exceeding the viewport width
			const maxWidth = body.clientWidth
			if (width <= maxWidth && width >= 100) {
				// Ensure a minimum width
				resizableBox.style.width = `${width}px`
			}
		}
	}

	function onMouseUp() {
		if (isResizing) {
			isResizing = false

			// Clean up event listeners
			document.removeEventListener('mousemove', onMouseMove)
			document.removeEventListener('mouseup', onMouseUp)
			document.removeEventListener('touchmove', onTouchMove)
			document.removeEventListener('touchend', onMouseUp)
		}
	}
</script>
<BaseLayout
	pageTitle={blogData.title}
	{showTypographyHero}
	description={blogData.description}
	theme={theme}
	fullWidthBody={fullWidthBody}
	display={blogData.display}>
	<div class="details-width">
		<BlogDetails {...blogData} />
	</div>
	<div class="article">
		<h3>The Design</h3>
		<p>
			A couple years back I was working a site that had a layout that stuck in
			my mind far after completing it. It had two rows. Both rows had two
			columns with about a 3/5 width and a 2/5 width. The first row had the big
			column on the left and then the second row had the big column on the
			right.
		</p>
		<p>
			The design also featured a centered square that dynamically aligned with
			the inner edges of the columns, maintaining its proportions as the screen
			size changed. At the time I just played with the percentages until
			everything lined up. I wanted to revisit this design to see if I could
			make it interactive.
		</p>
		<p class="instruction">
			Click and drag the resize handle to see how the columns and box adjust.
		</p>
	</div>

	<div class="row example-box">
		<div class="column example-column"></div>
		<div class="column example-column"></div>
		<div class="column example-column"></div>
		<div class="column example-column"></div>
		<div class="box"></div>
		<div class="resize-handle">
			<Icon
				name="mdi:arrow-split-vertical"
				style="stroke: var(--text-color); stroke-width: .3;"
			/>
		</div>
	</div>
	<div class="article">
		<h4>Responsive Squares</h4>
		<p>
			Before encountering this design, I had known that if you give a block
			element a padding-bottom of 100% it would render as a square as long as it
			had a 100% width. What I didn't know was that you could give it a width of
			50% and a padding-bottom of 50% and it would still render as a square. So
			knowing this, I can resize the square along with the columns and still
			keep the proportions of a square.
		</p>
		<p>
			Looking into it a little further I learned when you set padding-bottom:
			100% on a div, the height of the padding becomes 100% of the width of the
			div. Since padding adds space inside the div without directly affecting
			its width, this effectively creates a box where the height equals the
			width.
		</p>
		<p>Please humor me while I display this below real quick.</p>
		<style>
			.width-box {
				border: 0.1rem solid var(--text-color);
				margin: 0 auto 2rem;
				position: relative;
				text-align: center;
				p {
					position: absolute;
					top: 50%;
					transform: translateY(-50%);
					left: 0;
					width: 100%;
					font-style: italic;
					font-weight: 200;
					font-size: 2.2rem;
					padding: 0.5rem;
				}
			}
			.box-1 {
				width: 50%;
				padding-bottom: 50%;
			}
			.box-2 {
				width: 75%;
				padding-bottom: 75%;
			}
			.box-3 {
				width: 50%;
				aspect-ratio: 1/1;
			}
		</style>
		<div class="box-1 width-box">
			<p>
				width = 50%<br />
				padding-bottom = 50%
			</p>
		</div>
		<div class="box-2 width-box">
			<p>
				width = 75%<br />
				padding-bottom = 75%
			</p>
		</div>
		<h4>Aspect Ratio</h4>
		<p>
			All this padding-bottom talk isn't really necessary anymore with the
			advent of <code>aspect-ratio</code>. This is a much cleaner and
			straightforward approach.
		</p>
		<div class="box-3 width-box">
			<p>
				width = 50%<br />
				aspect-ratio = 1/1
			</p>
		</div>
		<h4>Square Positioning</h4>
		<p>
			In order to keep the square centered while having its width change I am
			absolutely positioning the square. I noticed that at certain widths the
			border of the square is not perfectly aligned with the column on the
			right. It isn't off by much, but the line looks thicker than the line on
			the left. If I adjust it to look good at one resolution it glitches at
			other resolutions.
		</p>
		<p>
			I tried a completely different layout where I use flex to position the
			square and used aspect-ratio to maintain the square shape but it had the
			same issue. This is an issue I will not go down the rabbit hole to fix as
			there are no project requirements.
		</p>
		<p>
			If this was a real project, I would suggest having larger borders to hide
			the inconsistency as long as that aligned with design's goals.
		</p>

		<h3>The Idea</h3>
		<p>
			I had the idea to make a slider that controls the width of all the
			elements inside. If you change the width of the big column, the rest of
			the widths and proportions would update.
		</p>
		<blockquote>
			I admit this math isn't very complicated. But it's still fun.
		</blockquote>
		<div class="tip tip-left tip-hidden">
			<div class="tip-inner" id="tipContainer">
				I am using <a
					href="https://katex.org/"
					title="Katex Official Site"
					target="_blank">Katex</a
				> to render this math. My math here is too simple to look real cool <span
					class="emoji">💀</span
				>
			</div>
		</div>
		<h3>The Math</h3>
		<h5>Big Column Width</h5>
		<div class="math">
			<p set:html={renderedMath.find(({ id }) => id === 'w').html} />
		</div>
		<h5>Small Column Width</h5>
		<div class="math">
			<p
				set:html={renderedMath.find(({ id }) => id === 'smallColumnWidth').html}
			/>
			<p class="result">Result: 40%</p>
		</div>
		<h5>Box Width</h5>
		<div class="math">
			<p set:html={renderedMath.find(({ id }) => id === 'boxWidth').html} />
			<p class="result">Result: 20%</p>
		</div>
		<p>
			After calculating the proportions, I implemented a slider that updates the
			values in real-time as you adjust it, allowing for an interactive
			demonstration of the layout.
		</p>
		<p>
			The inner box can get too tall for the container so once the box height is
			taller than the container I change the amount of padding-bottom it gets.
			This changes it from a square to a rectangle.
		</p>
		<h3>The Result</h3>
	</div>
	<div class="grid-feature">
		<div class="controls">
			<label>
				<p class="sliderLabel">Box Width</p>
				<p class="sliderValue">
					<span id="boxWidthValue">60</span>%
				</p>
				<input
					type="range"
					id="boxWidthSlider"
					min="51"
					max="95"
					value="60"
					step="0.01"
				/>
			</label>
		</div>

		<div class="row box-lines">
			<div class="column column-box-lines"></div>
			<div class="column column-box-lines"></div>
			<div class="column column-box-lines"></div>
			<div class="column column-box-lines"></div>
			<div class="box"><div class="box-height"></div></div>
		</div>
	</div>
	<script>
		document.addEventListener('DOMContentLoaded', function () {
			const slider = document.querySelector('#boxWidthSlider')
			const boxWidthValue = document.querySelector('#boxWidthValue')

			// Function to calculate the square width
			function getSquareWidth(width) {
				return 100 - (100 - width) * 2
			}

			// Function to update styles based on the slider value
			function updateStyles(e) {
				let value = e?.target?.value || slider?.value
				if (!value) return

				// Round the value to two decimal places
				value = parseFloat(value).toFixed(2)

				boxWidthValue.innerText = value
				const squareWidth = getSquareWidth(value)

				const columns = document.querySelectorAll('.column-box-lines')
				const box = document.querySelector('.box-lines .box')
				const boxHouse = document.querySelector('.box-lines')
				const boxHeightDisplay = document.querySelector('.box-height')

				columns.forEach((column, index) => {
					let width = index === 0 || index === 3 ? value : 100 - value
					column.style.flexBasis = `${width}%`
					column.innerText = `${parseFloat(width).toFixed(2)}%`
				})

				box.style.width = `${squareWidth + 0.1}%`
				box.style.paddingBottom = `${squareWidth}%`
				boxHeightDisplay.innerText = `${parseFloat(squareWidth).toFixed(2)}%`

				const boxHeight = box.offsetHeight
				const boxHouseHeight = boxHouse.offsetHeight
				if (boxHeight > boxHouseHeight) {
					// If the box is taller than the container, adjust padding
					box.style.paddingBottom = `${squareWidth / 2}%`
				}
			}

			// Attach event listener to the slider
			if (slider) {
				slider.addEventListener('input', updateStyles)
				requestAnimationFrame(() => updateStyles({ target: slider }))
			}
			updateStyles() // Initialize styles when DOM content is loaded
		})
	</script>

	<style lang="scss">
		.controls {
			display: flex;
			flex-direction: column;

			padding: 1rem 3rem;
			max-width: 50rem;
			width: 100%;
			margin: 20px auto 0;
			border: 0.1rem solid var(--text-color);
			border-bottom: none;
			label {
				font-size: 1.1rem;
				color: var(--text-color);
				display: flex;
				justify-content: center;
				align-items: center;
				gap: 2rem;
				flex-flow: row wrap;
			}
		}

		.sliderLabel {
			font-size: 1.5rem;
			font-family: var(--a-font);
			flex: 0 0 8rem;
			margin: 0;
		}
		.sliderValue {
			font-weight: bold;
			font-size: 3rem;
			font-family: var(--a-font);
			color: var(--background-color);
			-webkit-text-stroke: 0.1rem var(--text-color);
			text-stroke: 0.1rem var(--text-color);
			display: inline-block;
			min-width: 11rem;
			margin: 0;
		}

		.box-lines {
			display: flex;
			flex-flow: row wrap;
			position: relative;
			.column {
				flex: 1 1 0px;
				border: 0.1rem solid var(--text-color);
				height: 25vw;
				// Top and Bottom
				&:nth-child(1),
				&:nth-child(2) {
					border-bottom: none;
				}

				// Left
				&:nth-child(1),
				&:nth-child(3) {
					border-right: none;
				}

				// 56
				--width-a: 56.08%;
				&:nth-child(1),
				&:nth-child(4) {
					flex: 0 0 var(--width-a);
				}
				// 44
				--width-b: 43.92%;
				&:nth-child(2),
				&:nth-child(3) {
					flex: 0 0 var(--width-b);
				}
			}

			// Square
			.box {
				--box-size: 21.9%;
				position: absolute;
				height: 0;
				width: var(--box-size);
				padding-bottom: var(--box-size);
				border: 0.1rem solid var(--text-color);
				background-color: var(--background-color);
				left: 50%;
				top: 50%;
				transform: translate(-50%, -50%);
			}
			.column,
			.box {
				display: flex;
				justify-content: center;
				align-items: center;
				font-size: 4rem;
				font-family: var(--a-font);
				color: var(--background-color);
				-webkit-text-stroke: 0.1rem var(--text-color);
				text-stroke: 0.1rem var(--text-color);
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
			}
			.box-height {
				position: absolute;
				top: 50%;
				left: 50%;
				transform: translate(-50%, -50%);
			}
		}

		@media screen and (max-width: 768px) {
			#boxWidthSlider {
				flex: 0 0 100%;
			}
		}
	</style>
</BaseLayout>
</file>

<file path="src/pages/play/youtube-timer.astro">
---
import BaseLayout from '../../layouts/BaseLayout.astro'
import BlogDetails from '../../components/BlogDetails.astro'
import timingNotesData from '../../data/see-you-later-alligator-timing.json'
import mightyToSaveTimingData from '../../data/mighty-to-save-timing.json'
import alwaysInvisibleTimingData from '../../data/always-invisible-timing.json'
import { Icon } from 'astro-icon/components'
import '../../styles/youtube-timer.css'

export const blogData = {
	title: 'YouTube Timing Controller',
	author: 'David Volz',
	description: `A tool to control YouTube playback with timed text annotations and BPM-based counting.`,
	image: {
		url: 'https://docs.astro.build/assets/arc.webp',
		alt: 'The Astro logo on a dark background with a purple gradient arc.',
	},
	pubDate: '2025-12-6',
	tags: ['javascript', 'code', 'tools'],
	featured: true,
	display: true,
}

const showTypographyHero = true
const fullWidthBody = true
---

<BaseLayout
	pageTitle={blogData.title}
	{showTypographyHero}
	description={blogData.description}
	fullWidthBody={fullWidthBody}>
	<Fragment slot="head">
		<link rel="preconnect" href="https://www.youtube.com" />
		<link rel="preconnect" href="https://i.ytimg.com" />
	</Fragment>
	<div class="details-width">
		<BlogDetails {...blogData} />
	</div>

	<div class="article">
		<p class="intro-text">
			This tool allows you to control YouTube video playback with precise timing
			annotations. Set start times, add timed text notes, and sync with BPM for
			musical analysis or learning.
		</p>
	</div>

	<div class="youtube-timer-container">
		<!-- Configuration Panel -->
		<div class="config-panel">
			<h3>Configuration</h3>

			<div class="config-inputs">
				<div class="input-group">
					<label for="videoUrl">YouTube Video ID or URL</label>
					<input
						type="text"
						id="videoUrl"
						placeholder="dQw4w9WgXcQ or full URL"
					/>
				</div>

				<div class="input-group">
					<label for="startTime">Start Time (seconds) - Optional</label>
					<input
						type="number"
						id="startTime"
						placeholder="Leave empty for start"
						step="any"
					/>
					<small
						>Time in seconds where video should start (61 = 1 minute 1 second).
						Leave empty to start from beginning.</small
					>
				</div>

				<div class="input-group">
					<label for="duration">Duration (seconds) - Optional</label>
					<input
						type="number"
						id="duration"
						placeholder="Leave empty for full video"
						step="any"
					/>
					<small
						>How long to play from start time. Leave empty to play the entire
						video.</small
					>
				</div>

				<div class="input-group">
					<label for="bpm">BPM - Optional</label>
					<input type="number" id="bpm" placeholder="120" min="1" />
					<small>Beat interval <span id="beatInterval">0</span>s</small>
				</div>

				<div class="input-group">
					<label for="timeSignature">Time Signature - Optional</label>
					<select id="timeSignature">
						<option value="4">4/4</option>
						<option value="3">3/4</option>
						<option value="2">2/4</option>
						<option value="5">5/4</option>
						<option value="6">6/8</option>
						<option value="7">7/4</option>
					</select>
					<small>Number of beats per measure for count-in</small>
				</div>
			</div>

			<div class="config-actions">
				<button id="loadVideo" class="btn-primary">Load Video</button>
				<button id="loadExample2" class="btn-secondary"
					>Load Example: Mighty to Save</button
				>
				<button id="loadExample" class="btn-secondary"
					>Load Example: See You Later Alligator</button
				>
				<button id="loadExample3" class="btn-secondary"
					>Load Example: Always Invisible</button
				>
			</div>
			<div class="main-content">
				<!-- Video Player -->
				<div class="player-section">
					<button id="toggleVideo" class="btn-toggle-video">▼ Show Video</button
					>
					<div class="player-wrapper hidden" id="playerWrapper">
						<div id="player"></div>
					</div>

					<div
						class="timing-display"
						role="region"
						aria-label="Current timing note">
						<div
							id="currentNote"
							class="note-display"
							aria-live="polite"
							aria-atomic="true">
							No note active
						</div>
						<div
							id="nextNote"
							class="note-display next-note"
							aria-live="polite">
							Up next: <span id="nextNoteText">--</span>
						</div>
					</div>

					<div class="controls">
						<div class="time-display">
							<span id="currentTime">0:00</span> / <span id="totalTime"
								>0:00</span
							>
						</div>
						<div class="controls-buttons">
							<button
								id="playBtn"
								class="btn-control"
								disabled
								aria-label="Play">▶</button
							>
							<button
								id="pauseBtn"
								class="btn-control"
								disabled
								aria-label="Pause">⏸</button
							>
							<div class="btn-control-wrapper">
								<button
									id="slowBtn"
									class="btn-control"
									disabled
									aria-label="Slow down playback">
									<Icon name="mdi:snail" aria-hidden="true" />
								</button>
								<div id="speedDisplay" class="speed-display" aria-live="polite">
								</div>
							</div>
							<button
								id="resetBtn"
								class="btn-control"
								disabled
								aria-label="Reset to start">↻</button
							>
						</div>
					</div>

					<!-- Scrubber -->
					<div class="scrubber-container">
						<label for="scrubber" class="sr-only">Video timeline scrubber</label
						>
						<input
							type="range"
							id="scrubber"
							min="0"
							max="100"
							value="0"
							step="0.1"
							disabled
						/>
						<div class="scrubber-markers" id="markers"></div>
					</div>
				</div>

				<!-- Timing Notes Sidebar -->
				<div class="notes-list">
					<!-- Mode Toggle -->
					<div class="sidebar-mode-toggle">
						<button id="toggleSidebarMode" class="btn-primary">

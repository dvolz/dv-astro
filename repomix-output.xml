<file path="src/styles/global/_external-links.scss">
// External Link Styling
// Adds bold visual distinction to outbound links within article content.
// Mini pill treatment with gradient accent bar & animated arrow.

.article a[href^='http'] {
	position: relative;
	display: inline;
	text-decoration: none;
	font-weight: 600;
	color: var(--primary-color);

	// Gradient accent bar on the left edge
	padding: 0.15rem 0.5rem 0.15rem 1rem;
	margin: 0 0.1rem;
	border-radius: 0.4rem;
	background: linear-gradient(
			135deg,
			var(--highlight-secondary),
			var(--highlight-accent)
		)
		no-repeat 0 0;
	background-size: 0.3rem 100%;

	// Subtle tinted background so the pill shape is visible
	box-decoration-break: clone;
	-webkit-box-decoration-break: clone;

	transition:
		background-size 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94),
		background-color 0.3s ease,
		color 0.3s ease,
		box-shadow 0.3s ease;

	// Arrow indicator — always visible for clarity
	&::after {
		content: '\2009\2197'; // thin space + ↗
		display: inline-block;
		font-size: 0.75em;
		font-style: normal;
		font-weight: 400;
		line-height: 1;
		opacity: 0.6;
		vertical-align: super;
		transition:
			opacity 0.3s ease,
			transform 0.3s ease;
	}

	// Hover: gradient fills the full background, bar stays
	&:hover {
		color: var(--primary-color);
		background:
			linear-gradient(
					135deg,
					var(--highlight-secondary),
					var(--highlight-accent)
				)
				no-repeat 0 0 / 0.3rem 100%,
			linear-gradient(
					135deg,
					rgba(74, 151, 184, 0.12),
					rgba(85, 200, 146, 0.12)
				)
				no-repeat 0 0 / 100% 100%;
		box-shadow: 0 0.2rem 0.6rem rgba(91, 181, 152, 0.2);

		&::after {
			opacity: 1;
			transform: translate(0.15rem, -0.15rem);
		}
	}

	// Visited state — slightly dimmer arrow
	&:visited {
		&::after {
			opacity: 0.35;
		}
		&:hover::after {
			opacity: 0.9;
		}
	}
}
</file>


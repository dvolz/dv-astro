		background-color: $terminal-background;
		color: $terminal-green;
		border-radius: 1rem;
		box-shadow: 0 0 2rem rgba(0, 255, 0, 0.7);
		margin: 0 auto;
		font-size: 1.4rem;
		text-align: right;
		line-height: 2.2;
		max-width: 30rem;
		@media screen and (min-width: 850px) {
			margin-right: 0;
		}
		.inner {
			padding: 2rem;
			position: relative;
			&:before {
				content: '';
				display: block;
				border-top: 0.1rem dashed $terminal-green;
				margin-bottom: 2rem;
			}
			&:after {
				content: '$ astro details';
				padding-right: 1rem;
				position: absolute;
				top: 0.6rem;
				background: $terminal-background;
				left: 1.3rem;
				font-size: 1.3rem;

  ctx.fillStyle = "#0a1824"; ctx.fillRect(e.x * CELL - 1, e.y * CELL - 1, CELL + 2, CELL + 2);
  ctx.fillStyle = "#162d40"; ctx.fillRect(e.x * CELL, e.y * CELL, CELL, CELL);

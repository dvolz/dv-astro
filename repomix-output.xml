<file path="src/components/display/youtube-timing-controller-display.astro">
---
const { title, url, description } = Astro.props
---

<style lang="scss">
	.frame {
		background: color-mix(in srgb, var(--note-color, #d8a7b1), transparent 85%);
	}

	.title {
		border: 6px solid var(--note-color, #d8a7b1);
		border-radius: 7.1px;
		padding: 2.5rem 3rem;
		background: var(--background-color);
		font-family: var(--a-font);
		font-size: 2.5rem;
		font-weight: 900;
		line-height: 1.1;
		letter-spacing: 0.02em;
		color: var(--text-color);
		margin: 0;
		transition: all 0.6s ease;
		box-shadow: inset 0 0 0 1px var(--text-color);
	}
</style>

<a class="blogPost" href={url}>
	<div class="frame youtube-timer-animated">
		<p class="title youtube-timer-note">{title}</p>
	</div>
</a>

<script>
	document.addEventListener('DOMContentLoaded', function () {
		const colors = [
			'#D8A7B1',
			'#E8A87C',
			'#D4B483',
			'#A3B18A',
			'#E5989B',
			'#B8A9C9',
			'#C97C5D',
			'#7D9BA6',
		]

		const frames = document.querySelectorAll('.youtube-timer-animated')

		frames.forEach((frame) => {
			let currentIndex = 0
			const duration = 3000

			function updateColor() {
				const color = colors[currentIndex]
				const nextColor = colors[(currentIndex + 1) % colors.length]
				frame.style.setProperty('--note-color', color)
				frame.style.setProperty('--next-note-color', nextColor)
				currentIndex = (currentIndex + 1) % colors.length
			}

			updateColor()
			setInterval(updateColor, duration)
		})
	})
</script>
</file>

<file path="src/components/AstroImage.astro">
---
import { Image } from 'astro:assets'

// Destructure the props and set defaults
const {
	src,
	alt,
	width = 800,
	height = 600,
	format = 'webp',
	quality = 75,
	layout = 'responsive',
} = Astro.props

// Check if the src is passed as a URL (a string path)
let resolvedSrc = src

// If the src is not directly imported but a path string, resolve it using import.meta.glob
if (typeof src === 'string' && src.startsWith('/src/assets/images')) {
	const images = import.meta.glob('/src/assets/images/*.jpeg', { eager: true })
	resolvedSrc = images[src]
}

if (!resolvedSrc) {
	throw new Error(`Image not found for the path: ${src}`)
}
---

<Image
	src={resolvedSrc}
	alt={alt}
	width={width}
	height={height}
	format={format}
	quality={quality}
	layout={layout}
/>
</file>


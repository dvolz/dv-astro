<file path="src/components/CatSVG.astro">
---
import CatSVGFile from '../svgs/cat.svg?raw'
import '../styles/module/_slider.scss'
---

<style lang="scss">
	.catSVG {
		width: 70px;
		height: auto;
		margin: 0 auto;
		cursor: var(--cursor-hover);
	}
	.catControls {
		max-height: 0;
		overflow: hidden;
		transition: max-height 0.3s ease-in;
		width: 100%;
		max-width: 40rem;
		margin: 0 auto;
		padding: 0.1rem;
	}
	$border-height: 0.5rem;
	.catControlsInner {
		margin: 0.2rem 0 2rem;
		background-color: var(--background-color);
		position: relative;
		// middle stroke
		border: $border-height solid var(--background-color);
		border-radius: $border-height + 1.1;
		padding: 2.5rem 2rem 3rem;
		text-align: center;
		color: var(--text-color);
		transition: border-color 0.3s ease;
		&:before,
		&:after {
			content: '';
			position: absolute;
			top: 0;
			left: 0;
			right: 0;
			bottom: 0;
			pointer-events: none;
		}
		// outer stroke
		&:before {
			border: 1px solid var(--text-color);
			left: -($border-height + 0.1);
			top: -($border-height + 0.1);
			width: calc(100% + 12px);
			height: calc(100% + 12px);
			border-radius: $border-height + 1.2;
		}
		// inner stroke
		&:after {
			border: 1px solid var(--text-color);
			border-radius: $border-height + 0.5;
		}
	}
	label,
	#slider-value {
		font-family: var(--a-font);
	}
	label {
		margin-bottom: 1.5rem;
		display: block;
	}

	#spacing-slider {
		margin-bottom: 0rem;
	}
	#slider-value {
		font-size: 3rem;
	}
</style>

<div id="background-container">
	<div class="catSVG" id="cat-svg" data-svg={CatSVGFile}>
		<Fragment set:html={CatSVGFile} />
	</div>
	<div class="catControls">
		<div class="catControlsInner line-border">
			<label for="spacing-slider">Adjust Cat Space</label>
			<input id="spacing-slider" type="range" min="100" max="600" value="250" />
			<span id="slider-value">100</span>
		</div>
	</div>
</div>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const body = document.querySelector('body') as HTMLBodyElement
		const slider = document.getElementById('spacing-slider') as HTMLInputElement
		const sliderValue = document.getElementById(
			'slider-value'
		) as HTMLSpanElement
		const svgElement = document.getElementById('cat-svg') as HTMLElement
		const rawSVG = svgElement.getAttribute('data-svg')
		const catControls = document.querySelector('.catControls') as HTMLElement

		// SVG base viewBox dimensions (must match the original SVG)
		const BASE_WIDTH = 500
		const BASE_HEIGHT = 300
		const BASE_X = 75
		const BASE_Y = 75

		// Function to encode SVG for inline use
		function encodeSVG(svg: string): string {
			return `data:image/svg+xml,${encodeURIComponent(svg)}`
		}

		// Regex pattern for SVG tag (compiled once)
		const svgTagRegex = /<svg[^>]+>/

		// Function to update the SVG viewBox and apply as tiled background
		function updateSVGViewBox(spacing: number): void {
			// Scale factor: slider 100 = 1x, slider 600 = 6x
			const scaleFactor = 1 + (spacing - 100) / 100

			// Expand viewBox to add transparent padding around cat
			const newWidth = BASE_WIDTH * scaleFactor
			const newHeight = BASE_HEIGHT * scaleFactor

			// Offset so the cat stays centered in the expanded viewBox
			const newX = BASE_X - (newWidth - BASE_WIDTH) / 2
			const newY = BASE_Y - (newHeight - BASE_HEIGHT) / 2

			const updatedViewBox = `${newX} ${newY} ${newWidth} ${newHeight}`

			// Replace SVG tag with updated viewBox and opacity
			const updatedSVG = rawSVG.replace(
				svgTagRegex,
				`<svg xmlns="http://www.w3.org/2000/svg" viewBox="${updatedViewBox}" opacity="0.2">`
			)

			// Set the tiled background
			body.style.backgroundImage = `url('${encodeSVG(updatedSVG)}')`

			// Scale background-size proportionally so the cat stays the same visual size
			// while the tile (and thus spacing) grows
			body.style.backgroundSize = `${newWidth / 5}px ${newHeight / 5}px`
		}

		// Initial background state from localStorage or default to false
		let isBackgroundSet = false
		let spacing = 250
		try {
			isBackgroundSet =
				JSON.parse(localStorage.getItem('isBackgroundSet')) || false
			spacing = JSON.parse(localStorage.getItem('backgroundSpacing')) || 250
		} catch {
			// Corrupted localStorage data, use defaults
		}

		// Function to apply the background state
		function applyBackgroundState(): void {
			if (isBackgroundSet) {
				catControls.style.maxHeight = '20rem' // Show controls
				updateSVGViewBox(spacing) // Apply background with saved spacing
			} else {
				body.style.backgroundImage = ''
				catControls.style.maxHeight = '0' // Hide controls
			}
		}

		// Function to toggle the background
		function toggleBackground(): void {
			isBackgroundSet = !isBackgroundSet // Toggle state
			applyBackgroundState() // Apply the updated state
			localStorage.setItem('isBackgroundSet', JSON.stringify(isBackgroundSet)) // Save state to local storage
		}

		// Update slider value display and background on input
		slider.addEventListener('input', (event) => {
			if (isBackgroundSet) {
				const target = event.target as HTMLInputElement
				spacing = parseInt(target.value, 10)
				sliderValue.textContent = spacing.toString()
				updateSVGViewBox(spacing)
				localStorage.setItem('backgroundSpacing', JSON.stringify(spacing)) // Save state to local storage
			}
		})

		// Set the slider value on page load to the saved spacing value
		slider.value = spacing.toString()
		sliderValue.textContent = spacing.toString() // Set the displayed value next to the slider

		// Attach the toggle function to the click event
		svgElement.addEventListener('click', toggleBackground)

		// Apply the saved state on page load
		applyBackgroundState()
	})
</script>
</file>

<file path="src/components/CodeBlock.astro">
---
interface Props {
	code: string
	lang?: string
}

const { code, lang = 'typescript' } = Astro.props

import { getHighlighter, type Highlighter } from 'shiki'

const theme = 'material-theme-palenight'

// Cache the highlighter as a singleton across all CodeBlock instances
const highlighterCache = (globalThis as any).__shikiHighlighter as
	| Promise<Highlighter>
	| undefined
const highlighterPromise =
	highlighterCache ??
	((globalThis as any).__shikiHighlighter = getHighlighter({
		themes: [theme],
		langs: ['typescript', 'javascript', 'jsx', 'tsx', 'html', 'css', 'astro'],
	}))

const highlighter = await highlighterPromise

const html = highlighter.codeToHtml(code, {
	lang,
	theme: theme,
})
---

<div class="code-block">
	<Fragment set:html={html} />
</div>

<style lang="scss">
	:global(.shiki) {
		background-color: #332e2e !important;
		border-radius: 0.5rem;
	}
	:global(.dark .shiki) {
		border: 0.1rem solid var(--text-color);
	}

	.code-block {
		position: relative;
		margin: 1rem 0;

		overflow: hidden;
	}

	.code-block :global(pre) {
		padding: 2rem;
		margin: 0;
		overflow-x: auto;
	}
	:global(code) {
		line-height: 1.5;
		white-space: pre-wrap;
		word-wrap: break-word;
	}
</style>
</file>


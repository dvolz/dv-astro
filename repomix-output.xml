		span {
			border: 0.1rem solid $terminal-green;
			border-radius: 0.5rem;
			box-shadow: 0 0 0.8rem rgba(0, 255, 0, 0.7);
			padding: 0.7rem;
		}
		.top {
			border-top: 0.1rem dashed $terminal-green;
		}
	}

	.terminal p {
		margin-bottom: 1rem;
	}

	// Bottom command bar — mirrors the top $ astro details treatment
	.sg-bar {
		margin-top: 1.5rem;
		padding-top: 0;
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		border-bottom: 0.1rem dashed $terminal-green;
	}
	.sg-link {
		display: inline-block;
		position: relative;
		color: $terminal-green;
		text-decoration: none;
		font-size: 1.3rem;
		text-align: left;
		padding-right: 1rem;
		padding-bottom: 0.4rem;
		z-index: 1;
		.sg-dollar,
		.sg-cmd,
		.sg-style,
		.sg-guide {
			transition: text-shadow 0.3s ease;
		}
		&:hover {
			.sg-dollar,
			.sg-cmd,
			.sg-guide {
				text-shadow:
					0 0 1rem rgba(0, 255, 0, 0.9),
					0 0 2.5rem rgba(0, 255, 0, 0.5),
					0 0 4rem rgba(0, 255, 0, 0.3);
				animation: neonPulse 1.5s ease-in-out infinite;
			}
			.sg-style {
				text-shadow:
					0 0 1.5rem rgba(0, 255, 0, 1),
					0 0 3rem rgba(0, 255, 0, 0.6),
					0 0 5rem rgba(0, 255, 0, 0.4);
				animation: neonPulseStrong 1.5s ease-in-out infinite;
			}
		}
	}
	// "style" keyword — italic serif, terminal green with glow
	.sg-style {
		font-family: var(--p-font);
		font-style: italic;
		font-weight: 600;
		color: $terminal-green;
		text-shadow: 0 0 0.6rem rgba(0, 255, 0, 0.6);
		border: none !important;
		box-shadow: none !important;
		padding: 0 !important;
	}
	// Individual word colors from site palette
	.sg-dollar {
		color: $terminal-green;
		text-shadow: 0 0 0.6rem rgba(0, 255, 0, 0.6);
		border: none !important;
		box-shadow: none !important;
		padding: 0 !important;
	}
	.sg-cmd {
		color: $terminal-green;
		border: none !important;
		box-shadow: none !important;
		padding: 0 !important;
	}
	.sg-guide {
		color: $terminal-green;
		border: none !important;
		box-shadow: none !important;
		padding: 0 !important;
	}
	// Blinking cursor
	.sg-cursor {
		font-size: 1.3rem;
		padding-left: 1rem !important;
		padding-bottom: 0.4rem;
		z-index: 2;
		position: relative;
		border: none !important;
		box-shadow: none !important;
		padding-top: 0 !important;
		padding-right: 0 !important;
		border-radius: 0 !important;
		animation: cursorBlink 0.8s step-end infinite;
	}

	@keyframes cursorBlink {
		50% {
			color: transparent;
		}
	}

	@keyframes neonPulse {
		0%,
		100% {
			text-shadow:
				0 0 0.8rem rgba(0, 255, 0, 0.7),
				0 0 1.6rem rgba(0, 255, 0, 0.4);
		}
		50% {
			text-shadow:
				0 0 1.5rem rgba(0, 255, 0, 1),
				0 0 3rem rgba(0, 255, 0, 0.6),
				0 0 4.5rem rgba(0, 255, 0, 0.3);
		}
	}

	@keyframes neonPulseStrong {
		0%,
		100% {
			text-shadow:
				0 0 1rem rgba(0, 255, 0, 0.8),
				0 0 2rem rgba(0, 255, 0, 0.5);
		}
		50% {
			text-shadow:
				0 0 2rem rgba(0, 255, 0, 1),
				0 0 4rem rgba(0, 255, 0, 0.7),
				0 0 6rem rgba(0, 255, 0, 0.4);
		}
	}
</style>

<div class="astroSVG">
	<Fragment set:html={AstroSVGRaw} />
</div>
<div class="lastUpdated terminal">
	<div class="inner">
		<p>Astro Version <span>{astroVersionReal}</span></p>
		<p>
			Site last updated<br />
			<span>{lastUpdated}</span>
		</p>
		<div class="sg-bar">
			<a href="/style-guide/" class="sg-link"
				><span class="sg-dollar">$</span>
				<span class="sg-cmd">cat</span>
				<span class="sg-style">style</span><span class="sg-guide">-guide</span
				></a
			>
			<span class="sg-cursor">|</span>
		</div>
	</div>
</div>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const astroSVG = document.querySelector('.astroSVG')
		const details = document.querySelector('.lastUpdated')
		let isOpen = false
		function showDetails() {
			if (isOpen) {
				astroSVG.classList.toggle('open')
				details.classList.toggle('open')
				isOpen = false
			} else {
				astroSVG.classList.toggle('open')
				details.classList.toggle('open')
				isOpen = true
			}
		}
		astroSVG.addEventListener('click', showDetails)
	})
</script>
</file>


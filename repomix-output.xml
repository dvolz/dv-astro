import BaseLayout from '../../layouts/BaseLayout.astro'
import BlogDetails from '../../components/BlogDetails.astro'

export const blogData = {
	title: 'Shark Thief 2',
	author: 'David Volz',
	description: "The sequel — a browser game built from a kid's prompt.",
	image: {
		url: 'https://docs.astro.build/assets/arc.webp',
		alt: 'The Astro logo on a dark background with a purple gradient arc.',
	},
	pubDate: '2026-3-15',
	tags: ['javascript', 'code', 'fluff'],
	featured: false,
	display: false,
}

const showTypographyHero = true
const fullWidthBody = true
---

<style lang="scss">
	/* ── Game ── */
	.game-wrapper {
		max-width: 90rem;
		margin: 0 auto;
		padding: 0 2rem;
		text-align: center;
		overflow-x: hidden;
	}
	@media (max-width: 640px) {
		.game-wrapper {
			padding: 0 0.5rem;
		}
	}
	.game-hud {
		display: flex;
		justify-content: center;
		gap: 3rem;
		margin: 0 0 1.5rem;
		font-family: var(--a-font);
		font-size: 1.6rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		span span {
			color: #5dade2;
			font-size: 2rem;
			font-weight: 800;
			letter-spacing: 0.04em;
		}
		.multiplier {
			color: #e8a87c;
		}
		.filled {
			color: #a3b18a;
		}
	}
	.game-canvas-wrapper {
		display: inline-block;
		border: 2px solid var(--text-color);
		border-radius: 0.4rem;
		line-height: 0;
	}
	canvas {
		display: block;
		max-width: 100%;
		height: auto;
		touch-action: none;
	}
	.game-instructions {
		margin: 0 auto 2.5rem;
		max-width: 44rem;
		padding: 1.6rem 2rem;
		border: 1px solid rgba(128, 128, 128, 0.15);
		border-radius: 0.6rem;
		text-align: left;
		line-height: 1.8;
		font-size: 1.4rem;
	}
	.game-instructions .how-to-play {
		font-family: var(--a-font);
		font-weight: 700;
		font-size: 1.2rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		opacity: 0.5;
		margin: 0 0 0.6rem;
	}
	.game-instructions ol {
		margin: 0;
		padding-left: 2rem;
		list-style: decimal;
	}
	.game-instructions li {
		margin-bottom: 0.3rem;
		font-family: var(--p-font);
	}
	.game-instructions li strong {
		font-weight: 700;
	}
	.game-instructions .controls-note {
		margin: 0.8rem 0 0;
		font-size: 1.2rem;
		opacity: 0.55;
		font-family: var(--a-font);
	}

	/* ── Game Over Overlay ── */
	.game-over-overlay {
		position: absolute;
		inset: 0;
		display: none;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		background: rgba(0, 0, 0, 0.85);
		z-index: 10;
		border-radius: 0.4rem;
	}
	.game-over-overlay.visible {
		display: flex;
	}
	.game-over-overlay h2 {
		font-family: var(--a-font);
		font-size: 4rem;
		color: #e74c3c;
		margin: 0 0 0.5rem;
	}
	.game-over-overlay .final-score {
		font-family: var(--a-font);
		font-size: 2rem;
		color: #fff;
		margin: 0 0 2rem;
	}
	.game-over-overlay .game-over-buttons {
		display: flex;
		gap: 1.5rem;
	}
	.game-over-overlay button,
	.game-over-overlay a {
		font-family: var(--a-font);
		font-size: 1.6rem;
		font-weight: 600;
		padding: 0.8rem 2.5rem;
		border: 1px solid #fff;
		border-radius: 0.6rem;
		background: none;
		color: #fff;
		cursor: pointer;
		text-decoration: none;
		transition: all 0.3s ease;
		&:hover {
			background: #fff;
			color: #000;
		}
	}

	.game-canvas-container {
		position: relative;
		display: inline-block;
		max-width: 100%;
	}

	/* ── DOS-style prompt ── */
	.prompt-terminal {
		max-width: 60rem;
		margin: 0 auto 3rem;
		border: 1px solid rgba(93, 173, 226, 0.3);
		border-radius: 0.6rem;
		overflow: hidden;
		background: #0c1421;
		box-shadow: 0 0 24px rgba(93, 173, 226, 0.06);
	}
	.prompt-titlebar {
		background: rgba(93, 173, 226, 0.12);
		border-bottom: 1px solid rgba(93, 173, 226, 0.2);
		padding: 0.5rem 1.2rem;
		display: flex;
		align-items: center;
		gap: 0.6rem;
	}
	.prompt-dot {
		width: 0.8rem;
		height: 0.8rem;
		border-radius: 50%;
		&:nth-child(1) {
			background: #e74c3c;
		}
		&:nth-child(2) {
			background: #f39c12;
		}
		&:nth-child(3) {
			background: #2ecc71;
		}
	}
	.prompt-titlebar span:last-child {
		font-family: var(--a-font);
		font-size: 1rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: rgba(93, 173, 226, 0.6);
		margin-left: auto;
	}
	.prompt-body {
		padding: 1.6rem 2rem;
		font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', 'Menlo', monospace;
		font-size: 1.3rem;
		line-height: 1.7;
		color: #a8c7e2;
	}
	.prompt-label {
		color: #5dade2;
		font-weight: 700;
	}
	.prompt-cursor {
		display: inline-block;
		width: 0.7rem;
		height: 1.4rem;
		background: #5dade2;
		margin-left: 0.3rem;
		vertical-align: text-bottom;
		animation: blink 1s step-end infinite;
	}
	@keyframes blink {
		50% {
			opacity: 0;
		}
	}

	/* ── Name Input on Game Over ── */
	.submit-prompt {
		margin: 0 0 1.2rem;
	}
	.submit-prompt button {
		font-family: var(--a-font);
		font-size: 1.5rem;
		font-weight: 600;

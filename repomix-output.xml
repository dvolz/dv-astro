	/* ──────────────────────────────────────────────
	   STYLE GUIDE – SCOPED STYLES
	   ────────────────────────────────────────────── */

	/* ── Swatches ── */
	.sg-swatches {
		display: flex;
		flex-flow: row wrap;
		gap: 1.5rem;
		margin: 2rem 0 3rem;
	}
	.sg-swatch {
		flex: 0 0 calc(33.333% - 1rem);
		text-align: center;
		@media screen and (max-width: 640px) {
			flex: 0 0 calc(50% - 1rem);
		}
	}
	.sg-swatch-block {
		height: 7rem;
		border-radius: 0.6rem;
		background: var(--sw);
		border: 1px solid var(--text-color);
		margin-bottom: 0.5rem;
		transition:
			transform 0.3s ease,
			box-shadow 0.3s ease;
		&:hover {
			transform: translateY(-0.3rem);
			box-shadow: 0 0.4rem 1rem rgba(0, 0, 0, 0.12);
		}
	}
	.sg-swatch-block--light {
		border: 1px solid var(--text-color);
	}
	.sg-swatch-label {
		font-size: 1.3rem;
		line-height: 1.4;
		em {
			font-style: normal;
			opacity: 0.6;
		}
	}

	/* ── Type Specimen ── */
	.sg-type-specimen {
		margin: 2rem 0 3rem;
	}
	.sg-type-row {
		display: flex;
		align-items: baseline;
		padding: 1rem 0;
		border-bottom: 1px solid rgba(0, 0, 0, 0.07);
		gap: 1.5rem;
	}
	.sg-type-label {
		flex: 0 0 4rem;
		font-family: var(--a-font);
		font-size: 1.3rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		opacity: 0.5;
	}
	.sg-inline {
		margin: 0 !important;
	}

	/* ── Button row ── */
	.sg-button-row {
		display: flex;
		flex-wrap: wrap;
		gap: 1.5rem;
		margin: 1.5rem 0 3rem;
	}

	/* ── Solo-line demo ── */
	.sg-solo-line-demo {
		position: relative;
		display: inline-block;
		padding: 1.5rem 3rem 2rem;
		margin: 1rem 0 3rem;
		p {
			margin: 0;
		}
	}

	/* ── Frame card demo ── */
	$sg-bh: 0.5rem;
	.sg-frame-demo {
		margin: 1.5rem 0 3rem;
		max-width: 36rem;
	}
	.sg-frame-card {
		position: relative;
		border: $sg-bh solid var(--background-color);
		border-radius: $sg-bh + 1.1;
		padding: 2.5rem 2rem 3rem;
		text-align: center;
		transition: border-color 0.3s ease;

		&:before,
		&:after {
			content: '';
			position: absolute;
			top: 0;
			left: 0;
			right: 0;
			bottom: 0;
		}
		&:before {
			border: 1px solid var(--text-color);
			left: -($sg-bh + 0.1);
			top: -($sg-bh + 0.1);
			width: calc(100% + 1.2rem);
			height: calc(100% + 1.2rem);
			border-radius: $sg-bh + 1.2;
		}
		&:after {
			border: 1px solid var(--text-color);
			border-radius: $sg-bh + 0.5;
		}
		&:hover {
			border-color: var(--accent-color);
		}
	}
	.sg-frame-title {
		font-family: var(--a-font);
		font-weight: 700;
		font-size: 2.4rem;
		margin: 0 0 0.5rem;
	}
	.sg-frame-desc {
		font-weight: 300;
	}

	/* ── Hero demo ── */
	.sg-hero-demo {
		text-align: center;
		padding: 2rem 0 1rem;
		margin: 1rem 0 3rem;
		border: 1px dashed rgba(0, 0, 0, 0.12);
		border-radius: 0.6rem;
	}
	.sg-hero-title {
		font-family: var(--a-font);
		font-weight: 700;
		font-size: 5rem;
		line-height: 1;
		margin: 0 0 0.5rem;
	}
	.sg-hero-sub {
		font-size: 2.5rem;
		line-height: 1.3;
		margin: 0 0 1.5rem;
	}
	.sg-hero-bar {
		width: 80%;
		max-width: 50rem;
		height: 0.7rem;
		background: var(--accent-color);
		border: 0.1rem solid var(--text-color);
		margin: 0 auto;
		border-radius: 0.5rem;
	}

	/* ── Placeholder image ── */
	.sg-placeholder-image {
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(
			135deg,
			var(--highlight-secondary),
			var(--highlight-accent)
		);
		color: white;
		font-family: var(--a-font);
		font-weight: 700;
		font-size: 1.6rem;
		height: 20rem;
		border-radius: 0.4rem;
	}

	/* ── Spacing grid ── */
	.sg-spacing-grid {
		display: grid;
		grid-template-columns: 1fr 1fr 1fr;
		gap: 0.6rem;
		margin: 1.5rem 0 3rem;
	}
	.sg-spacing-box {
		background: rgba(0, 0, 0, 0.04);
		border: 1px solid var(--text-color);
		border-radius: 0.4rem;
		padding: 1.5rem;
		text-align: center;
		font-family: var(--a-font);
		font-size: 1.3rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.sg-spacing-main {
		grid-column: span 2;
	}
	.sg-spacing-full {
		grid-column: 1 / -1;
	}

	/* ── Animation row ── */
	.sg-anim-row {
		display: flex;
		align-items: center;
		gap: 3rem;
		margin: 1.5rem 0 3rem;
	}

	/* ── Variable reference table ── */
	.sg-var-table {
		margin: 1.5rem 0 3rem;
		font-size: 1.5rem;
		border: 1px solid var(--text-color);
		border-radius: 0.6rem;
		overflow: hidden;
	}
	.sg-var-row {
		display: grid;
		grid-template-columns: 1fr 1fr 1fr;
		gap: 0 1.5rem;
		padding: 0.8rem 1.5rem;
		border-bottom: 1px solid rgba(0, 0, 0, 0.07);
		&:last-child {
			border-bottom: none;
		}
	}
	.sg-var-header {
		font-family: var(--a-font);
		font-weight: 700;
		font-size: 1.3rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		background: var(--text-color);
		color: var(--background-color);
		span {
			padding: 0.3rem 0;
		}
	}
</style>

---
import BaseLayout from "../../layouts/BaseLayout.astro";

export const blogData = {
  title: "Shark Thief iOS",
  author: "David Volz",
  description:
    "Web prototype for the Shark Thief iOS app — pixel-art ocean arcade game with depth levels.",
  pubDate: "2026-4-11",
  tags: ["javascript", "code", "game", "ios"],
  featured: true,
  display: true,
};

const showTypographyHero = false;
const fullWidthBody = true;
---

<style lang="scss">
  /* ── Design Tokens ── */
  .shark-ios-app {
    --ocean-abyss: #0a1f2e;
    --ocean-deep: #0d3545;
    --ocean-mid: #0f5262;
    --ocean-surface: #1d7e92;
    --cyan: #48cae4;
    --cyan-bright: #90e0ef;
    --gold: #ffd166;
    --coral-danger: #ef476f;
    --coral-block: #c8906a;
    --text-primary: #caf0f8;
    --text-muted: #7ac4d8;
    --border-glow: rgba(72, 202, 228, 0.2);
    --font-pixel: "Press Start 2P", cursive;
    --font-terminal: "VT323", monospace;
  }

  /* ── App Container ── */
  :global(main):has(.shark-ios-app) {
    padding-left: 0;
    padding-right: 0;
  }

  :global(html):has(.shark-ios-app),
  :global(body):has(.shark-ios-app) {
    touch-action: manipulation;
  }

  .shark-ios-app {
    width: 100%;
    touch-action: manipulation;
    background: var(--ocean-abyss);
    color: var(--text-primary);
    position: relative;
    min-height: calc(100dvh - 8rem);
  }

  /* ── Screens ── */
  .screen {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: calc(100dvh - 8rem);
    width: 100%;
    padding: 2rem 1.6rem;
    box-sizing: border-box;
    position: relative;

    &.active {
      display: flex;
    }
  }

  /* scanline overlay for menu screens */
  .screen-menu::after {
    content: "";
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.06) 2px,
      rgba(0, 0, 0, 0.06) 4px
    );
    pointer-events: none;
  }

  /* ── Typography ── */
  .pixel-title {
    font-family: var(--font-pixel);
    color: var(--cyan);
    text-align: center;
    line-height: 1.8;
    text-shadow:
      0 0 20px rgba(72, 202, 228, 0.6),
      0 0 40px rgba(72, 202, 228, 0.3);
    letter-spacing: 0.05em;
  }

  .terminal-text {
    font-family: var(--font-terminal);
    color: var(--text-primary);
    font-size: 2rem;
    line-height: 1.4;
  }

  /* ── Pixel Button ── */
  .pixel-btn {
    font-family: var(--font-pixel);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    padding: 1rem 2rem;
    border: 3px solid var(--cyan);
    border-radius: 2px;
    background: transparent;
    color: var(--cyan);
    cursor: pointer;
    text-transform: uppercase;
    transition:
      background 0.08s,
      box-shadow 0.08s,
      color 0.08s;
    min-height: 44px;
    touch-action: manipulation;

    &:hover {
      background: var(--cyan);
      color: var(--ocean-abyss);
      box-shadow: 0 0 14px rgba(72, 202, 228, 0.5);
    }
    &:active {
      transform: scale(0.95);
    }
  }

  .pixel-btn-muted {
    border-color: var(--text-muted);
    color: var(--text-muted);
    &:hover {
      background: var(--text-muted);
      color: var(--ocean-abyss);
    }
  }

  .pixel-btn-danger {
    border-color: var(--coral-danger);
    color: var(--coral-danger);
    &:hover {
      background: var(--coral-danger);
      color: #fff;
    }
  }

  /* ── Splash Screen ── */
  .splash-screen {
    background: var(--ocean-abyss);
    gap: 2rem;
  }

  .splash-canvas-wrap {
    position: relative;
    canvas {
      display: block;
    }
  }

  .splash-title {
    font-size: 1.4rem;
    margin: 0;
  }

  .splash-sub {
    font-family: var(--font-pixel);
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.15em;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  /* ── Main Menu ── */
  #menuSharkCanvas {
    display: block;
    margin-bottom: 1.6rem;
    image-rendering: pixelated;
  }

  .main-menu-title {
    font-size: 2rem;
    margin: 0 0 0.5rem;
  }

  .main-menu-sub {
    font-family: var(--font-terminal);
    font-size: 1.6rem;
    color: var(--text-muted);
    margin: 0 0 3rem;
  }

  .main-menu-buttons {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    width: 100%;
    max-width: 22rem;
  }

  .main-menu-buttons .pixel-btn {
    width: 100%;
    font-size: 1.05rem;
    padding: 1.2rem 2rem;
  }

  .main-menu-depth {
    font-family: var(--font-terminal);
    font-size: 1.6rem;
    color: var(--text-muted);
    margin-top: 2.5rem;
    letter-spacing: 0.1em;
  }

  /* ── Main Menu Save / Depth Buttons ── */
  .pixel-btn-continue {
    border-color: var(--cyan);
    color: var(--cyan);
    box-shadow: 0 0 14px rgba(72, 202, 228, 0.5), 0 0 28px rgba(72, 202, 228, 0.2);
    animation: continuePulse 2.4s ease-in-out infinite;
  }

  @keyframes continuePulse {
    0%, 100% { box-shadow: 0 0 10px rgba(72, 202, 228, 0.4), 0 0 24px rgba(72, 202, 228, 0.15); }
    50%       { box-shadow: 0 0 18px rgba(72, 202, 228, 0.75), 0 0 36px rgba(72, 202, 228, 0.35); }
  }

  .pixel-btn-continue:hover {
    background: var(--cyan);
    color: var(--ocean-abyss);
    animation: none;
  }

  .pixel-btn-abandon {
    border-color: #4a7a8a;
    color: #4a7a8a;
    font-size: 0.6rem;
    padding: 0.7rem 1.4rem;
    margin-top: 0.4rem;
  }

  .pixel-btn-abandon:hover {
    background: #4a7a8a;
    color: var(--ocean-abyss);
  }

  /* ── DIVE IN dropdown trigger ── */
  /* When it has unlocked depths, render as a proper dropdown toggle */
  .pixel-btn-dive-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;

    &::after {
      content: "▼";
      font-size: 0.6em;
      opacity: 0.65;
      margin-left: 0.8em;
      transition: transform 0.18s ease, opacity 0.18s ease;
    }
    &.open::after {
      transform: rotate(180deg);
      opacity: 1;
    }
    &.open {
      background: var(--cyan);
      color: var(--ocean-abyss);
      transform: scale(0.95);
      box-shadow: 0 0 14px rgba(72, 202, 228, 0.5);
    }
  }

  /* ── Depth Sub-Button Toggle Panel ── */
  /* Negative margins cancel the parent flex gap when collapsed so LEADERBOARD
     doesn't drift away from DIVE IN. Margins animate with the panel. */
  .depth-sub-btns {
    display: flex;
    flex-direction: column;
    gap: 0;
    width: 100%;
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    /* collapsed: eat the gap above and below */
    margin-top: -0.6rem;
    margin-bottom: -0.6rem;
    transition:
      max-height 0.22s ease-out,
      opacity 0.18s ease-out,
      margin-top 0.22s ease-out,
      margin-bottom 0.22s ease-out;
    pointer-events: none;

    &.expanded {
      max-height: 20rem;
      opacity: 1;
      margin-top: 0;
      margin-bottom: 0;
      pointer-events: all;
    }
  }

  /* Depth sub-buttons are injected via JS innerHTML, so they don't carry
     Astro's scope hash. Use :global() inside the scoped .depth-sub-btns
     parent so the scope hash is still anchored to the component. */

  /* Base pixel-btn style for all injected sub-buttons */
  .depth-sub-btns :global(button) {
    font-family: var(--font-pixel);
    font-size: 1.05rem; /* match .main-menu-buttons .pixel-btn */
    letter-spacing: 0.06em;
    padding: 0.85rem 2rem; /* slightly tighter than main 1.2rem */
    border: 3px solid var(--cyan);
    border-radius: 2px;
    background: transparent;
    color: var(--cyan);
    cursor: pointer;
    text-transform: uppercase;
    min-height: 40px;
    touch-action: manipulation;
    width: 100%;
    transition: background 0.08s, box-shadow 0.08s, color 0.08s;

    &:hover {
      background: var(--cyan);
      color: var(--ocean-abyss);
      box-shadow: 0 0 14px rgba(72, 202, 228, 0.5);
    }
    &:active { transform: scale(0.95); }
  }

  /* Depth 2: lighter coral — derived from coral shell sprite highlight */
  .depth-sub-btns :global(.pixel-btn-d2) {
    border-color: #daa070;
    color: #daa070;

    &:hover {
      background: #daa070;
      color: var(--ocean-abyss);
      box-shadow: 0 0 14px rgba(218, 160, 112, 0.5);
    }
  }

  /* Depth 3: deep abyss violet */
  .depth-sub-btns :global(.pixel-btn-d3) {
    border-color: #9d6fe0;
    color: #9d6fe0;

    &:hover {
      background: #9d6fe0;
      color: var(--ocean-abyss);
      box-shadow: 0 0 14px rgba(157, 111, 224, 0.5);
    }
  }

  /* Sub-panel top border connects visually to the open DIVE IN button */
  .depth-sub-btns.expanded {
    border-top: 2px solid rgba(218, 160, 112, 0.25);
    padding-top: 0.7rem;
    gap: 0.6rem;
  }

  /* ── Main Menu Best Score ── */
  .main-menu-best {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    margin-bottom: 2rem;
  }

  .main-menu-best-label {
    font-family: var(--font-pixel);
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
  }

  .main-menu-best-score {
    font-family: var(--font-terminal);
    font-size: 2.8rem;
    color: var(--gold);
    line-height: 1;
  }

  /* ── Game Screen ── */
  .game-screen {
    padding: 0;
    justify-content: flex-start;
    min-height: calc(100dvh - 8rem);
    gap: 0;
  }

  .game-depth-wrapper {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    transition: background 0.8s ease;

    &.depth-1 {
      background: var(--ocean-abyss);
    }
    &.depth-2 {
      background: #071828;
    }
    &.depth-3 {
      background: #040f1a;
    }
  }

  /* ── HUD ── */
  .ios-hud {
    width: 100%;
    max-width: 600px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.8rem 1.2rem;
    box-sizing: border-box;
    background: rgba(7, 20, 40, 0.9);
    border-bottom: 1px solid var(--ocean-surface);
  }

  .hud-score-group {
    display: flex;
    gap: 2rem;
  }

  .hud-score-item {
    text-align: center;
  }

  .hud-score-label {
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    color: var(--text-muted);
    display: block;
    margin-bottom: 0.2rem;
    letter-spacing: 0.1em;
  }

  .hud-score-value {
    font-family: var(--font-terminal);
    font-size: 2.2rem;
    color: var(--gold);
    line-height: 1;
  }

  /* HUD buttons share the pixel-btn language at compact HUD scale */
  .hud-btn {
    font-family: var(--font-pixel);
    font-size: 0.58rem;
    letter-spacing: 0.06em;
    padding: 0.55rem 0.9rem;
    border: 2px solid var(--text-muted);
    border-radius: 2px;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    text-transform: uppercase;
    touch-action: manipulation;
    transition: background 0.08s, color 0.08s, border-color 0.08s, box-shadow 0.08s;
    min-height: 36px;
    white-space: nowrap;
    flex-shrink: 0;

    &:hover {
      background: var(--text-muted);
      color: var(--ocean-abyss);
    }
    &:active { transform: scale(0.95); }
  }

  /* Depth button: color shifts per depth, plus the [?] info icon */
  .hud-depth-btn {
    border-color: var(--cyan);
    color: var(--cyan);
    display: flex;
    align-items: center;
    gap: 0.45em;

    &:hover {
      background: var(--cyan);
      color: var(--ocean-abyss);
      box-shadow: 0 0 10px rgba(72, 202, 228, 0.5);
    }
    &.depth-2 {
      border-color: #daa070;
      color: #daa070;
      &:hover { background: #daa070; color: var(--ocean-abyss); box-shadow: 0 0 10px rgba(218,160,112,0.5); }
    }
    &.depth-3 {
      border-color: #9d6fe0;
      color: #9d6fe0;
      &:hover { background: #9d6fe0; color: var(--ocean-abyss); box-shadow: 0 0 10px rgba(157,111,224,0.5); }
    }
  }

  .hud-info-icon {
    font-family: var(--font-terminal);
    font-size: 1.15em;
    line-height: 1;
    opacity: 0.75;
  }

  /* ── Depth Info Overlay ── */
  .depth-info-overlay {
    position: fixed;
    inset: 0;
    z-index: 500;
    background: rgba(4, 12, 24, 0.92);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 2rem 1rem 3rem;
    box-sizing: border-box;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.18s ease;
    overflow-y: auto;

    &.visible {
      opacity: 1;
      pointer-events: all;
    }
  }

  .depth-info-panel {
    background: var(--ocean-deep);
    border: 3px solid var(--cyan);
    border-radius: 2px;
    width: 100%;
    max-width: 440px;
    overflow: hidden;
    transform: translateY(10px);
    transition: transform 0.2s ease, border-color 0.2s ease;

    .depth-info-overlay.visible & {
      transform: translateY(0);
    }
  }

  .depth-info-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: 1.4rem 1.4rem 1.1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }

  .depth-info-badge {
    font-family: var(--font-pixel);
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    margin-bottom: 0.45rem;
    color: var(--cyan); /* set by JS per depth */
  }

  .depth-info-name {
    font-family: var(--font-pixel);
    font-size: 0.85rem;
    color: var(--text-primary);
    line-height: 1.7;
  }

  .depth-info-rules {
    padding: 1.4rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Rules content is injected via innerHTML — must use :global() anchored to
     the static .depth-info-rules parent so Astro's scope hash still gates it */
  .depth-info-rules :global(.depth-rules-section-label) {
    font-family: var(--font-pixel);
    font-size: 0.52rem;
    color: var(--text-muted);
    letter-spacing: 0.18em;
    margin-bottom: 1rem;
    display: block;
  }

  .depth-info-rules :global(.depth-rule-row) {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: 0.8rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    align-items: start;
  }

  .depth-info-rules :global(.depth-rule-key) {
    font-family: var(--font-pixel);
    font-size: 0.55rem;
    letter-spacing: 0.05em;
    padding-top: 0.2rem;
  }

  .depth-info-rules :global(.depth-rule-val) {
    font-family: var(--font-terminal);
    font-size: 1.25rem;
    color: var(--text-primary);
    line-height: 1.35;
  }

  .depth-info-scene {
    padding: 1.4rem;
  }

  .depth-scene-section-label {
    font-family: var(--font-pixel);
    font-size: 0.52rem;
    color: var(--text-muted);
    letter-spacing: 0.18em;
    margin-bottom: 1rem;
  }

  .depth-scene-canvas-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 0.9rem;
  }

  #depthSceneCanvas {
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    border: 2px solid rgba(255, 255, 255, 0.08);
    display: block;
  }

  .depth-scene-caption {
    font-family: var(--font-terminal);
    font-size: 1.35rem;
    color: var(--text-muted);
    text-align: center;
    min-height: 2.2em;
    margin: 0 0 1.2rem;
    line-height: 1.4;
  }

  .depth-scene-controls {
    display: flex;
    gap: 0.8rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Scene control buttons reuse hud-btn but with depth color override */
  .depth-scene-ctrl {
    font-size: 0.62rem;
    padding: 0.6rem 1.1rem;
  }

  /* Move counter pill — sits below the mini canvas */
  .depth-scene-move-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
  }

  .depth-scene-move-pip {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    border: 1px solid rgba(255,255,255,0.25);
    background: rgba(255,255,255,0.08);
    transition: background 0.12s, border-color 0.12s;

    &.shark-pip {
      border-color: #7aaab8;
      &.filled { background: #7aaab8; }
    }
    &.enemy-pip {
      border-color: #162d40;
      &.filled { background: #162d40; }
    }
  }

  .depth-scene-move-label {
    font-family: var(--font-pixel);
    font-size: 0.46rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
  }

  /* ── Canvas ── */
  .game-canvas-area {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    width: 100%;
    max-width: 600px;
    padding: 0.4rem 0;
  }

  #gameCanvas {
    display: block;
    max-width: min(600px, calc(100vw - 16px));
    aspect-ratio: 1;
    width: 100%;
    height: auto;
    image-rendering: pixelated;
  }

  /* ── Depth Flash ── */
  .depth-flash {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-pixel);
    font-size: 1.4rem;
    color: var(--cyan);
    opacity: 0;
    pointer-events: none;
    z-index: 20;
    text-shadow:
      0 0 20px var(--cyan),
      0 0 40px rgba(72, 202, 228, 0.5);
    letter-spacing: 0.1em;

    &.flashing {
      animation: depth-flash-anim 1.6s ease-out forwards;
    }
  }

  @keyframes depth-flash-anim {
    0% {
      opacity: 0;
      transform: scale(0.7);
    }
    15% {
      opacity: 1;
      transform: scale(1.1);
    }
    55% {
      opacity: 1;
      transform: scale(1);
    }
    100% {
      opacity: 0;
      transform: scale(1);
    }
  }

  /* ── Game Over Overlay ── */
  .game-over-overlay {
    position: absolute;
    inset: 0;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(2, 8, 20, 0.88);
    z-index: 30;

    &.visible {
      display: flex;
    }
  }

  .game-over-title {
    font-family: var(--font-pixel);
    font-size: 1.4rem;
    color: var(--coral-danger);
    text-shadow: 0 0 20px rgba(239, 71, 111, 0.7);
    margin: 0 0 0.8rem;
    letter-spacing: 0.1em;
  }

  .game-over-score {
    font-family: var(--font-terminal);
    font-size: 3.2rem;
    color: var(--gold);
    margin: 0 0 2rem;
    line-height: 1;
  }

  .game-over-buttons {
    display: flex;
    gap: 1.2rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 1.2rem;
  }

  .submit-area {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 0.4rem;
  }

  .name-input-row {
    display: none;
    gap: 0.6rem;

    &.visible {
      display: flex;
    }
  }

  .name-input {
    font-family: var(--font-terminal);
    font-size: 1.8rem;
    padding: 0.4rem 0.8rem;
    border: 2px solid var(--cyan);
    border-radius: 2px;
    background: rgba(72, 202, 228, 0.08);
    color: var(--text-primary);
    width: 14rem;
    outline: none;

    &::placeholder {
      color: var(--text-muted);
    }
    &:focus {
      box-shadow: 0 0 8px rgba(72, 202, 228, 0.4);
    }
  }

  .submit-status {
    font-family: var(--font-terminal);
    font-size: 1.6rem;
    color: var(--cyan);
    min-height: 1.8rem;
  }

  /* ── D-Pad ── */
  .dpad {
    display: none;
    width: 100%;
    max-width: 600px;
    padding: 0.6rem 1.2rem 1.2rem;
    box-sizing: border-box;
    -webkit-user-select: none;
    user-select: none;
    touch-action: none;
    background: rgba(7, 20, 40, 0.9);
    border-top: 1px solid var(--ocean-surface);
  }

  @media (pointer: coarse) {
    .dpad {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: repeat(3, 1fr);
      gap: 0.5rem;
      width: 100%;
      max-width: none;
      /* Center the button area (≈28rem) while extending bg edge-to-edge */
      padding-left: max(1.2rem, calc(50% - 14rem));
      padding-right: max(1.2rem, calc(50% - 14rem));
      box-sizing: border-box;
      margin: 0;
    }
  }

  .dpad-btn {
    appearance: none;
    width: 100%;
    aspect-ratio: 1;
    border: 3px solid var(--cyan);
    border-radius: 4px;
    background: rgba(72, 202, 228, 0.05);
    color: var(--cyan);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      background 0.08s,
      box-shadow 0.08s;
    -webkit-tap-highlight-color: transparent;
    touch-action: none;
    min-height: 5.5rem;

    svg {
      width: 2.4rem;
      height: 2.4rem;
      fill: var(--cyan);
      stroke: none;
    }

    &.pressed,
    &:active {
      background: rgba(72, 202, 228, 0.22);
      box-shadow: 0 0 14px rgba(72, 202, 228, 0.5);
    }
  }

  .dpad-up {
    grid-column: 2;
    grid-row: 1;
  }
  .dpad-left {
    grid-column: 1;
    grid-row: 2;
  }
  .dpad-right {
    grid-column: 3;
    grid-row: 2;
  }
  .dpad-down {
    grid-column: 2;
    grid-row: 3;
  }
  .dpad-center {
    grid-column: 2;
    grid-row: 2;
    border: none;
    background: none;
    pointer-events: none;
  }

  /* ── Leaderboard Screen ── */
  .leaderboard-screen {
    align-items: flex-start;
    padding: 2rem 1.2rem;
  }

  .lb-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
    margin-bottom: 2rem;
  }

  .lb-title {
    font-family: var(--font-pixel);
    font-size: 0.7rem;
    color: var(--cyan);
    margin: 0;
    flex: 1;
  }

  .lb-map-label {
    font-family: var(--font-terminal);
    font-size: 1.6rem;
    color: var(--text-muted);
    display: block;
    text-align: right;
  }

  .lb-table-wrap {
    width: 100%;
    overflow-x: auto;
  }

  .lb-table {
    width: 100%;
    min-width: 32rem;
    border-collapse: collapse;
    font-family: var(--font-terminal);
    font-size: 1.8rem;

    thead th {
      font-family: var(--font-pixel);
      font-size: 0.7rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      padding: 0.6rem 0.8rem;
      border-bottom: 2px solid var(--ocean-surface);
      text-align: left;
    }

    tbody td {
      padding: 0.5rem 0.8rem;
      border-bottom: 1px solid rgba(26, 94, 122, 0.4);
      color: var(--text-primary);
    }

    tbody tr:hover td {
      background: rgba(72, 202, 228, 0.04);
    }

    tbody tr.highlight td {
      background: rgba(72, 202, 228, 0.1);
    }

    td.lb-score {
      color: var(--gold);
      font-size: 2.2rem;
      text-align: center;
    }

    td.lb-date {
      color: var(--text-muted);
      font-size: 1.4rem;
      text-align: right;
      white-space: nowrap;
    }

    td.lb-rank {
      width: 4rem;
      text-align: center;
      font-size: 1.6rem;
    }
  }

  .medal {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 50%;
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    box-shadow: inset 0 -2px 4px rgba(0, 0, 0, 0.2);
  }

  /* ── Leaderboard Tab Bar ── */
  .lb-tab-bar {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    width: 100%;
    margin-bottom: 1.5rem;
    padding-bottom: 0.2rem;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    &::-webkit-scrollbar { display: none; }
  }

  .lb-tab {
    font-family: var(--font-pixel);
    font-size: 0.52rem;
    letter-spacing: 0.06em;
    padding: 0.5rem 0.85rem;
    border: 2px solid rgba(255, 255, 255, 0.18);
    border-radius: 2px;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    text-transform: uppercase;
    white-space: nowrap;
    flex-shrink: 0;
    touch-action: manipulation;
    min-height: 36px;
    transition: background 0.08s, color 0.08s, border-color 0.08s;

    &:hover:not(:disabled) {
      background: rgba(255, 255, 255, 0.07);
      border-color: rgba(255, 255, 255, 0.4);
      color: var(--text-primary);
    }

    &:focus-visible {
      outline: 2px solid var(--cyan);
      outline-offset: 2px;
    }

    &[aria-selected="true"],
    &.active {
      background: var(--cyan);
      border-color: var(--cyan);
      color: var(--ocean-abyss);
    }

    &.lb-tab-disabled,
    &:disabled {
      opacity: 0.32;
      cursor: not-allowed;
      pointer-events: none;
    }
  }

  /* Shark Score [?] inline help button */
  .lb-shark-help {
    background: none;
    border: 1px solid var(--text-muted);
    color: var(--text-muted);
    font-family: var(--font-pixel);
    font-size: 0.42rem;
    padding: 0.1rem 0.35rem;
    border-radius: 2px;
    cursor: pointer;
    margin-left: 0.45rem;
    vertical-align: middle;
    touch-action: manipulation;
    transition: color 0.08s, border-color 0.08s;
    min-height: 0;
    &:hover { color: var(--gold); border-color: var(--gold); }
    &:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }
  }

  /* Shark Score formula popup — gold border override */
  .shark-score-panel {
    border-color: var(--gold) !important;
  }

  .shark-score-rules {
    padding: 1.2rem 1.4rem 1.6rem;
  }

  .shark-score-rules :global(.depth-rules-section-label) {
    font-family: var(--font-pixel);
    font-size: 0.52rem;
    color: var(--text-muted);
    letter-spacing: 0.18em;
    margin-bottom: 1rem;
    display: block;
  }

  .shark-score-rules :global(.depth-rule-row) {
    display: grid;
    grid-template-columns: 5.5rem 1fr;
    gap: 0.8rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    align-items: start;
  }

  .shark-score-rules :global(.depth-rule-key) {
    font-family: var(--font-pixel);
    font-size: 0.52rem;
    letter-spacing: 0.05em;
    padding-top: 0.2rem;
    color: var(--gold);
  }

  .shark-score-rules :global(.depth-rule-val) {
    font-family: var(--font-terminal);
    font-size: 1.25rem;
    color: var(--text-primary);
    line-height: 1.35;
  }

  .medal-gold {
    background: linear-gradient(145deg, #f7dc6f, #d4a017);
    color: #5c4300;
    border: 2px solid #c9960c;
  }
  .medal-silver {
    background: linear-gradient(145deg, #d5d5d5, #a0a0a0);
    color: #4a4a4a;
    border: 2px solid #909090;
  }
  .medal-bronze {
    background: linear-gradient(145deg, #dea06e, #b87333);
    color: #5a3510;
    border: 2px solid #a0612a;
  }

  .lb-empty {
    font-family: var(--font-terminal);
    font-size: 1.8rem;
    color: var(--text-muted);
    text-align: center;
    padding: 2rem 0;
  }

  /* ── Settings Screen ── */
  .settings-screen {
    align-items: center;
    padding: 2rem 1.6rem;
  }

  .settings-screen .lb-header {
    width: 100%;
    max-width: 36rem;
  }

  .settings-title {
    font-size: 0.75rem;
    margin: 0 0 2.5rem;
  }

  .settings-rows {
    width: 100%;
    max-width: 36rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .settings-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.4rem 0;
    border-bottom: 1px solid var(--ocean-surface);
  }

  .settings-row-label {
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    color: var(--text-primary);
    letter-spacing: 0.06em;
  }

  .settings-row-sub {
    font-family: var(--font-terminal);
    font-size: 1.4rem;
    color: var(--text-muted);
    display: block;
    margin-top: 0.3rem;
  }

  .pixel-toggle {
    position: relative;
    width: 4.4rem;
    height: 2.4rem;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;

    input {
      opacity: 0;
      width: 0;
      height: 0;
      position: absolute;
    }

    .toggle-track {
      position: absolute;
      inset: 0;
      background: var(--ocean-surface);
      border: 2px solid var(--ocean-surface);
      border-radius: 2px;
      transition:
        background 0.1s,
        border-color 0.1s;
    }

    .toggle-knob {
      position: absolute;
      top: 3px;
      left: 3px;
      width: 1.4rem;
      height: 1.4rem;
      background: var(--text-muted);
      border-radius: 2px;
      transition:
        transform 0.1s,
        background 0.1s;
    }

    input:checked ~ .toggle-track {
      background: rgba(72, 202, 228, 0.2);
      border-color: var(--cyan);
      box-shadow: 0 0 10px rgba(72, 202, 228, 0.7), 0 0 20px rgba(72, 202, 228, 0.3);
    }

    input:checked ~ .toggle-track .toggle-knob {
      transform: translateX(2rem);
      background: var(--cyan);
    }
  }

  .settings-version {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    color: var(--text-muted);
    margin-top: 3rem;
  }

  /* ── Dev Panel ── */
  .dev-panel {
    width: 100%;
    max-width: 36rem;
    margin-top: 2.4rem;
    border: 2px dashed rgba(255, 209, 102, 0.4);
    border-radius: 2px;
    padding: 1.2rem 1.4rem;
    box-sizing: border-box;
  }

  .dev-panel-label {
    font-family: var(--font-pixel);
    font-size: 0.55rem;
    color: var(--gold);
    letter-spacing: 0.1em;
    opacity: 0.7;
    margin: 0 0 1rem;
    text-transform: uppercase;
  }

  .dev-panel-btns {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .dev-panel-btns :global(button) {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    padding: 0.6rem 1rem;
    border: 2px solid rgba(255, 209, 102, 0.5);
    border-radius: 2px;
    background: transparent;
    color: var(--gold);
    cursor: pointer;
    letter-spacing: 0.05em;
    opacity: 0.75;
    touch-action: manipulation;
    transition: background 0.08s, opacity 0.08s;

    &:hover {
      background: rgba(255, 209, 102, 0.15);
      opacity: 1;
    }

    &:active {
      transform: scale(0.95);
    }
  }
</style>

<BaseLayout
  pageTitle={blogData.title}
  showTypographyHero={showTypographyHero}
  description={blogData.description}
  fullWidthBody={fullWidthBody}>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323:wght@400&display=swap"
      rel="stylesheet"
    />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no"
    />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta
      name="apple-mobile-web-app-status-bar-style"
      content="black-translucent"
    />
  </Fragment>

  <div class="shark-ios-app" id="sharkIosApp">
    <!-- ── Screen 1: Splash ── LaunchView.swift -->
    <div id="screen-splash" class="screen splash-screen active">
      <canvas id="splashSharkCanvas" width="160" height="160"></canvas>
      <h1 class="pixel-title splash-title">SHARK<br />THIEF</h1>
      <p class="splash-sub">LOADING...</p>
    </div>

    <!-- ── Screen 2: Main Menu ── MainMenuView.swift -->
    <div id="screen-main-menu" class="screen screen-menu">
      <canvas id="menuSharkCanvas" width="120" height="120"></canvas>
      <h2 class="pixel-title main-menu-title">SHARK THIEF</h2>
      <p class="main-menu-sub">OCEAN ARCADE</p>
      <div class="main-menu-best">
        <span class="main-menu-best-label">BEST</span>
        <span class="main-menu-best-score" id="menuBestScore">0</span>
      </div>
      <div class="main-menu-buttons">
        <button class="pixel-btn pixel-btn-continue" id="menuContinueBtn" style="display:none">CONTINUE</button>
        <button class="pixel-btn" id="menuPlayBtn">DIVE IN</button>
        <div class="depth-sub-btns" id="depthSubBtns"></div>
        <button class="pixel-btn pixel-btn-muted" id="menuLeaderboardBtn"
          >LEADERBOARD</button
        >
        <button class="pixel-btn pixel-btn-muted" id="menuSettingsBtn"
          >SETTINGS</button
        >
        <button class="pixel-btn pixel-btn-abandon" id="menuAbandonBtn" style="display:none">ABANDON DIVE</button>
      </div>
      <p class="main-menu-depth" id="menuDepthLabel"></p>
    </div>

    <!-- ── Screen 4: Game ── GameView.swift -->
    <div id="screen-game" class="screen game-screen">
      <div class="game-depth-wrapper depth-1" id="gameDepthWrapper">
        <!-- HUDView.swift -->
        <div class="ios-hud">
          <button class="hud-btn" id="hudMenuBtn">MENU</button>
          <div class="hud-score-group">
            <div class="hud-score-item">
              <span class="hud-score-label">SCORE</span>
              <span class="hud-score-value" id="hudScore">0</span>
            </div>
            <div class="hud-score-item">
              <span class="hud-score-label">BEST</span>
              <span class="hud-score-value" id="hudBest">0</span>
            </div>
          </div>
          <button class="hud-btn hud-depth-btn" id="hudDepthBtn">
            <span id="hudDepthLabel">DEPTH 1</span>
            <span class="hud-info-icon">[?]</span>
          </button>
        </div>

        <!-- Canvas area -->
        <div class="game-canvas-area">
          <canvas id="gameCanvas" width="600" height="600"></canvas>
          <div class="depth-flash" id="depthFlash"></div>

          <!-- GameOverView.swift — overlay on frozen canvas -->
          <div class="game-over-overlay" id="gameOverOverlay">
            <h2 class="game-over-title">YOU DIED</h2>
            <p class="game-over-score">SCORE: <span id="finalScore">0</span></p>
            <div class="submit-area">
              <div id="submitPrompt">
                <button class="pixel-btn" id="wantToSubmitBtn"
                  >SUBMIT SCORE</button
                >
              </div>
              <div class="name-input-row" id="nameInputRow">
                <input
                  class="name-input"
                  type="text"
                  id="playerName"
                  placeholder="YOUR NAME"
                  maxlength="20"
                  autocomplete="off"
                />
                <button class="pixel-btn" id="submitScoreBtn">GO</button>
              </div>
              <p class="submit-status" id="submitStatus"></p>
            </div>
            <div class="game-over-buttons">
              <button class="pixel-btn" id="playAgainBtn">DIVE AGAIN</button>
              <button class="pixel-btn pixel-btn-muted" id="gameOverMenuBtn"
                >SURFACE</button
              >
            </div>
          </div>
        </div>

        <!-- DPadView.swift -->
        <div class="dpad" id="dpad">
          <button class="dpad-btn dpad-up" data-dir="up" aria-label="Move up">
            <svg viewBox="0 0 24 24"><path d="M12 4 L22 20 L2 20 Z"></path></svg
            >
          </button>
          <button
            class="dpad-btn dpad-left"
            data-dir="left"
            aria-label="Move left">
            <svg viewBox="0 0 24 24"><path d="M4 12 L20 2 L20 22 Z"></path></svg
            >
          </button>
          <div class="dpad-center"></div>
          <button
            class="dpad-btn dpad-right"
            data-dir="right"
            aria-label="Move right">
            <svg viewBox="0 0 24 24"><path d="M20 12 L4 2 L4 22 Z"></path></svg>
          </button>
          <button
            class="dpad-btn dpad-down"
            data-dir="down"
            aria-label="Move down">
            <svg viewBox="0 0 24 24"><path d="M12 20 L2 4 L22 4 Z"></path></svg>
          </button>
        </div>
      </div>
    </div>

    <!-- ── Screen 5: Leaderboard ── LeaderboardView.swift -->
    <div id="screen-leaderboard" class="screen leaderboard-screen">
      <div class="lb-header">
        <button class="pixel-btn pixel-btn-muted" id="lbBackBtn">BACK</button>
        <div>
          <h2 class="lb-title">LEADERBOARD</h2>
          <span class="lb-map-label" id="lbMapLabel">SHARK THIEF</span>
        </div>
      </div>
      <!-- Tab bar -->
      <div class="lb-tab-bar" role="tablist" aria-label="Leaderboard categories">
        <button class="lb-tab active" role="tab" aria-selected="true"  data-category="high_score">HIGH SCORE</button>
        <button class="lb-tab"        role="tab" aria-selected="false" data-category="d1_time">D1 TIME</button>
        <button class="lb-tab"        role="tab" aria-selected="false" data-category="d2_time">D2 TIME</button>
        <button class="lb-tab lb-tab-disabled" role="tab" aria-selected="false" aria-disabled="true" data-category="d3_time" disabled>D3 TIME</button>
        <button class="lb-tab"        role="tab" aria-selected="false" data-category="shark_score">SHARK SCORE</button>
      </div>
      <div class="lb-table-wrap">
        <table class="lb-table">
          <thead id="lbTableHead">
            <tr>
              <th>#</th>
              <th>NAME</th>
              <th>SCORE</th>
              <th>DATE</th>
            </tr>
          </thead>
          <tbody id="leaderboardBody">
            <tr><td colspan="4" class="lb-empty">LOADING...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- ── Screen 6: Settings ── SettingsView.swift -->
    <div id="screen-settings" class="screen settings-screen">
      <div class="lb-header">
        <button class="pixel-btn pixel-btn-muted" id="settingsBackBtn"
          >BACK</button
        >
        <h2 class="pixel-title settings-title">SETTINGS</h2>
      </div>
      <div class="settings-rows">
        <div class="settings-row">
          <div>
            <span class="settings-row-label">COLORBLIND MODE</span>
            <span class="settings-row-sub">Grid lines only</span>
          </div>
          <label class="pixel-toggle" aria-label="Toggle colorblind mode">
            <input type="checkbox" id="settingsColorblind" />
            <div class="toggle-track">
              <div class="toggle-knob"></div>
            </div>
          </label>
        </div>
        <div class="settings-row">
          <div>
            <span class="settings-row-label">HAPTIC FEEDBACK</span>
            <span class="settings-row-sub">Vibration on move</span>
          </div>
          <label class="pixel-toggle" aria-label="Toggle haptic feedback">
            <input type="checkbox" id="settingsHaptics" checked />
            <div class="toggle-track">
              <div class="toggle-knob"></div>
            </div>
          </label>
        </div>
        <div class="settings-row">
          <div>
            <span class="settings-row-label">WATER SHIMMER</span>
            <span class="settings-row-sub">Animated light on tiles</span>
          </div>
          <label class="pixel-toggle" aria-label="Toggle water shimmer">
            <input type="checkbox" id="settingsShimmer" />
            <div class="toggle-track">
              <div class="toggle-knob"></div>
            </div>
          </label>
        </div>
      </div>
      <div class="dev-panel">
        <p class="dev-panel-label">⚠ DEV — JUMP TO DEPTH</p>
        <div class="dev-panel-btns" id="devJumpBtns"></div>
      </div>
      <p class="settings-version">SHARK THIEF iOS v0.1.0 — WEB PROTOTYPE</p>
    </div>

    <!-- ── Depth Info Overlay ── -->
    <div class="depth-info-overlay" id="depthInfoOverlay">
      <div class="depth-info-panel" id="depthInfoPanel">
        <div class="depth-info-header">
          <div>
            <div class="depth-info-badge" id="depthInfoBadge">DEPTH 1</div>
            <div class="depth-info-name" id="depthInfoName">SURFACE REEF</div>
          </div>
          <button class="hud-btn" id="depthInfoClose">✕ BACK</button>
        </div>
        <div class="depth-info-rules" id="depthInfoRules">
          <!-- populated by JS -->
        </div>
        <div class="depth-info-scene">
          <div class="depth-scene-section-label">► HOW IT WORKS</div>
          <div class="depth-scene-canvas-wrap">
            <canvas id="depthSceneCanvas" width="200" height="200"></canvas>
          </div>
          <div class="depth-scene-move-row" id="depthMoveRow">
            <span class="depth-scene-move-label">YOU</span>
            <div class="depth-scene-move-pip shark-pip" id="movePip1"></div>
            <div class="depth-scene-move-pip shark-pip" id="movePip2"></div>
            <span class="depth-scene-move-label">ENEMY</span>
            <div class="depth-scene-move-pip enemy-pip" id="enemyPip1"></div>
          </div>
          <p class="depth-scene-caption" id="depthSceneCaption">—</p>
          <div class="depth-scene-controls">
            <button class="hud-btn depth-scene-ctrl" id="depthScenePlay">▶ PLAY</button>
            <button class="hud-btn depth-scene-ctrl" id="depthScenePause" style="display:none">⏸ PAUSE</button>
            <button class="hud-btn depth-scene-ctrl" id="depthSceneReset" style="display:none">↺ RESET</button>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Shark Score Formula Popup ── -->
    <div class="depth-info-overlay" id="sharkScorePopup">
      <div class="depth-info-panel shark-score-panel">
        <div class="depth-info-header">
          <div>
            <div class="depth-info-badge" style="color:var(--gold)">SCORING FORMULA</div>
            <div class="depth-info-name">SHARK SCORE</div>
          </div>
          <button class="hud-btn" id="sharkScorePopupClose">✕ BACK</button>
        </div>
        <div class="depth-info-rules shark-score-rules">
          <div class="depth-rules-section-label">► THE FORMULA</div>
          <div class="depth-rule-row">
            <span class="depth-rule-key">FORMULA</span>
            <span class="depth-rule-val">SHARK SCORE = SCORE² ÷ TIME (seconds)</span>
          </div>
          <div class="depth-rule-row">
            <span class="depth-rule-key">EXAMPLE</span>
            <span class="depth-rule-val">Score 250 in 90s → 250² ÷ 90 = 694</span>
          </div>
          <div class="depth-rules-section-label" style="margin-top:1.4rem">► DESIGN INTENT</div>
          <div class="depth-rule-row">
            <span class="depth-rule-key">HIGH SCORE</span>
            <span class="depth-rule-val">Matters most — doubling your score quadruples Shark Score.</span>
          </div>
          <div class="depth-rule-row">
            <span class="depth-rule-key">FAST TIME</span>
            <span class="depth-rule-val">Acts as a multiplier — cutting time in half doubles Shark Score.</span>
          </div>
          <div class="depth-rule-row">
            <span class="depth-rule-key">BALANCE</span>
            <span class="depth-rule-val">A high score at average speed still ranks well. Neither extreme dominates.</span>
          </div>
          <div class="depth-rules-section-label" style="margin-top:1.4rem">► NOTE</div>
          <div class="depth-rule-row">
            <span class="depth-rule-key">TUNABLE</span>
            <span class="depth-rule-val">The exponent (currently 2) may be adjusted as the game grows to keep the leaderboard meaningful across all score ranges.</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  // ╔══════════════════════════════════════════════════════╗
  // ║  SHARK THIEF iOS — Web Prototype                     ║
  // ║  Code sections mirror the Swift file architecture   ║
  // ╚══════════════════════════════════════════════════════╝

  // ===== GameConfig =====  →  GameConfig.swift

  const ANIM_DURATION = 80; // ms — matches iOS 80ms ease-out quad
  const MIN_ENEMY_DIST = 5; // min Manhattan distance for enemy spawn
  const PICKUP_RATE = 0.00025; // per cell per move
  const SUPER_RATE_OF_PICKUP = 0.0175; // fraction of new pickups that become super
  const PICKUP_INIT = 0.05; // 5% of cells on init
  const SUPER_INIT = 1 / 40; // 1 in 40 init pickups become super
  const CORAL_PICKUP_RATE = 0.00028; // depth-2+ coral shell (5pts) growth per cell per move
  const CORAL_PICKUP_INIT = 4; // # of coral shells spawned on entering depth 2

  // ===== GameState =====  →  GameState.swift

  interface Enemy {
    x: number;
    y: number;
  }
  interface BigEnemy {
    x: number;
    y: number;
  }
  interface Leviathan {
    x: number;
    y: number;
  }

  const GRID = 25;
  let CELL = 0; // set after canvas size is known

  let shark = { x: 0, y: 0 };
  let sharkDir: "right" | "left" | "up" | "down" = "right";
  let score = 0;
  let highScore = 0;
  let moveCount = 0;
  let gameOver = false;

  // Smooth shark animation state
  let sharkVisualX = 0,
    sharkVisualY = 0;
  let sharkFromX = 0,
    sharkFromY = 0;
  let animStartTime = 0;
  let animRafId: number | null = null;

  // Bounce animation state (coral shell impact)
  let bounceTargetX = 0, bounceTargetY = 0;

  // ===== GridState =====  →  GridState.swift

  let colors: string[][] = [];
  let pickups: boolean[][] = [];
  let superPickups: boolean[][] = [];
  let coralPickups: boolean[][] = []; // Depth 2+: cone shell (5 pts)
  let coral: boolean[][] = []; // Depth 2: impassable barrier tiles

  // ===== EnemyAI (state) =====  →  Enemy.swift / BigEnemy.swift

  let enemies: Enemy[] = [];
  let bigEnemies: BigEnemy[] = [];
  let leviathan: Leviathan | null = null; // Depth 3: 3×3 mega enemy

  // ===== DepthSystem =====  →  DepthSystem.swift

  let currentDepth = 1;

  // ===== TimingService =====  →  TimingService.swift

  let gameStartTime = 0;        // performance.now() when current run started
  let totalTimeMs = 0;          // accumulated ms when game ends
  let levelStartTime = 0;       // performance.now() when current depth started
  let levelTimes: number[] = []; // ms spent in each depth [depth1ms, depth2ms, ...]

  interface DyingEnemy {
    x: number;
    y: number;
    isBig: boolean; // 2×2 if true
    startTime: number; // performance.now() when animation begins
  }
  const DYING_DURATION = 450; // ms per enemy
  let dyingEnemies: DyingEnemy[] = [];
  let dyingRafId: number | null = null;

  function startDyingLoop() {
    if (dyingRafId) return;
    function tick() {
      const now = performance.now();
      dyingEnemies = dyingEnemies.filter(de => now - de.startTime < DYING_DURATION);
      draw();
      if (dyingEnemies.length > 0) {
        dyingRafId = requestAnimationFrame(tick);
      } else {
        dyingRafId = null;
      }
    }
    dyingRafId = requestAnimationFrame(tick);
  }

  // Keep 5 farthest enemies, dissolve the closest — closest disappear first (0ms delay)
  function clearCloseEnemies() {
    type EnemyRef = { x: number; y: number; isBig: boolean };
    const all: EnemyRef[] = [
      ...enemies.map(e => ({ x: e.x, y: e.y, isBig: false })),
      ...bigEnemies.map(e => ({ x: e.x, y: e.y, isBig: true })),
    ];
    if (all.length === 0) return;

    const dist = (p: EnemyRef) =>
      Math.abs(p.x - shark.x) + Math.abs(p.y - shark.y);

    all.sort((a, b) => dist(b) - dist(a)); // farthest first
    const keep = new Set(all.slice(0, 5).map(p => `${p.x},${p.y},${p.isBig}`));
    const toRemove = all.filter(p => !keep.has(`${p.x},${p.y},${p.isBig}`));
    if (toRemove.length === 0) return;

    // Stagger: closest enemies disappear first (0ms), farthest-removed last (200ms)
    const maxD = Math.max(...toRemove.map(dist));
    const minD = Math.min(...toRemove.map(dist));
    const range = Math.max(1, maxD - minD);
    const now = performance.now();

    for (const p of toRemove) {
      const delay = ((dist(p) - minD) / range) * 200; // close=0ms, far=200ms
      dyingEnemies.push({ x: p.x, y: p.y, isBig: p.isBig, startTime: now + delay });
    }

    enemies = enemies.filter(e => keep.has(`${e.x},${e.y},false`));
    bigEnemies = bigEnemies.filter(e => keep.has(`${e.x},${e.y},true`));

    startDyingLoop();
  }

  function getDepthForScore(s: number): number {
    if (s >= 200) return 3;
    if (s >= 100) return 2;
    return 1;
  }

  function checkDepthTransition() {
    const newDepth = getDepthForScore(score);
    if (newDepth <= currentDepth) return;
    levelTimes.push(performance.now() - levelStartTime);
    levelStartTime = performance.now();
    currentDepth = newDepth;
    updateHudDepth(currentDepth);

    const flash = document.getElementById("depthFlash")!;
    flash.textContent = `DEPTH ${currentDepth}`;
    flash.classList.remove("flashing");
    void (flash as HTMLElement).offsetWidth;
    flash.classList.add("flashing");

    const wrapper = document.getElementById("gameDepthWrapper")!;
    wrapper.className = `game-depth-wrapper depth-${currentDepth}`;

    updateMaxDepth(currentDepth);
    clearCloseEnemies();
    if (currentDepth === 2) {
      // Clear depth-1 ammonite shells — they don't appear below the reef
      for (let r = 0; r < GRID; r++) superPickups[r].fill(false);
      spawnCoral();
      // Seed a handful of coral shell pickups as an immediate reward
      let placed = 0, attempts = 0;
      while (placed < CORAL_PICKUP_INIT && attempts < 800) {
        attempts++;
        const cpx = Math.floor(Math.random() * GRID);
        const cpy = Math.floor(Math.random() * GRID);
        if (
          !coralPickups[cpy][cpx] && !pickups[cpy][cpx] &&
          !superPickups[cpy][cpx] && !coral[cpy][cpx] &&
          !(cpx === shark.x && cpy === shark.y)
        ) {
          coralPickups[cpy][cpx] = true;
          placed++;
        }
      }
    }
    if (currentDepth === 3) spawnLeviathan();
  }

  // ===== SpawnManager =====  →  SpawnManager.swift

  function spawnEnemy(): Enemy {
    let ex: number, ey: number;
    let attempts = 0;
    do {
      ex = Math.floor(Math.random() * GRID);
      ey = Math.floor(Math.random() * GRID);
      attempts++;
      if (attempts > 1000) break;
    } while (
      Math.abs(ex - shark.x) + Math.abs(ey - shark.y) < MIN_ENEMY_DIST ||
      enemies.some((e) => e.x === ex && e.y === ey) ||
      coral[ey]?.[ex]
    );
    return { x: ex, y: ey };
  }

  function spawnBigEnemy(): BigEnemy {
    let ex: number, ey: number;
    let attempts = 0;
    do {
      ex = Math.floor(Math.random() * (GRID - 1));
      ey = Math.floor(Math.random() * (GRID - 1));
      attempts++;
      if (attempts > 1000) break;
    } while (
      Math.min(
        Math.abs(ex - shark.x) + Math.abs(ey - shark.y),
        Math.abs(ex + 1 - shark.x) + Math.abs(ey - shark.y),
        Math.abs(ex - shark.x) + Math.abs(ey + 1 - shark.y),
        Math.abs(ex + 1 - shark.x) + Math.abs(ey + 1 - shark.y),
      ) < MIN_ENEMY_DIST ||
      bigEnemies.some((b) => bigEnemyOverlaps(ex, ey, b.x, b.y)) ||
      coral[ey]?.[ex] ||
      coral[ey]?.[ex + 1] ||
      coral[ey + 1]?.[ex] ||
      coral[ey + 1]?.[ex + 1]
    );
    return { x: ex, y: ey };
  }

  function spawnCoral() {
    // N ≈ 2% of grid cells
    const N = Math.max(5, Math.floor(GRID * GRID * 0.02));
    let placed = 0,
      attempts = 0;
    while (placed < N && attempts < 2000) {
      attempts++;
      const cx = Math.floor(Math.random() * GRID);
      const cy = Math.floor(Math.random() * GRID);
      if (coral[cy][cx]) continue;
      if (cx === shark.x && cy === shark.y) continue;
      if (Math.abs(cx - shark.x) + Math.abs(cy - shark.y) < 4) continue;
      if (enemies.some((e) => e.x === cx && e.y === cy)) continue;
      if (
        bigEnemies.some(
          (be) => cx >= be.x && cx <= be.x + 1 && cy >= be.y && cy <= be.y + 1,
        )
      )
        continue;
      if (pickups[cy][cx] || superPickups[cy][cx]) continue;
      coral[cy][cx] = true;
      placed++;
    }
  }

  function spawnLeviathan() {
    if (leviathan) return; // max one at a time
    let lx: number, ly: number;
    let attempts = 0;
    do {
      lx = Math.floor(Math.random() * (GRID - 2));
      ly = Math.floor(Math.random() * (GRID - 2));
      attempts++;
      if (attempts > 1000) break;
    } while (
      Math.min(
        Math.abs(lx - shark.x) + Math.abs(ly - shark.y),
        Math.abs(lx + 2 - shark.x) + Math.abs(ly - shark.y),
        Math.abs(lx - shark.x) + Math.abs(ly + 2 - shark.y),
        Math.abs(lx + 2 - shark.x) + Math.abs(ly + 2 - shark.y),
      ) < 7 ||
      [0, 1, 2].some((dx) => [0, 1, 2].some((dy) => coral[ly + dy]?.[lx + dx]))
    );
    leviathan = { x: lx, y: ly };
  }

  // ===== CollisionDetector =====  →  CollisionDetector.swift

  function bigEnemyOverlaps(
    ax: number,
    ay: number,
    bx: number,
    by: number,
  ): boolean {
    return ax < bx + 2 && ax + 2 > bx && ay < by + 2 && ay + 2 > by;
  }

  function leviathanCollision(): boolean {
    if (!leviathan) return false;
    return (
      shark.x >= leviathan.x &&
      shark.x <= leviathan.x + 2 &&
      shark.y >= leviathan.y &&
      shark.y <= leviathan.y + 2
    );
  }

  // ===== EnemyAI =====  →  EnemyAI.swift

  function moveEnemiesAI() {
    // Regular enemies: Manhattan-first, avoid coral and each other
    for (const e of enemies) {
      const diffX = shark.x - e.x;
      const diffY = shark.y - e.y;
      let tx = e.x,
        ty = e.y;
      if (Math.abs(diffX) >= Math.abs(diffY)) {
        tx += Math.sign(diffX);
      } else {
        ty += Math.sign(diffY);
      }
      // Clamp to grid
      tx = Math.max(0, Math.min(GRID - 1, tx));
      ty = Math.max(0, Math.min(GRID - 1, ty));
      const occupied = enemies.some((o) => o !== e && o.x === tx && o.y === ty);
      const blockedByCoral = !!coral[ty]?.[tx];
      if (!occupied && !blockedByCoral) {
        e.x = tx;
        e.y = ty;
      }
    }

    // Big enemies: same AI, clamped to GRID-2 (2×2 block)
    for (const be of bigEnemies) {
      const diffX = shark.x - be.x;
      const diffY = shark.y - be.y;
      let tx = be.x,
        ty = be.y;
      if (Math.abs(diffX) >= Math.abs(diffY)) {
        tx += Math.sign(diffX);
      } else {
        ty += Math.sign(diffY);
      }
      tx = Math.max(0, Math.min(GRID - 2, tx));
      ty = Math.max(0, Math.min(GRID - 2, ty));
      const blocked = bigEnemies.some(
        (o) => o !== be && bigEnemyOverlaps(tx, ty, o.x, o.y),
      );
      const hitsCoral =
        coral[ty]?.[tx] ||
        coral[ty]?.[tx + 1] ||
        coral[ty + 1]?.[tx] ||
        coral[ty + 1]?.[tx + 1];
      if (!blocked && !hitsCoral) {
        be.x = tx;
        be.y = ty;
      }
    }
  }

  function moveLeviathanAI() {
    if (!leviathan) return;
    const diffX = shark.x - leviathan.x;
    const diffY = shark.y - leviathan.y;
    let tx = leviathan.x,
      ty = leviathan.y;
    if (Math.abs(diffX) >= Math.abs(diffY)) {
      tx += Math.sign(diffX);
    } else {
      ty += Math.sign(diffY);
    }
    tx = Math.max(0, Math.min(GRID - 3, tx));
    ty = Math.max(0, Math.min(GRID - 3, ty));
    const hitsCoral = [0, 1, 2].some((dx) =>
      [0, 1, 2].some((dy) => coral[ty + dy]?.[tx + dx]),
    );
    if (!hitsCoral) {
      leviathan.x = tx;
      leviathan.y = ty;
    }
  }

  // ===== GameEngine =====  →  GameEngine.swift

  function init() {
    score = 0;
    moveCount = 0;
    gameOver = false;
    currentDepth = 1;
    gameStartTime = performance.now();
    levelStartTime = performance.now();
    levelTimes = [];
    totalTimeMs = 0;

    hudScore.textContent = "0";
    updateHudDepth(1);
    gameOverOverlay.classList.remove("visible");

    const wrapper = document.getElementById("gameDepthWrapper")!;
    wrapper.className = "game-depth-wrapper depth-1";

    // GridState — tile colors
    colors = Array.from({ length: GRID }, () =>
      Array.from({ length: GRID }, () => randomTileColor()),
    );

    // GridState — pickups (5% density on init)
    pickups = Array.from({ length: GRID }, () =>
      Array.from({ length: GRID }, () => Math.random() < PICKUP_INIT),
    );

    // GridState — super pickups (1/40 of pickups)
    superPickups = Array.from({ length: GRID }, (_, r) =>
      Array.from({ length: GRID }, (_, c) => {
        if (pickups[r][c] && Math.random() < SUPER_INIT) {
          pickups[r][c] = false;
          return true;
        }
        return false;
      }),
    );

    // GridState — coral pickups (cleared; spawned at Depth 2)
    coralPickups = Array.from({ length: GRID }, () => Array(GRID).fill(false));

    // GridState — coral barriers (cleared; spawned at Depth 2)
    coral = Array.from({ length: GRID }, () => Array(GRID).fill(false));

    // EnemyAI state — cleared
    bigEnemies = [];
    leviathan = null;

    // Place shark at random position, not on a pickup
    shark.x = Math.floor(Math.random() * GRID);
    shark.y = Math.floor(Math.random() * GRID);
    pickups[shark.y][shark.x] = false;
    superPickups[shark.y][shark.x] = false;

    // Snap visual position
    sharkVisualX = shark.x;
    sharkVisualY = shark.y;

    // Load high score from UserDefaultsService
    highScore = getHighScore();
    hudBest.textContent = String(highScore);

    // Reset dying enemies
    dyingEnemies = [];
    if (dyingRafId) { cancelAnimationFrame(dyingRafId); dyingRafId = null; }

    // Reset shimmer state and start loop
    shimmerIntensity.fill(0);
    shimmerSpeed.fill(0);
    if (shimmerRafId) cancelAnimationFrame(shimmerRafId);
    if (shimmerMode) shimmerRafId = requestAnimationFrame(tickShimmer);

    // SpawnManager — one initial enemy
    enemies = [spawnEnemy()];

    draw();
  }

  function moveShark(dx: number, dy: number) {
    if (gameOver) return;

    const nx = shark.x + dx;
    const ny = shark.y + dy;

    // CollisionDetector — bounds check
    if (nx < 0 || nx >= GRID || ny < 0 || ny >= GRID) return;

    // CollisionDetector — coral check (Depth 2)
    if (coral[ny][nx]) return;

    // CollisionDetector — coral shell: running into it hardens it into a barrier
    if (coralPickups[ny][nx]) {
      // Face the shell before bouncing
      if (dx === 1) sharkDir = "right";
      else if (dx === -1) sharkDir = "left";
      else if (dy === 1) sharkDir = "down";
      else if (dy === -1) sharkDir = "up";
      // Convert to coral barrier + award 5 points + spawn enemy
      coralPickups[ny][nx] = false;
      coral[ny][nx] = true;
      score += 5;
      hudScore.textContent = String(score);
      enemies.push(spawnEnemy());
      checkDepthTransition();
      // Nudge toward it then rebound — shark stays at current position
      startBounceAnim(nx, ny);
      saveGame();
      return;
    }

    shark.x = nx;
    shark.y = ny;
    moveCount++;

    // Track facing direction  →  SharkNode.swift rotation
    if (dx === 1) sharkDir = "right";
    else if (dx === -1) sharkDir = "left";
    else if (dy === 1) sharkDir = "down";
    else if (dy === -1) sharkDir = "up";

    // Check pickup (1 point + spawn enemy)
    if (pickups[ny][nx]) {
      pickups[ny][nx] = false;
      score++;
      hudScore.textContent = String(score);
      enemies.push(spawnEnemy());
      checkDepthTransition();
    }

    // Check super pickup (10 points + spawn big enemy)
    if (superPickups[ny][nx]) {
      superPickups[ny][nx] = false;
      score += 10;
      hudScore.textContent = String(score);
      bigEnemies.push(spawnBigEnemy());
      checkDepthTransition();
    }

    // SpawnManager — random pickup growth
    for (let r = 0; r < GRID; r++) {
      for (let c = 0; c < GRID; c++) {
        if (
          !pickups[r][c] &&
          !superPickups[r][c] &&
          !coralPickups[r][c] &&
          !coral[r][c] &&
          Math.random() < PICKUP_RATE
        ) {
          // Ammonite shells only appear at depth 1
          if (currentDepth === 1 && Math.random() < SUPER_RATE_OF_PICKUP) {
            superPickups[r][c] = true;
          } else {
            pickups[r][c] = true;
          }
        }
        // Coral shell growth — depth 2+ only
        if (
          currentDepth >= 2 &&
          !coralPickups[r][c] &&
          !pickups[r][c] &&
          !superPickups[r][c] &&
          !coral[r][c] &&
          Math.random() < CORAL_PICKUP_RATE
        ) {
          coralPickups[r][c] = true;
        }
      }
    }

    // EnemyAI — regular + big enemies move every 2 player moves
    if (moveCount % 2 === 0) {
      moveEnemiesAI();
    }

    // EnemyAI — Leviathan moves every player move (Depth 3)
    moveLeviathanAI();

    // CollisionDetector — death checks
    for (const e of enemies) {
      if (e.x === shark.x && e.y === shark.y) {
        endGame();
        return;
      }
    }
    for (const be of bigEnemies) {
      if (
        shark.x >= be.x &&
        shark.x <= be.x + 1 &&
        shark.y >= be.y &&
        shark.y <= be.y + 1
      ) {
        endGame();
        return;
      }
    }
    if (leviathanCollision()) {
      endGame();
      return;
    }

    saveGame();
    startSharkAnim();
  }

  function endGame() {
    gameOver = true;
    totalTimeMs = performance.now() - gameStartTime;
    levelTimes.push(performance.now() - levelStartTime);
    clearSave(); // player died — no restore
    sharkVisualX = shark.x;
    sharkVisualY = shark.y;
    draw();

    // UserDefaultsService — persist high score
    if (score > highScore) {
      highScore = score;
      saveHighScore(highScore);
      hudBest.textContent = String(highScore);
    }

    // UserDefaultsService — persist best Shark Score
    const sharkScore = calcSharkScore(score, totalTimeMs);
    if (sharkScore > getSharkBest()) {
      saveSharkBest(sharkScore);
    }

    finalScoreEl.textContent = String(score);
    submitPrompt.style.display = score > 0 ? "block" : "none";
    nameInputRow.classList.remove("visible");
    submitScoreBtn.disabled = false;
    submitStatus.textContent = "";
    playerNameInput.value = localStorage.getItem("sharkPlayerName") || "";
    gameOverOverlay.classList.add("visible");
  }

  // ===== Renderer =====  →  GameScene.swift

  // Ocean tile palette — shallow sunlit reef, cyan-turquoise, clearly lighter than deep
  const TILE_COLORS = [
    "#1d7e92",
    "#228898",
    "#1a7888",
    "#268498",
    "#1e8090",
    "#248898",
    "#1c7682",
    "#247c8e",
    "#1e7e8e",
    "#207a8c",
  ];

  function randomTileColor(): string {
    return TILE_COLORS[Math.floor(Math.random() * TILE_COLORS.length)];
  }

  let colorblindMode = localStorage.getItem("sharkColorblind") === "true";
  let shimmerMode = localStorage.getItem("sharkShimmer") === "true";

  // Per-cell shimmer state — intensity 0→1→0, speed drives direction
  const shimmerIntensity = new Float32Array(GRID * GRID);
  const shimmerSpeed = new Float32Array(GRID * GRID);
  let shimmerRafId: number | null = null;

  function tickShimmer() {
    if (!shimmerMode || gameOver) { shimmerRafId = null; return; }
    let dirty = false;
    for (let i = 0; i < shimmerIntensity.length; i++) {
      if (shimmerSpeed[i] !== 0) {
        shimmerIntensity[i] = Math.max(0, Math.min(1, shimmerIntensity[i] + shimmerSpeed[i]));
        if (shimmerIntensity[i] >= 1)       shimmerSpeed[i] = -0.04; // peak → fade
        else if (shimmerIntensity[i] <= 0)  shimmerSpeed[i] = 0;     // done
        dirty = true;
      } else if (Math.random() < 0.0018) {
        shimmerSpeed[i] = 0.032 + Math.random() * 0.02; // random rise speed
        dirty = true;
      }
    }
    if (dirty) draw();
    shimmerRafId = requestAnimationFrame(tickShimmer);
  }

  function draw() {
    const canvas = document.getElementById("gameCanvas") as HTMLCanvasElement;
    const ctx = canvas.getContext("2d")!;

    if (colorblindMode) {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.strokeStyle = "#48cae4";
      ctx.lineWidth = 1;
      ctx.beginPath();
      for (let i = 0; i <= GRID; i++) {
        const pos =
          i === GRID ? canvas.width - 0.5 : Math.round(i * CELL) + 0.5;
        ctx.moveTo(pos, 0);
        ctx.lineTo(pos, canvas.height);
        ctx.moveTo(0, pos);
        ctx.lineTo(canvas.width, pos);
      }
      ctx.stroke();
    } else {
      // Background — ocean floor between tiles
      ctx.fillStyle = "#0f5262";
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      // Grid tiles
      for (let r = 0; r < GRID; r++) {
        for (let c = 0; c < GRID; c++) {
          ctx.fillStyle = colors[r][c];
          ctx.fillRect(c * CELL, r * CELL, CELL, CELL);
        }
      }

      // Water shimmer overlay — caustic light flickers
      if (shimmerMode) {
        ctx.fillStyle = "#d8f4fc";
        for (let r = 0; r < GRID; r++) {
          for (let c = 0; c < GRID; c++) {
            const v = shimmerIntensity[r * GRID + c];
            if (v > 0.02) {
              ctx.globalAlpha = v * 0.18;
              ctx.fillRect(c * CELL, r * CELL, CELL, CELL);
            }
          }
        }
        ctx.globalAlpha = 1;
      }
    }

    // Coral barriers (Depth 2) — warm coral/terracotta
    for (let r = 0; r < GRID; r++) {
      for (let c = 0; c < GRID; c++) {
        if (!coral[r][c]) continue;
        const cx = c * CELL,
          cy = r * CELL;
        ctx.fillStyle = "#7a4a30";
        ctx.fillRect(cx, cy, CELL, CELL);
        ctx.fillStyle = "#c8906a";
        ctx.fillRect(cx + 1, cy + 1, CELL - 2, CELL - 2);
        // Pixel highlight corners
        if (CELL >= 8) {
          ctx.fillStyle = "#e0b898";
          const dot = Math.max(2, Math.floor(CELL * 0.15));
          ctx.fillRect(cx + 2, cy + 2, dot, dot);
          ctx.fillRect(cx + CELL - dot - 2, cy + 2, dot, dot);
        }
      }
    }

    // Pickups — gold squares
    const pad = CELL * 0.2;
    for (let r = 0; r < GRID; r++) {
      for (let c = 0; c < GRID; c++) {
        if (!pickups[r][c]) continue;
        const px = c * CELL + pad,
          py = r * CELL + pad,
          ps = CELL - pad * 2;
        ctx.fillStyle = "#7a5500";
        ctx.fillRect(px - 1, py - 1, ps + 2, ps + 2);
        ctx.fillStyle = "#ffd166";
        ctx.fillRect(px, py, ps, ps);
      }
    }

    // Super pickups — Ecco-style ammonite shell (10 pts)
    for (let r = 0; r < GRID; r++) {
      for (let c = 0; c < GRID; c++) {
        if (!superPickups[r][c]) continue;
        const px = c * CELL + pad,
          py = r * CELL + pad,
          ps = CELL - pad * 2;
        drawShellPickup(ctx, px, py, ps);
      }
    }

    // Coral shell pickups — depth-2+ cone shell (5 pts)
    if (currentDepth >= 2) {
      for (let r = 0; r < GRID; r++) {
        for (let c = 0; c < GRID; c++) {
          if (!coralPickups[r][c]) continue;
          const cpx = c * CELL + pad,
            cpy = r * CELL + pad,
            cps = CELL - pad * 2;
          drawCoralShell(ctx, cpx, cpy, cps);
        }
      }
    }

    // Dying enemies — sink + fade (depth transition dissolve)
    if (dyingEnemies.length > 0) {
      const now = performance.now();
      for (const de of dyingEnemies) {
        const elapsed = now - de.startTime;
        if (elapsed < 0) continue; // stagger delay not yet reached
        const t = Math.min(1, elapsed / DYING_DURATION);
        const ease = 1 - t * t; // ease-out fade
        const drift = t * CELL * 0.22; // sink into the reef floor
        const inset = t * CELL * 0.3; // shrink inward
        ctx.save();
        ctx.globalAlpha = ease;
        if (de.isBig) {
          const bx = de.x * CELL + inset, by = de.y * CELL + inset + drift;
          const bw = Math.max(0, CELL * 2 - inset * 2);
          ctx.fillStyle = "#120a1e";
          ctx.fillRect(bx - 1, by - 1, bw + 2, bw + 2);
          ctx.fillStyle = "#2d1a4a";
          ctx.fillRect(bx, by, bw, bw);
        } else {
          const ex = de.x * CELL + inset, ey = de.y * CELL + inset + drift;
          const ew = Math.max(0, CELL - inset * 2);
          ctx.fillStyle = "#0a1824";
          ctx.fillRect(ex - 1, ey - 1, ew + 2, ew + 2);
          ctx.fillStyle = "#162d40";
          ctx.fillRect(ex, ey, ew, ew);
        }
        ctx.restore();
      }
    }

    // Regular enemies — 1×1 shadow-creature squares (dark navy silhouette)
    for (const e of enemies) {
      ctx.fillStyle = "#0a1824";
      ctx.fillRect(e.x * CELL - 1, e.y * CELL - 1, CELL + 2, CELL + 2);
      ctx.fillStyle = "#162d40";
      ctx.fillRect(e.x * CELL, e.y * CELL, CELL, CELL);
    }

    // Big enemies — 2×2 deep purple squares (understated, distinct from regular navy)
    for (const be of bigEnemies) {
      const bx = be.x * CELL,
        by = be.y * CELL,
        bw = CELL * 2;
      ctx.fillStyle = "#120a1e";
      ctx.fillRect(bx - 1, by - 1, bw + 2, bw + 2);
      ctx.fillStyle = "#2d1a4a";
      ctx.fillRect(bx, by, bw, bw);
    }

    // Leviathan — 3×3 glowing mega enemy (Depth 3)
    if (leviathan) {
      const lx = leviathan.x * CELL,
        ly = leviathan.y * CELL,
        lw = CELL * 3;
      const canvas2d = document.getElementById(
        "gameCanvas",
      ) as HTMLCanvasElement;
      const ctx2 = canvas2d.getContext("2d")!;
      ctx2.shadowColor = "#0d3550";
      ctx2.shadowBlur = 18;
      ctx2.fillStyle = "#070f18";
      ctx2.fillRect(lx - 2, ly - 2, lw + 4, lw + 4);
      ctx2.fillStyle = "#0f2035";
      ctx2.fillRect(lx, ly, lw, lw);
      ctx2.fillStyle = "#162840";
      ctx2.fillRect(lx + 3, ly + 3, lw - 6, lw - 6);
      ctx2.shadowBlur = 0;
    }

    // ===== SharkRenderer =====  →  SharkNode.swift
    drawSharkOnCtx(ctx, sharkVisualX, sharkVisualY, CELL, sharkDir);
  }

  // ===== ShellRenderer =====  →  moon-snail / ammonite shell, purple, round
  function drawShellPickup(
    ctx: CanvasRenderingContext2D,
    px: number,
    py: number,
    ps: number,
  ) {
    // Round shell — arcs give a natural circular silhouette, no boxy edges.
    // Offset inner whorls create the nautilus/moon-snail spiral cross-section.
    ctx.save();
    const cx = px + ps / 2;
    const cy = py + ps / 2;
    const r = (ps - 1) / 2;

    // Outer dark ring
    ctx.fillStyle = "#180530";
    ctx.beginPath();
    ctx.arc(cx, cy, r, 0, Math.PI * 2);
    ctx.fill();

    // Shell body — vivid mid-purple
    ctx.fillStyle = "#6a28b0";
    ctx.beginPath();
    ctx.arc(cx, cy, r * 0.86, 0, Math.PI * 2);
    ctx.fill();

    // Inner whorl — lighter purple, shifted upper-left (spiral offset)
    const wx = cx - r * 0.18;
    const wy = cy - r * 0.18;
    ctx.fillStyle = "#9848d8";
    ctx.beginPath();
    ctx.arc(wx, wy, r * 0.52, 0, Math.PI * 2);
    ctx.fill();

    // Deep whorl — dark purple
    ctx.fillStyle = "#4a1888";
    ctx.beginPath();
    ctx.arc(wx - r * 0.1, wy - r * 0.1, r * 0.3, 0, Math.PI * 2);
    ctx.fill();

    // Center eye — lavender
    ctx.fillStyle = "#c088e8";
    ctx.beginPath();
    ctx.arc(wx - r * 0.14, wy - r * 0.14, r * 0.14, 0, Math.PI * 2);
    ctx.fill();

    // Catch-light on upper-right face
    ctx.fillStyle = "#d8b0f8";
    ctx.beginPath();
    ctx.arc(cx + r * 0.3, cy - r * 0.35, r * 0.14, 0, Math.PI * 2);
    ctx.fill();

    // White specular gleam
    ctx.fillStyle = "#ffffff";
    ctx.beginPath();
    ctx.arc(cx + r * 0.35, cy - r * 0.38, r * 0.07, 0, Math.PI * 2);
    ctx.fill();

    ctx.restore();
  }

  // ===== CoralShellRenderer =====  →  Depth 2 cone shell pickup
  // Silhouette: apex-up pyramid, unmistakably different from the round depth-1 ammonite.
  // Stacked fillRect rows widen from tip (top) to base (bottom) — reads as a cone at ≥16px.
  function drawCoralShell(
    ctx: CanvasRenderingContext2D,
    px: number,
    py: number,
    ps: number,
  ) {
    ctx.save();
    const cx = px + ps / 2;
    const ROWS = 8;

    // Pass 1: dark outline — 1px wider on each side per row
    ctx.fillStyle = "#4a2010";
    for (let i = 0; i < ROWS; i++) {
      const ry = Math.round(py + (i * ps) / ROWS);
      const rh = Math.max(1, Math.round(ps / ROWS + 0.5));
      const wFrac = (i + 1) / ROWS; // row 0 = 12.5%, row 7 = 100%
      const rw = Math.round(ps * wFrac);
      const rx = Math.round(cx - rw / 2);
      ctx.fillRect(rx - 1, ry, rw + 2, rh + 1);
    }

    // Pass 2: body, banding stripes, left-side highlight
    for (let i = 0; i < ROWS; i++) {
      const ry = Math.round(py + (i * ps) / ROWS);
      const rh = Math.max(1, Math.round(ps / ROWS));
      const wFrac = (i + 1) / ROWS;
      const rw = Math.round(ps * wFrac);
      const rx = Math.round(cx - rw / 2);

      // Characteristic cone-shell banding at rows 2 and 5
      const isStripe = i === 2 || i === 5;
      ctx.fillStyle = isStripe ? "#7a4a30" : "#c8906a";
      ctx.fillRect(rx, ry, rw, rh);

      // Left-edge highlight (top-left light source)
      if (!isStripe && rw >= 3) {
        ctx.fillStyle = "#e0b898";
        ctx.fillRect(rx, ry, Math.max(1, Math.round(rw * 0.22)), rh);
      }
    }

    // Apex gleam — tiny specular dot at tip
    ctx.fillStyle = "#f0c8a0";
    const tipRh = Math.max(1, Math.round(ps / ROWS * 0.5));
    const tipRw = Math.max(1, Math.round(ps * 0.06));
    ctx.fillRect(
      Math.round(cx - tipRw / 2) + Math.round(tipRw * 0.3),
      Math.round(py + 1),
      tipRw,
      tipRh,
    );

    ctx.restore();
  }

  function drawSharkOnCtx(
    ctx: CanvasRenderingContext2D,
    cx: number,
    cy: number,
    cellSize: number,
    dir: string,
    tailWag: number = 0, // -1 to 1: drives tail fin counter-oscillation
  ) {
    const x = cx * cellSize;
    const y = cy * cellSize;
    const w = cellSize;
    const h = cellSize;

    ctx.save();

    // Direction transform — shark faces RIGHT by default
    const midX = x + w / 2;
    const midY = y + h / 2;
    ctx.translate(midX, midY);
    if (dir === "left") ctx.scale(-1, 1);
    else if (dir === "down") ctx.rotate(Math.PI / 2);
    else if (dir === "up") ctx.rotate(-Math.PI / 2);
    ctx.translate(-midX, -midY);

    // Pixel-snapped rect helper — min 1px so tiny cells still render
    const R = (fx: number, fy: number, fw: number, fh: number) =>
      ctx.fillRect(
        Math.round(x + fx * w),
        Math.round(y + fy * h),
        Math.max(1, Math.round(fw * w)),
        Math.max(1, Math.round(fh * h)),
      );

    // 5-color pixel art palette — natural shark counter-shading
    // Light grey-blue body + white belly pops against the teal ocean tiles
    const OUTLINE = "#0a1e28";
    const BODY = "#7aaab8"; // cool shark grey — clearly lighter than tiles
    const DARK_FIN = "#4a7a8a"; // darker grey-teal for fins and shadow
    const HIGHLIGHT = "#c0dae2"; // pale blue-white top highlight
    const BELLY = "#f0f8fa"; // near-white underbelly

    // 1. Outline pass (dark slab drawn slightly larger)
    ctx.fillStyle = OUTLINE;
    R(0.06, 0.27, 0.82, 0.46); // body slab
    R(0.0, 0.12 - tailWag * 0.07, 0.14, 0.22); // tail top lobe outline
    R(0.0, 0.62 + tailWag * 0.07, 0.14, 0.22); // tail bottom lobe outline
    // Dorsal fin outline (triangle)
    ctx.beginPath();
    ctx.moveTo(Math.round(x + 0.34 * w), Math.round(y + 0.27 * h));
    ctx.lineTo(Math.round(x + 0.5 * w), Math.round(y + 0.01 * h));
    ctx.lineTo(Math.round(x + 0.67 * w), Math.round(y + 0.27 * h));
    ctx.closePath();
    ctx.fill();

    // 2. Body
    ctx.fillStyle = BODY;
    R(0.08, 0.29, 0.78, 0.42);

    // 3. Dorsal fin
    ctx.fillStyle = DARK_FIN;
    ctx.beginPath();
    ctx.moveTo(Math.round(x + 0.36 * w), Math.round(y + 0.29 * h));
    ctx.lineTo(Math.round(x + 0.5 * w), Math.round(y + 0.05 * h));
    ctx.lineTo(Math.round(x + 0.65 * w), Math.round(y + 0.29 * h));
    ctx.closePath();
    ctx.fill();

    // 4. Tail fins — lobes counter-oscillate when tailWag != 0
    ctx.fillStyle = DARK_FIN;
    R(0.01, 0.14 - tailWag * 0.07, 0.11, 0.16); // top lobe
    R(0.01, 0.64 + tailWag * 0.07, 0.11, 0.16); // bottom lobe

    // 5. Top highlight strip
    ctx.fillStyle = HIGHLIGHT;
    R(0.14, 0.29, 0.36, 0.09);

    // 6. Belly
    ctx.fillStyle = BELLY;
    R(0.18, 0.52, 0.5, 0.14);

    // 7. Pectoral fin hint
    ctx.fillStyle = DARK_FIN;
    R(0.36, 0.62, 0.2, 0.09);

    // 8. Eye
    ctx.fillStyle = "#d8eef4"; // light eye
    R(0.69, 0.33, 0.1, 0.14);
    ctx.fillStyle = "#08181f"; // dark pupil
    R(0.71, 0.35, 0.06, 0.09);
    ctx.fillStyle = "#ffffff";
    R(0.7, 0.34, 0.02, 0.03); // glint

    // 9. Mouth notch
    ctx.fillStyle = OUTLINE;
    R(0.84, 0.56, 0.08, 0.08);

    ctx.restore();
  }

  // Smooth animation  →  SKAction in GameScene.swift
  function startSharkAnim() {
    sharkFromX = sharkVisualX;
    sharkFromY = sharkVisualY;
    animStartTime = performance.now();
    if (animRafId) cancelAnimationFrame(animRafId);
    animRafId = requestAnimationFrame(tickAnim);
  }

  function tickAnim(now: number) {
    const t = Math.min(1, (now - animStartTime) / ANIM_DURATION);
    const ease = 1 - (1 - t) * (1 - t);
    sharkVisualX = sharkFromX + (shark.x - sharkFromX) * ease;
    sharkVisualY = sharkFromY + (shark.y - sharkFromY) * ease;
    draw();
    if (t < 1) {
      animRafId = requestAnimationFrame(tickAnim);
    } else {
      animRafId = null;
    }
  }

  // Bounce animation — shark nudges toward a blocked cell then rebounds
  // Used when running into a coral shell (which then hardens into a barrier).
  function startBounceAnim(targetX: number, targetY: number) {
    bounceTargetX = targetX;
    bounceTargetY = targetY;
    sharkFromX = sharkVisualX = shark.x;
    sharkFromY = sharkVisualY = shark.y;
    animStartTime = performance.now();
    if (animRafId) cancelAnimationFrame(animRafId);
    animRafId = requestAnimationFrame(tickBounceAnim);
  }

  function tickBounceAnim(now: number) {
    const BOUNCE_DURATION = 180; // ms — short, subtle
    const t = Math.min(1, (now - animStartTime) / BOUNCE_DURATION);
    // sin(t·π): 0 → peak → 0, scaled to 40% of cell width
    const push = Math.sin(t * Math.PI) * 0.40;
    sharkVisualX = sharkFromX + (bounceTargetX - sharkFromX) * push;
    sharkVisualY = sharkFromY + (bounceTargetY - sharkFromY) * push;
    draw();
    if (t < 1) {
      animRafId = requestAnimationFrame(tickBounceAnim);
    } else {
      sharkVisualX = sharkFromX;
      sharkVisualY = sharkFromY;
      animRafId = null;
    }
  }

  // ===== ScreenManager =====  →  RootNavigationView.swift

  type ScreenId = "splash" | "main-menu" | "game" | "leaderboard" | "settings";

  function showScreen(id: ScreenId) {
    document
      .querySelectorAll(".screen")
      .forEach((s) => s.classList.remove("active"));
    const target = document.getElementById(`screen-${id}`);
    if (target) target.classList.add("active");
    if (id === "main-menu") refreshMenuState();
  }

  // ===== DPad =====  →  DPadView.swift

  function execDir(dir: string) {
    switch (dir) {
      case "up":
        moveShark(0, -1);
        break;
      case "down":
        moveShark(0, 1);
        break;
      case "left":
        moveShark(-1, 0);
        break;
      case "right":
        moveShark(1, 0);
        break;
    }
  }

  function vibrate(ms: number) {
    const enabled = localStorage.getItem("sharkHaptics") !== "false";
    if (enabled && navigator.vibrate) navigator.vibrate(ms);
  }

  document.querySelectorAll(".dpad-btn").forEach((btn) => {
    const el = btn as HTMLElement;
    let repeatTimer: ReturnType<typeof setInterval> | null = null;

    const press = () => el.classList.add("pressed");
    const release = () => {
      el.classList.remove("pressed");
      if (repeatTimer) {
        clearInterval(repeatTimer);
        repeatTimer = null;
      }
    };

    const startMove = (e: Event) => {
      e.preventDefault();
      press();
      const dir = el.dataset.dir!;
      vibrate(12);
      execDir(dir);
      repeatTimer = setTimeout(() => {
        repeatTimer = setInterval(() => {
          vibrate(8);
          execDir(dir);
        }, 100);
      }, 200) as unknown as ReturnType<typeof setInterval>;
    };

    btn.addEventListener("touchstart", startMove, { passive: false });
    btn.addEventListener("touchend", release);
    btn.addEventListener("touchcancel", release);
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      vibrate(12);
      execDir(el.dataset.dir!);
      press();
      setTimeout(release, 150);
    });
  });

  // ===== HUD =====  →  HUDView.swift

  const hudScore = document.getElementById("hudScore")!;
  const hudBest = document.getElementById("hudBest")!;
  const hudDepthBtn = document.getElementById("hudDepthBtn")!;
  const hudDepthLabel = document.getElementById("hudDepthLabel")!;

  const DEPTH_META: Record<number, { color: string; glow: string; name: string }> = {
    1: { color: "#48cae4", glow: "rgba(72,202,228,0.5)", name: "SURFACE REEF" },
    2: { color: "#daa070", glow: "rgba(218,160,112,0.5)", name: "REEF" },
    3: { color: "#9d6fe0", glow: "rgba(157,111,224,0.5)", name: "ABYSS" },
  };

  function updateHudDepth(depth: number) {
    hudDepthLabel.textContent = `DEPTH ${depth}`;
    hudDepthBtn.className = `hud-btn hud-depth-btn${depth > 1 ? ` depth-${depth}` : ""}`;
  }

  // ===== Services =====  →  UserDefaultsService.swift + GameCenterService.swift

  const HS_KEY = "sharkIosHighScore";
  const SAVE_KEY = "sharkIosSave";
  const MAX_DEPTH_KEY = "sharkMaxDepth";
  const SHARK_BEST_KEY = "sharkTotalBest";

  function getHighScore(): number {
    return parseInt(localStorage.getItem(HS_KEY) || "0", 10);
  }
  function saveHighScore(v: number) {
    localStorage.setItem(HS_KEY, String(v));
  }

  function getSharkBest(): number {
    return parseInt(localStorage.getItem(SHARK_BEST_KEY) || "0", 10);
  }
  function saveSharkBest(v: number) {
    localStorage.setItem(SHARK_BEST_KEY, String(v));
  }

  function calcSharkScore(s: number, totalMs: number): number {
    if (totalMs <= 0) return 0;
    const secs = totalMs / 1000;
    return Math.floor((s * s) / secs);
  }

  // ===== SaveManager =====  →  SaveManager.swift

  function getSave(): any | null {
    try {
      const raw = localStorage.getItem(SAVE_KEY);
      if (!raw) return null;
      return JSON.parse(raw);
    } catch {
      return null;
    }
  }

  function saveGame() {
    const save = {
      shark: { x: shark.x, y: shark.y },
      sharkDir,
      score,
      currentDepth,
      moveCount,
      pickups: pickups.flat(),
      superPickups: superPickups.flat(),
      coralPickups: coralPickups.flat(),
      coral: coral.flat(),
      colors: colors.flat(),
      enemies,
      bigEnemies,
      leviathan,
      runElapsedMs: performance.now() - gameStartTime,
      levelElapsedMs: performance.now() - levelStartTime,
      levelTimes,
    };
    localStorage.setItem(SAVE_KEY, JSON.stringify(save));
  }

  function clearSave() {
    localStorage.removeItem(SAVE_KEY);
  }

  function getMaxDepth(): number {
    return parseInt(localStorage.getItem(MAX_DEPTH_KEY) || "1", 10);
  }

  function updateMaxDepth(depth: number) {
    if (depth > getMaxDepth()) {
      localStorage.setItem(MAX_DEPTH_KEY, String(depth));
    }
  }

  function loadGame(save: any) {
    // Restore 2D arrays from flat
    pickups = [];
    superPickups = [];
    coralPickups = [];
    coral = [];
    colors = [];
    const emptyRow = () => Array(GRID).fill(false);
    for (let r = 0; r < GRID; r++) {
      pickups.push(Array.from(save.pickups.slice(r * GRID, (r + 1) * GRID)));
      superPickups.push(Array.from(save.superPickups.slice(r * GRID, (r + 1) * GRID)));
      coralPickups.push(Array.from((save.coralPickups || []).slice(r * GRID, (r + 1) * GRID).concat(emptyRow()).slice(0, GRID)));
      coral.push(Array.from(save.coral.slice(r * GRID, (r + 1) * GRID)));
      colors.push(Array.from(save.colors.slice(r * GRID, (r + 1) * GRID)));
    }

    shark = { ...save.shark };
    sharkDir = save.sharkDir || "right";
    sharkVisualX = shark.x;
    sharkVisualY = shark.y;
    score = save.score || 0;
    currentDepth = save.currentDepth || 1;
    moveCount = save.moveCount || 0;
    enemies = save.enemies || [];
    bigEnemies = save.bigEnemies || [];
    leviathan = save.leviathan || null;
    gameOver = false;

    // Restore timing so the live clock continues from saved elapsed time
    gameStartTime = performance.now() - (save.runElapsedMs || 0);
    levelStartTime = performance.now() - (save.levelElapsedMs || 0);
    levelTimes = save.levelTimes || [];
    totalTimeMs = 0;

    // Update HUD
    hudScore.textContent = String(score);
    highScore = getHighScore();
    hudBest.textContent = String(highScore);
    updateHudDepth(currentDepth);

    // Depth wrapper
    const wrapper = document.getElementById("gameDepthWrapper")!;
    wrapper.className = `game-depth-wrapper depth-${currentDepth}`;

    // Reset dying enemies
    dyingEnemies = [];
    if (dyingRafId) { cancelAnimationFrame(dyingRafId); dyingRafId = null; }

    // Reset shimmer
    shimmerIntensity.fill(0);
    shimmerSpeed.fill(0);
    if (shimmerRafId) cancelAnimationFrame(shimmerRafId);
    if (shimmerMode) shimmerRafId = requestAnimationFrame(tickShimmer);

    gameOverOverlay.classList.remove("visible");
    draw();
  }

  function initAtDepth(targetDepth: number) {
    const canvas = document.getElementById("gameCanvas") as HTMLCanvasElement;
    CELL = canvas.width / GRID;
    showScreen("game");
    init(); // resets everything to depth 1

    if (targetDepth >= 2) {
      currentDepth = 2;
      // Score stays 0 — high scores require playing through all levels
      updateHudDepth(2);
      const wrapper = document.getElementById("gameDepthWrapper")!;
      wrapper.className = "game-depth-wrapper depth-2";
      // No ammonite shells at depth 2+
      for (let r = 0; r < GRID; r++) superPickups[r].fill(false);
      spawnCoral();
      // Seed some coral shell pickups
      let placed = 0, attempts = 0;
      while (placed < CORAL_PICKUP_INIT && attempts < 800) {
        attempts++;
        const cpx = Math.floor(Math.random() * GRID);
        const cpy = Math.floor(Math.random() * GRID);
        if (!coralPickups[cpy][cpx] && !pickups[cpy][cpx] && !coral[cpy][cpx] && !(cpx === shark.x && cpy === shark.y)) {
          coralPickups[cpy][cpx] = true;
          placed++;
        }
      }
    }
    if (targetDepth >= 3) {
      currentDepth = 3;
      updateHudDepth(3);
      const wrapper = document.getElementById("gameDepthWrapper")!;
      wrapper.className = "game-depth-wrapper depth-3";
      spawnLeviathan();
    }

    draw();
    fetchLeaderboard();
  }


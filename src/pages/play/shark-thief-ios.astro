  let hudClockInterval: ReturnType<typeof setInterval> | null = null;

  function formatClockSec(totalSec: number): string {
    const min = Math.floor(totalSec / 60);
    const sec = totalSec % 60;
    return `${String(min).padStart(2, "0")}:${String(sec).padStart(2, "0")}`;
  }

  function startHudClock() {
    stopHudClock();
    hudClockInterval = setInterval(() => {
      if (gameOver) return;
      const nowMs = performance.now();
      hudTimeEl.textContent  = formatClockSec(Math.floor((nowMs - gameStartTime)  / 1000));
      hudLvTime.textContent  = formatClockSec(Math.floor((nowMs - levelStartTime) / 1000));
    }, 500);
  }

  function stopHudClock() {
    if (hudClockInterval) { clearInterval(hudClockInterval); hudClockInterval = null; }

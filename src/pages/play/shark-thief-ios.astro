---
import BaseLayout from "../../layouts/BaseLayout.astro";

export const blogData = {
  title: "Shark Thief iOS",
  author: "David Volz",
  description:
    "Web prototype for the Shark Thief iOS app — pixel-art ocean arcade game with depth levels.",
  pubDate: "2026-4-11",
  tags: ["javascript", "code", "game", "ios"],
  featured: true,
  display: true,
};

const showTypographyHero = false;
const fullWidthBody = true;
---

<style lang="scss">
  /* ── Design Tokens ── */
  .shark-ios-app {
    --ocean-abyss: #0a1f2e;
    --ocean-deep: #0d3545;
    --ocean-mid: #0f5262;
    --ocean-surface: #1d7e92;
    --cyan: #48cae4;
    --cyan-bright: #90e0ef;
    --gold: #ffd166;
    --coral-danger: #ef476f;
    --coral-block: #c8906a;
    --text-primary: #caf0f8;
    --text-muted: #7ac4d8;
    --border-glow: rgba(72, 202, 228, 0.2);
    --font-pixel: "Press Start 2P", cursive;
    --font-terminal: "VT323", monospace;
  }

  /* ── App Container ── */
  :global(main):has(.shark-ios-app) {
    padding-left: 0;
    padding-right: 0;
  }

  :global(html):has(.shark-ios-app),
  :global(body):has(.shark-ios-app) {
    touch-action: manipulation;
  }

  .shark-ios-app {
    width: 100%;
    touch-action: manipulation;
    background: var(--ocean-abyss);
    color: var(--text-primary);
    position: relative;
    min-height: calc(100dvh - 8rem);
  }

  /* ── Screens ── */
  .screen {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: calc(100dvh - 8rem);
    width: 100%;
    padding: 2rem 1.6rem;
    box-sizing: border-box;
    position: relative;

    &.active {
      display: flex;
    }
  }

  /* scanline overlay for menu screens */
  .screen-menu::after {
    content: "";
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.06) 2px,
      rgba(0, 0, 0, 0.06) 4px
    );
    pointer-events: none;
  }

  /* ── Typography ── */
  .pixel-title {
    font-family: var(--font-pixel);
    color: var(--cyan);
    text-align: center;
    line-height: 1.8;
    text-shadow:
      0 0 20px rgba(72, 202, 228, 0.6),
      0 0 40px rgba(72, 202, 228, 0.3);
    letter-spacing: 0.05em;
  }

  .terminal-text {
    font-family: var(--font-terminal);
    color: var(--text-primary);
    font-size: 2rem;
    line-height: 1.4;
  }

  /* ── Pixel Button ── */
  .pixel-btn {
    font-family: var(--font-pixel);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    padding: 1rem 2rem;
    border: 3px solid var(--cyan);
    border-radius: 2px;
    background: transparent;
    color: var(--cyan);
    cursor: pointer;
    text-transform: uppercase;
    transition:
      background 0.08s,
      box-shadow 0.08s,
      color 0.08s;
    min-height: 44px;
    touch-action: manipulation;

    &:hover {
      background: var(--cyan);
      color: var(--ocean-abyss);
      box-shadow: 0 0 14px rgba(72, 202, 228, 0.5);
    }
    &:active {
      transform: scale(0.95);
    }
  }

  .pixel-btn-muted {
    border-color: var(--text-muted);
    color: var(--text-muted);
    &:hover {
      background: var(--text-muted);
      color: var(--ocean-abyss);
    }
  }

  .pixel-btn-danger {
    border-color: var(--coral-danger);
    color: var(--coral-danger);
    &:hover {
      background: var(--coral-danger);
      color: #fff;
    }
  }

  /* ── Splash Screen ── */
  .splash-screen {
    background: var(--ocean-abyss);
    gap: 2rem;
  }

  .splash-canvas-wrap {
    position: relative;
    canvas {
      display: block;
    }
  }

  .splash-title {
    font-size: 1.4rem;
    margin: 0;
  }

  .splash-sub {
    font-family: var(--font-pixel);
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.15em;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  /* ── Main Menu ── */
  #menuSharkCanvas {
    display: block;
    margin-bottom: 1.6rem;
    image-rendering: pixelated;
  }

  .main-menu-title {
    font-size: 2rem;
    margin: 0 0 0.5rem;
  }

  .main-menu-sub {
    font-family: var(--font-terminal);
    font-size: 1.6rem;
    color: var(--text-muted);
    margin: 0 0 3rem;
  }

  .main-menu-buttons {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    width: 100%;
    max-width: 22rem;
  }

  .main-menu-buttons .pixel-btn {
    width: 100%;
    font-size: 1.05rem;
    padding: 1.2rem 2rem;
  }

  .main-menu-depth {
    font-family: var(--font-terminal);
    font-size: 1.6rem;
    color: var(--text-muted);
    margin-top: 2.5rem;
    letter-spacing: 0.1em;
  }

  /* ── Main Menu Save / Depth Buttons ── */
  .pixel-btn-continue {
    border-color: var(--cyan);
    color: var(--cyan);
    box-shadow: 0 0 14px rgba(72, 202, 228, 0.5), 0 0 28px rgba(72, 202, 228, 0.2);
    animation: continuePulse 2.4s ease-in-out infinite;
  }

  @keyframes continuePulse {
    0%, 100% { box-shadow: 0 0 10px rgba(72, 202, 228, 0.4), 0 0 24px rgba(72, 202, 228, 0.15); }
    50%       { box-shadow: 0 0 18px rgba(72, 202, 228, 0.75), 0 0 36px rgba(72, 202, 228, 0.35); }
  }

  .pixel-btn-continue:hover {
    background: var(--cyan);
    color: var(--ocean-abyss);
    animation: none;
  }

  .pixel-btn-abandon {
    border-color: #4a7a8a;
    color: #4a7a8a;
    font-size: 0.6rem;
    padding: 0.7rem 1.4rem;
    margin-top: 0.4rem;
  }

  .pixel-btn-abandon:hover {
    background: #4a7a8a;
    color: var(--ocean-abyss);
  }

  /* ── DIVE IN dropdown trigger ── */
  /* When it has unlocked depths, render as a proper dropdown toggle */
  .pixel-btn-dive-toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;

    &::after {
      content: "▼";
      font-size: 0.6em;
      opacity: 0.65;
      margin-left: 0.8em;
      transition: transform 0.18s ease, opacity 0.18s ease;
    }
    &.open::after {
      transform: rotate(180deg);
      opacity: 1;
    }
    &.open {
      background: var(--cyan);
      color: var(--ocean-abyss);
      transform: scale(0.95);
      box-shadow: 0 0 14px rgba(72, 202, 228, 0.5);
    }
  }

  /* ── Depth Sub-Button Toggle Panel ── */
  /* Negative margins cancel the parent flex gap when collapsed so LEADERBOARD
     doesn't drift away from DIVE IN. Margins animate with the panel. */
  .depth-sub-btns {
    display: flex;
    flex-direction: column;
    gap: 0;
    width: 100%;
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    /* collapsed: eat the gap above and below */
    margin-top: -0.6rem;
    margin-bottom: -0.6rem;
    transition:
      max-height 0.22s ease-out,
      opacity 0.18s ease-out,
      margin-top 0.22s ease-out,
      margin-bottom 0.22s ease-out;
    pointer-events: none;

    &.expanded {
      max-height: 20rem;
      opacity: 1;
      margin-top: 0;
      margin-bottom: 0;
      pointer-events: all;
    }
  }

  /* Depth sub-buttons are injected via JS innerHTML, so they don't carry
     Astro's scope hash. Use :global() inside the scoped .depth-sub-btns
     parent so the scope hash is still anchored to the component. */

  /* Base pixel-btn style for all injected sub-buttons */
  .depth-sub-btns :global(button) {
    font-family: var(--font-pixel);
    font-size: 1.05rem; /* match .main-menu-buttons .pixel-btn */
    letter-spacing: 0.06em;
    padding: 0.85rem 2rem; /* slightly tighter than main 1.2rem */
    border: 3px solid var(--cyan);
    border-radius: 2px;
    background: transparent;
    color: var(--cyan);
    cursor: pointer;
    text-transform: uppercase;
    min-height: 40px;
    touch-action: manipulation;
    width: 100%;
    transition: background 0.08s, box-shadow 0.08s, color 0.08s;

    &:hover {
      background: var(--cyan);
      color: var(--ocean-abyss);
      box-shadow: 0 0 14px rgba(72, 202, 228, 0.5);
    }
    &:active { transform: scale(0.95); }
  }

  /* Depth 2: lighter coral — derived from coral shell sprite highlight */
  .depth-sub-btns :global(.pixel-btn-d2) {
    border-color: #daa070;
    color: #daa070;

    &:hover {
      background: #daa070;
      color: var(--ocean-abyss);
      box-shadow: 0 0 14px rgba(218, 160, 112, 0.5);
    }
  }

  /* Depth 3: nursery pink */
  .depth-sub-btns :global(.pixel-btn-d3) {
    border-color: #e06fa0;
    color: #e06fa0;
    &:hover { background: #e06fa0; color: var(--ocean-abyss); box-shadow: 0 0 10px rgba(224,111,160,0.5); }
  }
  /* Depth 4: deep abyss violet */
  .depth-sub-btns :global(.pixel-btn-d4) {
    border-color: #9d6fe0;
    color: #9d6fe0;

    &:hover {
      background: #9d6fe0;
      color: var(--ocean-abyss);
      box-shadow: 0 0 14px rgba(157, 111, 224, 0.5);
    }
  }

  /* Sub-panel top border connects visually to the open DIVE IN button */
  .depth-sub-btns.expanded {
    border-top: 2px solid rgba(218, 160, 112, 0.25);
    padding-top: 0.7rem;
    gap: 0.6rem;
  }

  /* ── Main Menu Best Score ── */
  .main-menu-best {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    margin-bottom: 2rem;
  }

  .main-menu-best-label {
    font-family: var(--font-pixel);
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
  }

  .main-menu-best-score {
    font-family: var(--font-terminal);
    font-size: 2.8rem;
    color: var(--gold);
    line-height: 1;
  }

  /* ── Game Screen ── */
  .game-screen {
    padding: 0;
    justify-content: flex-start;
    min-height: calc(100dvh - 8rem);
    gap: 0;
  }

  .game-depth-wrapper {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    transition: background 0.8s ease;

    &.depth-1 {
      background: var(--ocean-abyss);
    }
    &.depth-2 {
      background: #071828;
    }
    &.depth-3 {
      background: #0f0812;  // dark warm — nursery
    }
    &.depth-4 {
      background: #040f1a;
    }
  }

  /* ── HUD ── */
  .ios-hud {
    width: 100%;
    max-width: 600px;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
    background: rgba(7, 20, 40, 0.9);
  }

  /* Row 1 — controls */
  .hud-row-1 {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.65rem 1.2rem;
    border-bottom: 1px solid var(--ocean-surface);
  }

  /* Row 2 — stats bar */
  .hud-row-2 {
    display: flex;
    align-items: center;
    padding: 0.4rem 1.2rem;
  }

  .hud-stat-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    min-width: 0;
  }

  .hud-stat-label {
    font-family: var(--font-pixel);
    font-size: 0.48rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    margin-bottom: 0.1rem;
    white-space: nowrap;
  }

  .hud-stat-value {
    font-family: var(--font-terminal);
    font-size: 1.6rem;
    color: var(--text-primary);
    line-height: 1;
    white-space: nowrap;
  }

  .hud-stat-score {
    font-size: 2.2rem;
    color: var(--gold);
  }

  .hud-stat-divider {
    width: 1px;
    height: 2rem;
    background: rgba(255, 255, 255, 0.1);
    flex-shrink: 0;
    margin: 0 0.6rem;
  }

  @media (pointer: coarse) {
    .hud-stat-value { font-size: 1.3rem; }
    .hud-stat-score { font-size: 2.2rem; } /* score stays large */
  }

  /* HUD buttons share the pixel-btn language at compact HUD scale */
  .hud-btn {
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    padding: 0.7rem 1rem;
    border: 3px solid var(--text-muted);
    border-radius: 2px;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    text-transform: uppercase;
    touch-action: manipulation;
    transition: background 0.08s, color 0.08s, border-color 0.08s, box-shadow 0.08s;
    min-height: 44px;
    white-space: nowrap;
    flex-shrink: 0;

    &:hover {
      background: var(--text-muted);
      color: var(--ocean-abyss);
    }
    &:active { transform: scale(0.95); }
  }

  /* Depth button: color shifts per depth, plus the [?] info icon */
  .hud-depth-btn {
    border-color: var(--cyan);
    color: var(--cyan);
    display: flex;
    align-items: center;
    gap: 0.45em;

    &:hover {
      background: var(--cyan);
      color: var(--ocean-abyss);
      box-shadow: 0 0 10px rgba(72, 202, 228, 0.5);
    }
    &.depth-2 {
      border-color: #daa070;
      color: #daa070;
      &:hover { background: #daa070; color: var(--ocean-abyss); box-shadow: 0 0 10px rgba(218,160,112,0.5); }
    }
    &.depth-3 {
      border-color: #e06fa0;
      color: #e06fa0;
      &:hover { background: #e06fa0; color: var(--ocean-abyss); box-shadow: 0 0 10px rgba(224,111,160,0.5); }
    }
    &.depth-4 {
      border-color: #9d6fe0;
      color: #9d6fe0;
      &:hover { background: #9d6fe0; color: var(--ocean-abyss); box-shadow: 0 0 10px rgba(157,111,224,0.5); }
    }
  }

  .hud-info-icon {
    font-family: var(--font-terminal);
    font-size: 1.15em;
    line-height: 1;
    opacity: 0.75;
  }

  /* ── Depth Info Overlay ── */
  .depth-info-overlay {
    position: fixed;
    inset: 0;
    z-index: 500;
    background: rgba(4, 12, 24, 0.92);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 2rem 1rem 3rem;
    box-sizing: border-box;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.18s ease;
    overflow-y: auto;

    &.visible {
      opacity: 1;
      pointer-events: all;
    }
  }

  .depth-info-panel {
    background: var(--ocean-deep);
    border: 3px solid var(--cyan);
    border-radius: 2px;
    width: 100%;
    max-width: 440px;
    overflow: hidden;
    transform: translateY(10px);
    transition: transform 0.2s ease, border-color 0.2s ease;

    .depth-info-overlay.visible & {
      transform: translateY(0);
    }
  }

  .depth-info-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: 1.4rem 1.4rem 1.1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }

  .depth-info-badge {
    font-family: var(--font-pixel);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    margin-bottom: 0.5rem;
    color: var(--cyan); /* set by JS per depth */
  }

  .depth-info-name {
    font-family: var(--font-pixel);
    font-size: 0.95rem;
    color: var(--text-primary);
    line-height: 1.7;
  }

  .depth-info-rules {
    padding: 1.4rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Rules content is injected via innerHTML — must use :global() anchored to
     the static .depth-info-rules parent so Astro's scope hash still gates it */

  /* ── Depth summary block ── */
  .depth-info-rules :global(.depth-summary) {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 2px;
    background: rgba(255, 255, 255, 0.04);
    padding: 0.9rem 1rem;
    margin-bottom: 1.4rem;
  }

  .depth-info-rules :global(.depth-summary-text) {
    font-family: var(--font-terminal);
    font-size: 1.55rem;
    color: var(--text-primary);
    line-height: 1.6;
    margin: 0;
  }

  /* ── Section label ── */
  .depth-info-rules :global(.depth-rules-section-label) {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    color: var(--text-muted);
    letter-spacing: 0.18em;
    margin: 0 0 0.8rem;
    display: block;
  }

  /* ── Key / value rows — fixed key column so values always align ── */
  .depth-info-rules :global(.depth-rule-row) {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 0.75rem;
    padding: 0.65rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    align-items: center;
  }

  .depth-info-rules :global(.depth-rule-key) {
    font-family: var(--font-pixel);
    font-size: 0.58rem;
    letter-spacing: 0.04em;
    white-space: nowrap;
    line-height: 1.4;
  }

  .depth-info-rules :global(.depth-rule-val) {
    font-family: var(--font-terminal);
    font-size: 1.65rem;
    color: var(--text-primary);
    line-height: 1.4;
  }

  /* ── Collapsible full-details section ── */
  .depth-info-rules :global(.depth-details) {
    margin-top: 1.2rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 2px;
  }

  .depth-info-rules :global(.depth-details[open]) {
    border-color: rgba(255, 255, 255, 0.18);
  }

  .depth-info-rules :global(.depth-details-toggle) {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    color: var(--text-muted);
    letter-spacing: 0.15em;
    padding: 0.8rem 1rem;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    user-select: none;
  }

  .depth-info-rules :global(.depth-details-toggle::-webkit-details-marker) {
    display: none;
  }

  .depth-info-rules :global(.depth-details[open] .depth-details-toggle) {
    color: var(--text-primary);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .depth-info-rules :global(.depth-details-body) {
    padding: 0.8rem 1rem 0.4rem;
  }

  .depth-info-rules :global(.depth-details-body .depth-rule-row) {
    grid-template-columns: 6.5rem 1fr;
  }

  .depth-info-rules :global(.depth-details-body .depth-rule-val) {
    font-size: 1.45rem;
  }

  .depth-info-scene {
    padding: 1.4rem;
  }

  .depth-scene-section-label {
    font-family: var(--font-pixel);
    font-size: 0.65rem;
    color: var(--text-muted);
    letter-spacing: 0.18em;
    margin-bottom: 1rem;
  }

  .depth-scene-canvas-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 0.9rem;
  }

  #depthSceneCanvas {
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    border: 2px solid rgba(255, 255, 255, 0.08);
    display: block;
  }

  .depth-scene-caption {
    font-family: var(--font-terminal);
    font-size: 1.75rem;
    color: var(--text-muted);
    text-align: center;
    min-height: 2em;
    margin: 0 0 1.2rem;
    line-height: 1.45;
  }

  .depth-scene-controls {
    display: flex;
    gap: 0.8rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Scene control buttons reuse hud-btn but with depth color override */
  .depth-scene-ctrl {
    font-size: 0.62rem;
    padding: 0.6rem 1.1rem;
  }

  /* Move counter pill — sits below the mini canvas */
  .depth-scene-move-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
  }

  .depth-scene-move-pip {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    border: 1px solid rgba(255,255,255,0.25);
    background: rgba(255,255,255,0.08);
    transition: background 0.12s, border-color 0.12s;

    &.shark-pip {
      border-color: #7aaab8;
      &.filled { background: #7aaab8; }
    }
    &.enemy-pip {
      border-color: #162d40;
      &.filled { background: #162d40; }
    }
  }

  .depth-scene-move-label {
    font-family: var(--font-pixel);
    font-size: 0.55rem;
    color: var(--text-muted);
    letter-spacing: 0.1em;
  }

  /* ── Canvas ── */
  .game-canvas-area {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
    width: 100%;
    max-width: 600px;
    padding: 0.4rem 0;
  }

  #gameCanvas {
    display: block;
    max-width: min(600px, calc(100vw - 16px));
    aspect-ratio: 1;
    width: 100%;
    height: auto;
    image-rendering: pixelated;
  }

  /* ── Depth Flash ── */
  .depth-flash {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-pixel);
    font-size: 1.4rem;
    color: var(--cyan);
    opacity: 0;
    pointer-events: none;
    z-index: 20;
    text-shadow:
      0 0 20px var(--cyan),
      0 0 40px rgba(72, 202, 228, 0.5);
    letter-spacing: 0.1em;

    &.flashing {
      animation: depth-flash-anim 1.6s ease-out forwards;
    }
  }

  @keyframes depth-flash-anim {
    0% {
      opacity: 0;
      transform: scale(0.7);
    }
    15% {
      opacity: 1;
      transform: scale(1.1);
    }
    55% {
      opacity: 1;
      transform: scale(1);
    }
    100% {
      opacity: 0;
      transform: scale(1);
    }
  }

  /* ── Game Over Overlay ── */
  .game-over-overlay {
    position: absolute;
    inset: 0;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(2, 8, 20, 0.88);
    z-index: 30;

    &.visible {
      display: flex;
    }
  }

  .game-over-title {
    font-family: var(--font-pixel);
    font-size: 1.4rem;
    color: var(--coral-danger);
    text-shadow: 0 0 20px rgba(239, 71, 111, 0.7);
    margin: 0 0 0.8rem;
    letter-spacing: 0.1em;
  }

  .game-over-score {
    font-family: var(--font-terminal);
    font-size: 3.2rem;
    color: var(--gold);
    margin: 0 0 0.4rem;
    line-height: 1;
  }

  .game-over-shark {
    font-family: var(--font-terminal);
    font-size: 1.65rem;
    color: var(--cyan);
    margin: 0 0 1.8rem;
    line-height: 1;
    min-height: 1.65rem;
  }

  .game-over-buttons {
    display: flex;
    gap: 1.2rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 1.2rem;
  }

  .submit-area {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 0.4rem;
  }

  .name-input-row {
    display: none;
    gap: 0.6rem;

    &.visible {
      display: flex;
    }
  }

  .name-input {
    font-family: var(--font-terminal);
    font-size: 1.8rem;
    padding: 0.4rem 0.8rem;
    border: 2px solid var(--cyan);
    border-radius: 2px;
    background: rgba(72, 202, 228, 0.08);
    color: var(--text-primary);
    width: 14rem;
    outline: none;

    &::placeholder {
      color: var(--text-muted);
    }
    &:focus {
      box-shadow: 0 0 8px rgba(72, 202, 228, 0.4);
    }
  }

  .submit-status {
    font-family: var(--font-terminal);
    font-size: 1.6rem;
    color: var(--cyan);
    min-height: 1.8rem;
  }

  /* ── D-Pad ── */
  .dpad {
    display: none;
    width: 100%;
    max-width: 600px;
    padding: 0.6rem 1.2rem 1.2rem;
    box-sizing: border-box;
    -webkit-user-select: none;
    user-select: none;
    touch-action: none;
    background: rgba(7, 20, 40, 0.9);
    border-top: 1px solid var(--ocean-surface);
  }

  @media (pointer: coarse) {
    .dpad {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: repeat(3, 1fr);
      gap: 0.5rem;
      width: 100%;
      max-width: none;
      /* Center the button area (≈28rem) while extending bg edge-to-edge */
      padding-left: max(1.2rem, calc(50% - 14rem));
      padding-right: max(1.2rem, calc(50% - 14rem));
      box-sizing: border-box;
      margin: 0;
    }
  }

  .dpad-btn {
    appearance: none;
    width: 100%;
    aspect-ratio: 1;
    border: 3px solid var(--cyan);
    border-radius: 4px;
    background: rgba(72, 202, 228, 0.05);
    color: var(--cyan);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      background 0.08s,
      box-shadow 0.08s;
    -webkit-tap-highlight-color: transparent;
    touch-action: none;
    min-height: 5.5rem;

    svg {
      width: 2.4rem;
      height: 2.4rem;
      fill: var(--cyan);
      stroke: none;
    }

    &.pressed,
    &:active {
      background: rgba(72, 202, 228, 0.22);
      box-shadow: 0 0 14px rgba(72, 202, 228, 0.5);
    }
  }

  .dpad-up {
    grid-column: 2;
    grid-row: 1;
  }
  .dpad-left {
    grid-column: 1;
    grid-row: 2;
  }
  .dpad-right {
    grid-column: 3;
    grid-row: 2;
  }
  .dpad-down {
    grid-column: 2;
    grid-row: 3;
  }
  .dpad-center {
    grid-column: 2;
    grid-row: 2;
    border: none;
    background: none;
    pointer-events: none;
  }

  /* ── Leaderboard Screen ── */
  .leaderboard-screen {
    align-items: flex-start;
    padding: 2rem 1rem;
    justify-content: flex-start;
  }

  /* Centered content column — fits iPhone and wider */
  .lb-content-wrap {
    width: 100%;
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }

  .lb-header {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
    margin-bottom: 1.6rem;
  }

  .lb-title {
    font-family: var(--font-pixel);
    font-size: 0.7rem;
    color: var(--cyan);
    margin: 0;
    flex: 1;
  }

  .lb-map-label {
    font-family: var(--font-terminal);
    font-size: 1.6rem;
    color: var(--text-muted);
    display: block;
    text-align: right;
  }

  .lb-table-wrap {
    width: 100%;
    overflow-x: hidden;
    border-radius: 6px;
    border: 1px solid rgba(72, 202, 228, 0.4);
    background: rgba(13, 53, 69, 0.55);
  }

  .lb-table {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-terminal);
    font-size: 1.75rem;
    table-layout: fixed;

    /* Percentage-based columns */
    col.col-rank  { width: 8%; }
    col.col-name  { width: 36%; }
    col.col-score { width: 18%; }
    col.col-date  { width: 38%; }

    /* ── Header ── */
    thead tr {
      background: rgba(29, 126, 146, 0.35);
      border-bottom: 2px solid rgba(72, 202, 228, 0.6);
    }

    thead th {
      font-family: var(--font-pixel);
      font-size: 0.58rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding: 0.7rem 0.75rem;
      font-weight: normal;
      line-height: 1.3;
      white-space: nowrap;
      vertical-align: middle;
      border-right: 1px solid rgba(72, 202, 228, 0.45);

      &:first-child  { text-align: center; }
      &:nth-child(2) { text-align: left; }
      &:nth-child(3) { text-align: right; }
      &:last-child   { text-align: right; border-right: none; }
    }

    /* ── Body rows ── */
    tbody tr {
      border-bottom: 1px solid rgba(72, 202, 228, 0.25);
      transition: background 0.08s;

      &:last-child { border-bottom: none; }
      &:nth-child(even) td { background: rgba(0, 0, 0, 0.14); }
      &:hover td { background: rgba(72, 202, 228, 0.07); }
      &.highlight td { background: rgba(72, 202, 228, 0.13); }
    }

    tbody td {
      padding: 0.55rem 0.75rem;
      color: var(--text-primary);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      vertical-align: middle;
      border-right: 1px solid rgba(72, 202, 228, 0.3);

      &:last-child { border-right: none; }
    }

    /* ── Column-specific alignment & style ── */
    td.lb-rank {
      text-align: center;
      font-size: 1.4rem;
      color: var(--text-muted);
    }

    tbody td:nth-child(2) {
      text-align: left;
      font-size: 1.75rem;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    td.lb-score {
      color: var(--gold);
      font-size: 1.9rem;
      text-align: right;
      font-variant-numeric: tabular-nums;
    }

    td.lb-date {
      color: var(--text-muted);
      font-size: 1.45rem;
      text-align: right;
      white-space: normal;
      line-height: 1.25;
      vertical-align: middle;
      overflow: visible;
    }
  }

  /* ── Global overrides for dynamically-injected table cells ──
     Astro scoped styles don't reach innerHTML-created td/th/tr.
     :global() bypasses scoping so these rules always apply.        */

  :global(.lb-table thead tr) {
    border-bottom: 2px solid rgba(72, 202, 228, 0.6);
  }

  :global(.lb-table thead th) {
    border-right: 1px solid rgba(72, 202, 228, 0.45);
    padding: 0.7rem 0.75rem;
    font-family: "Press Start 2P", monospace;
    font-size: 0.58rem;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: normal;
    white-space: nowrap;
    vertical-align: middle;
  }

  :global(.lb-table thead th:last-child) {
    border-right: none;
  }

  :global(.lb-table thead th:first-child)  { text-align: center; }
  :global(.lb-table thead th:nth-child(2)) { text-align: left; }
  :global(.lb-table thead th:nth-child(3)) { text-align: right; }
  :global(.lb-table thead th:last-child)   { text-align: right; }

  :global(.lb-table tbody tr) {
    border-bottom: 1px solid rgba(72, 202, 228, 0.25);
  }

  :global(.lb-table tbody tr:last-child) {
    border-bottom: none;
  }

  :global(.lb-table tbody td) {
    border-right: 1px solid rgba(72, 202, 228, 0.3);
    padding: 0.55rem 0.75rem;
    vertical-align: middle;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  :global(.lb-table tbody td:last-child) {
    border-right: none;
  }

  :global(.lb-table td.lb-rank) {
    text-align: center;
    font-size: 1.4rem;
    color: var(--text-primary);
  }

  :global(.lb-table tbody td:nth-child(2)) {
    text-align: left;
    font-size: 1.75rem;
  }

  :global(.lb-table td.lb-score) {
    color: #ffd166;
    font-size: 1.9rem;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }

  :global(.lb-table td.lb-date) {
    color: var(--text-primary);
    font-size: 1.45rem;
    text-align: right;
    white-space: normal;
    line-height: 1.25;
    vertical-align: middle;
  }

  :global(.lb-table td.lb-empty) {
    text-align: center;
    color: var(--text-muted);
    font-size: 1.4rem;
    padding: 2rem 1rem;
  }

  .medal {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    font-family: var(--font-pixel);
    font-size: 0.55rem;
    box-shadow: inset 0 -2px 4px rgba(0, 0, 0, 0.2);
  }

  /* ── Leaderboard Tab Bar ── */
  .lb-tab-bar {
    display: flex;
    gap: 0.35rem;
    overflow-x: auto;
    width: 100%;
    margin-bottom: 1.4rem;
    padding-bottom: 0.15rem;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    &::-webkit-scrollbar { display: none; }
  }

  .lb-tab {
    font-family: var(--font-pixel);
    font-size: 0.85rem;      /* close to main menu 1.05rem, slightly smaller to fit 5 tabs */
    letter-spacing: 0.06em;
    padding: 0.9rem 0.5rem;
    border: 3px solid var(--cyan);
    border-radius: 2px;
    background: transparent;
    color: var(--cyan);
    cursor: pointer;
    text-transform: uppercase;
    white-space: nowrap;
    flex: 1 1 0;
    min-width: 0;
    touch-action: manipulation;
    min-height: 44px;
    transition: background 0.08s, box-shadow 0.08s, color 0.08s;
    text-align: center;

    &:hover:not(:disabled) {
      background: var(--cyan);
      color: var(--ocean-abyss);
      box-shadow: 0 0 14px rgba(72, 202, 228, 0.5);
    }

    &:active:not(:disabled) {
      transform: scale(0.95);
    }

    &:focus-visible {
      outline: 2px solid var(--cyan);
      outline-offset: 2px;
    }

    &[aria-selected="true"],
    &.active {
      background: var(--cyan);
      border-color: var(--cyan);
      color: var(--ocean-abyss);
      box-shadow: 0 0 14px rgba(72, 202, 228, 0.5);
    }

    &.lb-tab-disabled,
    &:disabled {
      opacity: 0.32;
      cursor: not-allowed;
      pointer-events: none;
    }
  }

  /* Shark Score [?] inline help button */
  .lb-shark-help {
    background: none;
    border: 1px solid var(--text-muted);
    color: var(--text-muted);
    font-family: var(--font-pixel);
    font-size: 0.42rem;
    padding: 0.1rem 0.35rem;
    border-radius: 2px;
    cursor: pointer;
    margin-left: 0.45rem;
    vertical-align: middle;
    touch-action: manipulation;
    transition: color 0.08s, border-color 0.08s;
    min-height: 0;
    &:hover { color: var(--gold); border-color: var(--gold); }
    &:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }
  }

  /* Shark Score formula popup — gold border override */
  .shark-score-panel {
    border-color: var(--gold) !important;
  }

  .shark-score-rules {
    padding: 1.2rem 1.4rem 1.6rem;
  }

  .shark-score-rules :global(.depth-rules-section-label) {
    font-family: var(--font-pixel);
    font-size: 0.65rem;
    color: var(--text-muted);
    letter-spacing: 0.18em;
    margin-bottom: 1.2rem;
    display: block;
  }

  .shark-score-rules :global(.depth-rule-row) {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 0.75rem;
    padding: 0.65rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    align-items: center;
  }

  .shark-score-rules :global(.depth-rule-key) {
    font-family: var(--font-pixel);
    font-size: 0.58rem;
    letter-spacing: 0.04em;
    color: var(--gold);
    white-space: nowrap;
    line-height: 1.4;
  }

  .shark-score-rules :global(.depth-rule-val) {
    font-family: var(--font-terminal);
    font-size: 1.65rem;
    color: var(--text-primary);
    line-height: 1.4;
  }

  .medal-gold {
    background: linear-gradient(145deg, #f7dc6f, #d4a017);
    color: #5c4300;
    border: 2px solid #c9960c;
  }
  .medal-silver {
    background: linear-gradient(145deg, #d5d5d5, #a0a0a0);
    color: #4a4a4a;
    border: 2px solid #909090;
  }
  .medal-bronze {
    background: linear-gradient(145deg, #dea06e, #b87333);
    color: #5a3510;
    border: 2px solid #a0612a;
  }

  .lb-empty {
    font-family: var(--font-terminal);
    font-size: 1.8rem;
    color: var(--text-muted);
    text-align: center;
    padding: 2rem 0;
  }

  /* ── Settings Screen ── */
  .settings-screen {
    align-items: center;
    padding: 2rem 1.6rem;
  }

  .settings-screen .lb-header {
    width: 100%;
    max-width: 36rem;
  }

  .settings-title {
    font-size: 0.75rem;
    margin: 0 0 2.5rem;
  }

  .settings-rows {
    width: 100%;
    max-width: 36rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .settings-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.4rem 0;
    border-bottom: 1px solid var(--ocean-surface);
  }

  .settings-row-label {
    font-family: var(--font-pixel);
    font-size: 0.75rem;
    color: var(--text-primary);
    letter-spacing: 0.06em;
  }

  .settings-row-sub {
    font-family: var(--font-terminal);
    font-size: 1.4rem;
    color: var(--text-muted);
    display: block;
    margin-top: 0.3rem;
  }

  .pixel-toggle {
    position: relative;
    width: 4.4rem;
    height: 2.4rem;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;

    input {
      opacity: 0;
      width: 0;
      height: 0;
      position: absolute;
    }

    .toggle-track {
      position: absolute;
      inset: 0;
      background: var(--ocean-surface);
      border: 2px solid var(--ocean-surface);
      border-radius: 2px;
      transition:
        background 0.1s,
        border-color 0.1s;
    }

    .toggle-knob {
      position: absolute;
      top: 3px;
      left: 3px;
      width: 1.4rem;
      height: 1.4rem;
      background: var(--text-muted);
      border-radius: 2px;
      transition:
        transform 0.1s,
        background 0.1s;
    }

    input:checked ~ .toggle-track {
      background: rgba(72, 202, 228, 0.2);
      border-color: var(--cyan);
      box-shadow: 0 0 10px rgba(72, 202, 228, 0.7), 0 0 20px rgba(72, 202, 228, 0.3);
    }

    input:checked ~ .toggle-track .toggle-knob {
      transform: translateX(2rem);
      background: var(--cyan);
    }
  }

  .settings-version {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    color: var(--text-muted);
    margin-top: 3rem;
  }

  /* ── Dev Panel ── */
  .dev-panel {
    width: 100%;
    max-width: 36rem;
    margin-top: 2.4rem;
    border: 2px dashed rgba(255, 209, 102, 0.4);
    border-radius: 2px;
    padding: 1.2rem 1.4rem;
    box-sizing: border-box;
  }

  .dev-panel-label {
    font-family: var(--font-pixel);
    font-size: 0.55rem;
    color: var(--gold);
    letter-spacing: 0.1em;
    opacity: 0.7;
    margin: 0 0 1rem;
    text-transform: uppercase;
  }

  .dev-panel-btns {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .dev-panel-btns :global(button) {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    padding: 0.6rem 1rem;
    border: 2px solid rgba(255, 209, 102, 0.5);
    border-radius: 2px;
    background: transparent;
    color: var(--gold);
    cursor: pointer;
    letter-spacing: 0.05em;
    opacity: 0.75;
    touch-action: manipulation;
    transition: background 0.08s, opacity 0.08s;

    &:hover {
      background: rgba(255, 209, 102, 0.15);
      opacity: 1;
    }

    &:active {
      transform: scale(0.95);
    }
  }
</style>

<BaseLayout
  pageTitle={blogData.title}
  showTypographyHero={showTypographyHero}
  description={blogData.description}
  fullWidthBody={fullWidthBody}>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323:wght@400&display=swap"
      rel="stylesheet"
    />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no"
    />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta
      name="apple-mobile-web-app-status-bar-style"
      content="black-translucent"
    />
  </Fragment>

  <div class="shark-ios-app" id="sharkIosApp">
    <!-- ── Screen 1: Splash ── LaunchView.swift -->
    <div id="screen-splash" class="screen splash-screen active">
      <canvas id="splashSharkCanvas" width="160" height="160"></canvas>
      <h1 class="pixel-title splash-title">SHARK<br />THIEF</h1>
      <p class="splash-sub">LOADING...</p>
    </div>

    <!-- ── Screen 2: Main Menu ── MainMenuView.swift -->
    <div id="screen-main-menu" class="screen screen-menu">
      <canvas id="menuSharkCanvas" width="120" height="120"></canvas>
      <h2 class="pixel-title main-menu-title">SHARK THIEF</h2>
      <p class="main-menu-sub">OCEAN ARCADE</p>
      <div class="main-menu-best">
        <span class="main-menu-best-label">BEST</span>
        <span class="main-menu-best-score" id="menuBestScore">0</span>
      </div>
      <div class="main-menu-buttons">
        <button class="pixel-btn pixel-btn-continue" id="menuContinueBtn" style="display:none">CONTINUE</button>
        <button class="pixel-btn" id="menuPlayBtn">DIVE IN</button>
        <div class="depth-sub-btns" id="depthSubBtns"></div>
        <button class="pixel-btn pixel-btn-muted" id="menuLeaderboardBtn"
          >LEADERBOARD</button
        >
        <button class="pixel-btn pixel-btn-muted" id="menuSettingsBtn"
          >SETTINGS</button
        >
        <button class="pixel-btn pixel-btn-abandon" id="menuAbandonBtn" style="display:none">ABANDON DIVE</button>
      </div>
      <p class="main-menu-depth" id="menuDepthLabel"></p>
    </div>

    <!-- ── Screen 4: Game ── GameView.swift -->
    <div id="screen-game" class="screen game-screen">
      <div class="game-depth-wrapper depth-1" id="gameDepthWrapper">
        <!-- HUDView.swift -->
        <div class="ios-hud">
          <!-- Row 1: controls -->
          <div class="hud-row hud-row-1">
            <button class="hud-btn" id="hudMenuBtn">MENU</button>
            <button class="hud-btn hud-depth-btn" id="hudDepthBtn">
              <span id="hudDepthLabel">DEPTH 1</span>
              <span class="hud-info-icon">[?]</span>
            </button>
          </div>
          <!-- Row 2: stats bar -->
          <div class="hud-row hud-row-2">
            <div class="hud-stat-block">
              <span class="hud-stat-label">SCORE</span>

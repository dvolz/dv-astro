  // ===== Keyboard Controls =====  →  GameView.swift

  document.addEventListener("keydown", (e) => {
    if (
      e.target instanceof HTMLInputElement ||
      e.target instanceof HTMLTextAreaElement
    )
      return;
    switch (e.key) {
      case "ArrowUp":
      case "w":
      case "W":
        e.preventDefault();
        moveShark(0, -1);
        break;
      case "ArrowDown":
      case "s":
      case "S":
        e.preventDefault();
        moveShark(0, 1);
        break;
      case "ArrowLeft":
      case "a":
      case "A":
        e.preventDefault();
        moveShark(-1, 0);
        break;
      case "ArrowRight":
      case "d":
      case "D":
        e.preventDefault();
        moveShark(1, 0);
        break;
    }
  });

  // ===== Navigation Wiring =====  →  RootNavigationView.swift

  // Splash → Main Menu (auto)
  setTimeout(() => showScreen("main-menu"), 1200);

  // Main Menu buttons
  document
    .getElementById("menuPlayBtn")!
    .addEventListener("click", () => showScreen("map-selector"));
  document
    .getElementById("menuLeaderboardBtn")!
    .addEventListener("click", () => {
      fetchLeaderboard();
      showScreen("leaderboard");
    });
  document
    .getElementById("menuSettingsBtn")!
    .addEventListener("click", () => showScreen("settings"));

  // Map selector
  const MAP_LABELS: Record<MapSize, string> = {
    small: "REEF (20×20)",
    medium: "ABYSS (30×30)",
  };
  let selectedMap: MapSize = "small";

  document.querySelectorAll(".map-card").forEach((card) => {
    card.addEventListener("click", () => {
      selectedMap = (card as HTMLElement).dataset.map as MapSize;
      document
        .querySelectorAll(".map-card")
        .forEach((c) => c.classList.remove("selected"));
      card.classList.add("selected");
      refreshMapScores();
    });
  });

  function refreshMapScores() {
    const small = parseInt(
      localStorage.getItem("sharkIosHighScore-small") || "0",
      10,
    );
    const medium = parseInt(
      localStorage.getItem("sharkIosHighScore") || "0",
      10,
    );
    document.getElementById("mapScoreSmall")!.textContent = String(small);
    document.getElementById("mapScoreMedium")!.textContent = String(medium);
  }

  document.getElementById("mapPlayBtn")!.addEventListener("click", () => {
    currentMap = selectedMap;
    GRID = MAP_GRIDS[currentMap];
    const canvas = document.getElementById("gameCanvas") as HTMLCanvasElement;
    CELL = canvas.width / GRID;

    document.getElementById("lbMapLabel")!.textContent = MAP_LABELS[currentMap];

    showScreen("game");
    init();
    fetchLeaderboard();
  });

  document
    .getElementById("mapBackBtn")!
    .addEventListener("click", () => showScreen("main-menu"));

  // Leaderboard back
  document
    .getElementById("lbBackBtn")!
    .addEventListener("click", () => showScreen("main-menu"));

  // HUD menu button — back to main menu during gameplay
  document.getElementById("hudMenuBtn")!.addEventListener("click", () => {
    gameOver = true; // stop input
    const label = document.getElementById("menuDepthLabel")!;
    label.textContent = currentDepth > 1 ? `REACHED DEPTH ${currentDepth}` : "";
    showScreen("main-menu");
  });

  // Game Over buttons
  document
    .getElementById("playAgainBtn")!
    .addEventListener("click", () => init());
  document.getElementById("gameOverMenuBtn")!.addEventListener("click", () => {
    const label = document.getElementById("menuDepthLabel")!;
    label.textContent = currentDepth > 1 ? `REACHED DEPTH ${currentDepth}` : "";
    showScreen("main-menu");
  });

  // Settings back
  document
    .getElementById("settingsBackBtn")!
    .addEventListener("click", () => showScreen("main-menu"));

  // Settings toggles
  const settingsColorblind = document.getElementById(
    "settingsColorblind",
  ) as HTMLInputElement;
  const settingsHaptics = document.getElementById(
    "settingsHaptics",
  ) as HTMLInputElement;

  settingsColorblind.checked =
    localStorage.getItem("sharkColorblind") === "true";
  settingsHaptics.checked = localStorage.getItem("sharkHaptics") !== "false";

  settingsColorblind.addEventListener("change", () => {
    colorblindMode = settingsColorblind.checked;
    localStorage.setItem("sharkColorblind", String(colorblindMode));
  });
  settingsHaptics.addEventListener("change", () => {
    localStorage.setItem("sharkHaptics", String(settingsHaptics.checked));
  });

  // ===== Startup =====  →  SharkThiefApp.swift

  // Draw splash shark
  const splashCanvas = document.getElementById(
    "splashSharkCanvas",
  ) as HTMLCanvasElement;
  if (splashCanvas) {
    const splashCtx = splashCanvas.getContext("2d")!;
    drawSharkOnCtx(splashCtx, 0, 0, splashCanvas.width, "right");
  }

  // Animate menu shark — breathing scale + vertical bob + tail wag
  const menuSharkCanvas = document.getElementById(
    "menuSharkCanvas",
  ) as HTMLCanvasElement;
  if (menuSharkCanvas) {
    const menuCtx = menuSharkCanvas.getContext("2d")!;
    const mw = menuSharkCanvas.width;
    const mh = menuSharkCanvas.height;
    let mt = 0;
    function menuSharkFrame() {
      mt += 0.032;
      menuCtx.clearRect(0, 0, mw, mh);
      menuCtx.save();
      // Breathing: subtle scale pulse centred on canvas
      const breathe = 1 + 0.028 * Math.sin(mt * 1.3);
      menuCtx.translate(mw / 2, mh / 2);
      menuCtx.scale(breathe, breathe);
      menuCtx.translate(-mw / 2, -mh / 2);
      // Gentle vertical float
      menuCtx.translate(0, Math.sin(mt * 0.75) * 3);
      // Tail lobes counter-oscillate at a different frequency
      const tailWag = Math.sin(mt * 2.4) * 0.85;
      drawSharkOnCtx(menuCtx, 0, 0, mw, "right", tailWag);
      menuCtx.restore();
      requestAnimationFrame(menuSharkFrame);
    }
    requestAnimationFrame(menuSharkFrame);
  }

  // Init map score display
  refreshMapScores();
</script>

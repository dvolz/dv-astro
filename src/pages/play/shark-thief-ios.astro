  function updateMaxDepth(depth: number) {
    if (depth > getMaxDepth()) {
      localStorage.setItem(MAX_DEPTH_KEY, String(depth));
    }
  }

  function loadGame(save: any) {
    // Restore 2D arrays from flat
    pickups = [];
    superPickups = [];
    coralPickups = [];
    coral = [];
    colors = [];
    const emptyRow = () => Array(GRID).fill(false);
    for (let r = 0; r < GRID; r++) {
      pickups.push(Array.from(save.pickups.slice(r * GRID, (r + 1) * GRID)));
      superPickups.push(Array.from(save.superPickups.slice(r * GRID, (r + 1) * GRID)));
      coralPickups.push(Array.from((save.coralPickups || []).slice(r * GRID, (r + 1) * GRID).concat(emptyRow()).slice(0, GRID)));
      coral.push(Array.from(save.coral.slice(r * GRID, (r + 1) * GRID)));
      colors.push(Array.from(save.colors.slice(r * GRID, (r + 1) * GRID)));
    }

    shark = { ...save.shark };
    sharkDir = save.sharkDir || "right";
    sharkVisualX = shark.x;
    sharkVisualY = shark.y;
    score = save.score || 0;
    currentDepth = save.currentDepth || 1;
    depthEntryScore = save.depthEntryScore ?? (currentDepth - 1) * 100; // fallback for old saves
    moveCount = save.moveCount || 0;
    enemies = save.enemies || [];
    bigEnemies = save.bigEnemies || [];
    leviathan = save.leviathan || null;
    gameOver = false;

    // Restore timing so the live clock continues from saved elapsed time
    gameStartTime = performance.now() - (save.runElapsedMs || 0);
    levelStartTime = performance.now() - (save.levelElapsedMs || 0);
    levelTimes = save.levelTimes || [];
    totalTimeMs = 0;

    // Update HUD
    hudScore.textContent = String(score);
    highScore = getHighScore();
    updateHudDepth(currentDepth);
    startHudClock();

    // Depth wrapper
    const wrapper = document.getElementById("gameDepthWrapper")!;
    wrapper.className = `game-depth-wrapper depth-${currentDepth}`;

    // Reset dying enemies
    dyingEnemies = [];
    if (dyingRafId) { cancelAnimationFrame(dyingRafId); dyingRafId = null; }

    // Reset shimmer
    shimmerIntensity.fill(0);
    shimmerSpeed.fill(0);
    if (shimmerRafId) cancelAnimationFrame(shimmerRafId);
    if (shimmerMode) shimmerRafId = requestAnimationFrame(tickShimmer);

    gameOverOverlay.classList.remove("visible");
    draw();
  }

  function initAtDepth(targetDepth: number) {
    const canvas = document.getElementById("gameCanvas") as HTMLCanvasElement;
    CELL = canvas.width / GRID;
    showScreen("game");
    init(); // resets everything to depth 1
    if (targetDepth > 1) {
      startedFromDepth1 = false; // dev jump — shark score ineligible
      depthEntryScore = 0; // score starts at 0 regardless of target depth
    }

    const devWrapper = document.getElementById("gameDepthWrapper")!;
    if (targetDepth >= 2) {
      currentDepth = 2;
      updateHudDepth(2);
      devWrapper.className = "game-depth-wrapper depth-2";
      // No ammonite shells at depth 2+
      for (let r = 0; r < GRID; r++) superPickups[r].fill(false);
      spawnCoral();
      // Seed some coral shell pickups
      let placed = 0, attempts = 0;
      while (placed < CORAL_PICKUP_INIT && attempts < 800) {
        attempts++;
        const cpx = Math.floor(Math.random() * GRID);
        const cpy = Math.floor(Math.random() * GRID);
        if (!coralPickups[cpy][cpx] && !pickups[cpy][cpx] && !coral[cpy][cpx] && !(cpx === shark.x && cpy === shark.y)) {
          coralPickups[cpy][cpx] = true;
          placed++;
        }
      }
    }
    if (targetDepth >= 3) {
      currentDepth = 3;
      updateHudDepth(3);
      devWrapper.className = "game-depth-wrapper depth-3";
      // Nursery — clear coral, spawn egg
      for (let r = 0; r < GRID; r++) {
        coral[r].fill(false);
        coralPickups[r].fill(false);
        superPickups[r].fill(false);
      }
      babySharks = [];
      bloodCells = [];
      sharkPositionHistory = [];
      spawnSharkEgg();
    }
    if (targetDepth >= 4) {
      currentDepth = 4;
      updateHudDepth(4);
      devWrapper.className = "game-depth-wrapper depth-4";
      sharkEgg = null;
      spawnLeviathan();
    }

    draw();
    fetchLeaderboard();
  }


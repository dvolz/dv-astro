  // ── Mini canvas constants ────────────────────────────────────────
  const MINI_CS = 40; // cell size: 5×5 grid = 200×200 canvas
  const MINI_N = 5;

  // Pre-seeded tile color grids so the board looks like the real game every render
  // Uses the same TILE_COLORS palette, deterministic so it doesn't flicker
  const MINI_TILE_COLORS_D1 = (() => {
    const seed = [0,3,1,4,2, 2,0,4,1,3, 4,2,0,3,1, 1,4,2,0,3, 3,1,3,2,0];
    return seed.map(i => TILE_COLORS[i % TILE_COLORS.length]);
  })();
  const MINI_TILE_COLORS_D2 = (() => {
    const seed = [1,4,0,3,2, 3,0,2,4,1, 0,3,4,1,2, 2,1,3,0,4, 4,2,1,3,0];
    return seed.map(i => TILE_COLORS[i % TILE_COLORS.length]);
  })();

  function eio(t: number) { return t < 0.5 ? 2*t*t : -1+(4-2*t)*t; }

  // ── Mini draw functions — exact same visuals as the real game ────

  function miniBackground(ctx: CanvasRenderingContext2D, depth: number) {
    // ocean floor between tiles
    ctx.fillStyle = "#0f5262";
    ctx.fillRect(0, 0, 200, 200);
    const tileGrid = depth === 2 ? MINI_TILE_COLORS_D2 : MINI_TILE_COLORS_D1;
    for (let r = 0; r < MINI_N; r++) {
      for (let c = 0; c < MINI_N; c++) {
        ctx.fillStyle = tileGrid[r * MINI_N + c];
        ctx.fillRect(c*MINI_CS, r*MINI_CS, MINI_CS, MINI_CS);
      }
    }
  }

  function miniDrawCoral(ctx: CanvasRenderingContext2D, col: number, row: number) {
    // Identical to real game coral barrier render
    const cx = col*MINI_CS, cy = row*MINI_CS;
    ctx.fillStyle = "#7a4a30";
    ctx.fillRect(cx, cy, MINI_CS, MINI_CS);
    ctx.fillStyle = "#c8906a";
    ctx.fillRect(cx+1, cy+1, MINI_CS-2, MINI_CS-2);
    ctx.fillStyle = "#e0b898";
    const dot = Math.max(2, Math.floor(MINI_CS * 0.15));
    ctx.fillRect(cx+2, cy+2, dot, dot);
    ctx.fillRect(cx+MINI_CS-dot-2, cy+2, dot, dot);
  }

  function miniDrawCoin(ctx: CanvasRenderingContext2D, col: number, row: number) {
    // Gold square pickup — same as real game
    const pad = MINI_CS * 0.2;
    const px = col*MINI_CS + pad, py = row*MINI_CS + pad, ps = MINI_CS - pad*2;
    ctx.fillStyle = "#7a5500";
    ctx.fillRect(px-1, py-1, ps+2, ps+2);
    ctx.fillStyle = "#ffd166";
    ctx.fillRect(px, py, ps, ps);
  }

  function miniDrawAmmonite(ctx: CanvasRenderingContext2D, col: number, row: number, alpha: number) {
    // Calls real drawShellPickup with alpha
    const pad = MINI_CS * 0.2;
    const px = col*MINI_CS + pad, py = row*MINI_CS + pad, ps = MINI_CS - pad*2;
    ctx.save(); ctx.globalAlpha = alpha;
    drawShellPickup(ctx, px, py, ps);
    ctx.restore();
  }

  function miniDrawCoralShell(ctx: CanvasRenderingContext2D, col: number, row: number, alpha: number) {
    // Calls real drawCoralShell with alpha
    const pad = MINI_CS * 0.2;
    const px = col*MINI_CS + pad, py = row*MINI_CS + pad, ps = MINI_CS - pad*2;
    ctx.save(); ctx.globalAlpha = alpha;
    drawCoralShell(ctx, px, py, ps);
    ctx.restore();
  }

  function miniDrawEnemy(ctx: CanvasRenderingContext2D, vx: number, vy: number, alpha: number) {
    // Real game enemy rendering — 1×1 dark navy
    ctx.save(); ctx.globalAlpha = alpha;
    ctx.fillStyle = "#0a1824";
    ctx.fillRect(vx*MINI_CS - 1, vy*MINI_CS - 1, MINI_CS + 2, MINI_CS + 2);
    ctx.fillStyle = "#162d40";
    ctx.fillRect(vx*MINI_CS, vy*MINI_CS, MINI_CS, MINI_CS);
    ctx.restore();
  }

  function miniDrawBigEnemy(ctx: CanvasRenderingContext2D, col: number, row: number, alpha: number) {
    // Real game big enemy — 2×2 deep purple
    const bx = col*MINI_CS, by = row*MINI_CS, bw = MINI_CS*2;
    ctx.save(); ctx.globalAlpha = alpha;
    ctx.fillStyle = "#120a1e";
    ctx.fillRect(bx-1, by-1, bw+2, bw+2);
    ctx.fillStyle = "#2d1a4a";
    ctx.fillRect(bx, by, bw, bw);
    ctx.restore();
  }

  function miniDrawShark(ctx: CanvasRenderingContext2D, vx: number, vy: number, dir: string) {
    // Calls real drawSharkOnCtx at mini cell size
    drawSharkOnCtx(ctx, vx, vy, MINI_CS, dir);
  }

  function miniDrawLabel(ctx: CanvasRenderingContext2D, col: number, row: number, text: string, alpha: number) {
    ctx.save(); ctx.globalAlpha = alpha;
    ctx.font = "bold 10px monospace";
    ctx.fillStyle = "#ffd166";
    ctx.textAlign = "center";
    ctx.fillText(text, (col+0.5)*MINI_CS, row*MINI_CS - 3);
    ctx.restore();
  }

  // ── Move pip updater ─────────────────────────────────────────────
  // Shows: [YOU ●●] [ENEMY ●] to explain the 2:1 move ratio
  function updateMovePips(sharkMovesDone: number) {
    // sharkMovesDone: 0=none, 1=first, 2=second(+enemy moved)
    const pip1 = document.getElementById("movePip1");
    const pip2 = document.getElementById("movePip2");
    const epip1 = document.getElementById("enemyPip1");
    if (!pip1 || !pip2 || !epip1) return;

    const turn = sharkMovesDone % 2; // 0 or 1 within the 2-move cycle
    const cycle = Math.floor(sharkMovesDone / 2); // completed cycles

    pip1.classList.toggle("filled", sharkMovesDone >= 1);
    pip2.classList.toggle("filled", sharkMovesDone >= 2);
    // Enemy pip lights when enemy has just moved (every 2nd shark move)
    epip1.classList.toggle("filled", cycle >= 1 || (sharkMovesDone > 0 && turn === 0));
  }

  // ── Animation state ──────────────────────────────────────────────
  let miniRaf: number | null = null;
  let miniElapsed = 0;
  let miniLastTick = 0;
  let miniPlaying = false;
  let miniDone = false;
  let miniDepth = 1;
  const MINI_TOTAL: Record<number, number> = { 1: 4800, 2: 5200, 3: 999 };

  function miniTick(now: number) {
    const delta = now - miniLastTick;
    miniLastTick = now;
    miniElapsed += delta;
    renderMiniScene(miniDepth, miniElapsed);
    if (miniElapsed >= MINI_TOTAL[miniDepth]) {
      miniDone = true; miniPlaying = false; miniRaf = null;
      syncMiniControls(); return;
    }
    miniRaf = requestAnimationFrame(miniTick);
  }

  function renderMiniScene(depth: number, elapsed: number) {
    const canvas = document.getElementById("depthSceneCanvas") as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext("2d")!;
    ctx.clearRect(0, 0, 200, 200);
    if (depth === 1) renderD1(ctx, elapsed);
    else if (depth === 2) renderD2(ctx, elapsed);
    else renderD3(ctx, elapsed);
  }

  function setMiniCaption(text: string) {
    const el = document.getElementById("depthSceneCaption");
    if (el) el.textContent = text;
  }

  // ── Depth 1 scene ────────────────────────────────────────────────
  // Board: shark (0,2)→right, ammonite (3,2), enemy (4,0)
  // Move 1 (500ms): shark→(1,2), enemy waits
  // Move 2 (900ms): shark→(2,2), ENEMY STEPS (4,0)→(3,1)
  // Move 3 (1300ms): shark→(3,2), collects ammonite, +10 flash
  // Big enemy spawns (1700ms)
  // Move 4 (2400ms): shark→(3,1) up, ENEMY STEPS (3,1)→(2,2)
  // Hold (3000ms+)
  function renderD1(ctx: CanvasRenderingContext2D, elapsed: number) {
    const M1 = 500, M1E = 850;    // move 1: shark slides
    const M2 = 900, M2E = 1250;   // move 2: shark slides + enemy steps
    const M3 = 1300, M3E = 1650;  // move 3: collect ammonite
    const FLASH = 1900;           // +10 pts visible
    const BSPAWN = 2100, BSPAWN_E = 2500; // big enemy fades in
    const M4 = 2600, M4E = 2950;  // move 4: shark up + enemy steps
    const DONE = MINI_TOTAL[1];
    const e = Math.min(elapsed, DONE);

    // Shark visual position
    let svx = 0, svy = 2, sdir = "right";
    if (e < M1) { svx = 0; }
    else if (e < M1E) { svx = eio((e-M1)/(M1E-M1)); }
    else if (e < M2) { svx = 1; }
    else if (e < M2E) { svx = 1 + eio((e-M2)/(M2E-M2)); }
    else if (e < M3) { svx = 2; }
    else if (e < M3E) { svx = 2 + eio((e-M3)/(M3E-M3)); }
    else if (e < M4) { svx = 3; }
    else if (e < M4E) { svy = 2 - eio((e-M4)/(M4E-M4)); svx = 3; sdir = "up"; }
    else { svx = 3; svy = 1; sdir = "up"; }

    // Enemy visual position (starts (4,4), moves on moves 2 and 4)
    // Move 2: shark at (2,2) → diffX=-2,diffY=-2 → horizontal → (4,4)→(3,4)
    // Move 4: shark at (3,1) → diffX=0,diffY=-3  → vertical   → (3,4)→(3,3)
    let evx = 4, evy = 4;
    if (e >= M2E) {
      if (e < M2E + 350) {
        const t = (e - M2E) / 350;
        evx = 4 - eio(t); evy = 4;          // (4,4)→(3,4) horizontal
      } else { evx = 3; evy = 4; }
    }
    if (e >= M4E) {
      const t2start = M4E, t2end = M4E + 350;
      if (e < t2end) {
        const t = (e - t2start) / 350;
        evx = 3; evy = 4 - eio(t);          // (3,4)→(3,3) vertical
      } else { evx = 3; evy = 3; }
    }

    const ammoniteAlpha = e >= M3 ? Math.max(0, 1 - eio(Math.min(1,(e-M3)/(M3E-M3)))*1.8) : 1;
    const plusAlpha = e >= M3E && e < FLASH ? Math.sin(((e-M3E)/(FLASH-M3E))*Math.PI) : 0;
    const bigEAlpha = e >= BSPAWN ? eio(Math.min(1,(e-BSPAWN)/(BSPAWN_E-BSPAWN))) : 0;

    // pip state: how many moves the shark has done so far
    const sharkMovesDone = e < M1 ? 0 : e < M2 ? 1 : e < M3 ? 2 : e < M4 ? 3 : 4;
    updateMovePips(sharkMovesDone);

    miniBackground(ctx, 1);
    [[0,1],[2,3],[4,3],[3,4]].forEach(([c,r]) => miniDrawCoin(ctx, c, r));
    if (bigEAlpha > 0) miniDrawBigEnemy(ctx, 0, 0, bigEAlpha);
    if (ammoniteAlpha > 0) miniDrawAmmonite(ctx, 3, 2, ammoniteAlpha);
    if (plusAlpha > 0) miniDrawLabel(ctx, 3, 2, "+10 PTS", plusAlpha);
    miniDrawEnemy(ctx, evx, evy, 1);
    miniDrawShark(ctx, svx, svy, sdir);

    if (e < M1) setMiniCaption("FIND THE PURPLE AMMONITE");
    else if (e < M1E) setMiniCaption("MOVE 1 — ENEMY WAITS...");
    else if (e < M2E) setMiniCaption("MOVE 2 — ENEMY ADVANCES!");
    else if (e < M3E) setMiniCaption("MOVE 3 — COLLECT THE AMMONITE!");
    else if (e < FLASH) setMiniCaption("+10 PTS — AMMONITE COLLECTED!");
    else if (e < BSPAWN_E) setMiniCaption("A BIG 2×2 ENEMY SPAWNS!");
    else if (e < M4E) setMiniCaption("MOVE 4 — ENEMY HUNTS AGAIN!");
    else setMiniCaption("REACH 100 PTS TO DESCEND");
  }

  // ── Depth 2 scene ────────────────────────────────────────────────
  // Board: shark (0,2), coral shell (2,2), enemy (4,0), spawned enemy (4,4)
  // Move 1 (500ms): shark→(1,2), enemy waits
  // Move 2: shark tries (2,2), BOUNCES BACK + ENEMY STEPS (4,0)→(3,0) horizontal
  //   Shell → barrier, +5 flash, new enemy spawns at (4,4)
  // Move 3: shark→(1,1) up
  // Move 4: shark→(2,1) right + ENEMY (3,0)→(2,0) horizontal, SPAWNED (4,4)→(4,3) vertical
  // Hold
  function renderD2(ctx: CanvasRenderingContext2D, elapsed: number) {
    const M1 = 500, M1E = 850;        // move 1
    const BOUNCE_S = 950, BOUNCE_E = 1600; // move 2: shark bounces
    const TRANSFORM = 1800;           // shell→barrier flash end
    const SPAWN_E = 2200;             // spawned enemy fades in
    const M3 = 2300, M3E = 2650;      // move 3 shark up
    const M4 = 2750, M4E = 3100;      // move 4 shark right + enemy moves
    const DONE = MINI_TOTAL[2];
    const e = Math.min(elapsed, DONE);

    // Shark position
    let svx = 0, svy = 2, sdir = "right";
    if (e < M1) { svx = 0; }
    else if (e < M1E) { svx = eio((e-M1)/(M1E-M1)); }
    else if (e < BOUNCE_S) { svx = 1; }
    else if (e < BOUNCE_E) {
      // sin bounce: lunge then rebound
      const t = (e-BOUNCE_S)/(BOUNCE_E-BOUNCE_S);
      svx = 1 + Math.sin(t * Math.PI) * 0.42;
    }
    else if (e < M3) { svx = 1; }
    else if (e < M3E) { svy = 2 - eio((e-M3)/(M3E-M3)); svx = 1; sdir = "up"; }
    else if (e < M4) { svx = 1; svy = 1; sdir = "up"; }
    else if (e < M4E) { svx = 1 + eio((e-M4)/(M4E-M4)); svy = 1; sdir = "right"; }
    else { svx = 2; svy = 1; sdir = "right"; }

    // Enemy A: starts (4,0), moves on move 2 and move 4
    // Move 2: shark at (1,2) → diffX=-3,diffY=2  → horizontal → (4,0)→(3,0)
    // Move 4: shark at (2,1) → diffX=-1,diffY=1  → horizontal (tie) → (3,0)→(2,0)
    let evx = 4, evy = 0;
    if (e >= BOUNCE_E) {
      const es = BOUNCE_E, ee = BOUNCE_E + 350;
      if (e < ee) { const t=(e-es)/350; evx=4-eio(t); evy=0; }  // (4,0)→(3,0) horizontal
      else { evx = 3; evy = 0; }
    }
    if (e >= M4E) {
      const es = M4E, ee = M4E + 350;
      if (e < ee) { const t=(e-es)/350; evx=3-eio(t); evy=0; }  // (3,0)→(2,0) horizontal
      else { evx = 2; evy = 0; }
    }

    // Spawned enemy: fades in after shell interaction, then moves on move 4
    // Move 4: shark at (2,1) → diffX=-2,diffY=-3 → vertical → (4,4)→(4,3)
    const spawnedAlpha = e >= TRANSFORM ? eio(Math.min(1,(e-TRANSFORM)/(SPAWN_E-TRANSFORM))) : 0;
    let sevx = 4, sevy = 4;
    if (e >= M4E) {
      const es = M4E, ee = M4E + 350;
      if (e < ee) { const t=(e-es)/350; sevx=4; sevy=4-eio(t); }  // (4,4)→(4,3) vertical
      else { sevx = 4; sevy = 3; }
    }

    // Shell→barrier
    const shellAlpha = e >= BOUNCE_E ? Math.max(0, 1 - eio(Math.min(1,(e-BOUNCE_E)/200))*2) : 1;
    const barrierVisible = e >= BOUNCE_E;
    const barrierFlashAlpha = e >= BOUNCE_E && e < TRANSFORM
      ? Math.sin(((e-BOUNCE_E)/(TRANSFORM-BOUNCE_E)) * Math.PI * 2) * 0.5
      : 0;
    const plusAlpha = e >= BOUNCE_E && e < BOUNCE_E+500
      ? Math.sin(((e-BOUNCE_E)/500) * Math.PI)
      : 0;

    const sharkMovesDone = e < M1 ? 0 : e < BOUNCE_S ? 1 : e < M3 ? 2 : e < M4 ? 3 : 4;
    updateMovePips(sharkMovesDone);

    miniBackground(ctx, 2);
    // Ambient coral barriers to establish depth-2 feel
    miniDrawCoral(ctx, 0, 4);
    miniDrawCoral(ctx, 2, 4);
    [[1,0],[4,1],[0,3],[3,4]].forEach(([c,r]) => miniDrawCoin(ctx, c, r));

    if (barrierVisible) {
      miniDrawCoral(ctx, 2, 2);
      if (barrierFlashAlpha > 0) {
        ctx.save(); ctx.globalAlpha = barrierFlashAlpha;
        ctx.fillStyle = "#daa070";
        ctx.fillRect(2*MINI_CS+2, 2*MINI_CS+2, MINI_CS-4, MINI_CS-4);
        ctx.restore();
      }
    }
    if (shellAlpha > 0) miniDrawCoralShell(ctx, 2, 2, shellAlpha);
    if (plusAlpha > 0) miniDrawLabel(ctx, 2, 2, "+5 PTS", plusAlpha);
    if (spawnedAlpha > 0) miniDrawEnemy(ctx, sevx, sevy, spawnedAlpha);
    miniDrawEnemy(ctx, evx, evy, 1);
    miniDrawShark(ctx, svx, svy, sdir);

    if (e < M1) setMiniCaption("THE CORAL SHELL BLOCKS THE PATH...");
    else if (e < BOUNCE_S) setMiniCaption("MOVE 1 — ENEMY WAITS...");
    else if (e < BOUNCE_E) setMiniCaption("MOVE 2 — CAN'T BE COLLECTED!");
    else if (e < TRANSFORM) setMiniCaption("+5 PTS — SHELL HARDENS INTO A WALL!");
    else if (e < SPAWN_E) setMiniCaption("A NEW ENEMY RELEASED...");
    else if (e < M3E) setMiniCaption("MOVE 3 — NAVIGATE AROUND THE BARRIER...");
    else if (e < M4E) setMiniCaption("MOVE 4 — ENEMY ADVANCES AGAIN!");
    else setMiniCaption("BARRIERS RESHAPE THE REEF PERMANENTLY");
  }

  // ── Depth 3 placeholder ──────────────────────────────────────────
  function renderD3(ctx: CanvasRenderingContext2D, _e: number) {
    // Dark version of the tile grid
    ctx.fillStyle = "#040f1a";
    ctx.fillRect(0, 0, 200, 200);
    for (let r = 0; r < MINI_N; r++) {
      for (let c = 0; c < MINI_N; c++) {
        ctx.globalAlpha = 0.35;
        ctx.fillStyle = MINI_TILE_COLORS_D1[r*MINI_N+c];
        ctx.fillRect(c*MINI_CS, r*MINI_CS, MINI_CS, MINI_CS);
      }
    }
    ctx.globalAlpha = 1;
    ctx.save();
    ctx.font = "bold 52px monospace";
    ctx.fillStyle = "rgba(157,111,224,0.4)";
    ctx.textAlign = "center"; ctx.textBaseline = "middle";
    ctx.fillText("?", 100, 100);
    ctx.restore();
    setMiniCaption("DEPTH 3 IS UNCHARTED TERRITORY...");
    updateMovePips(0);
  }

  // ── Rules content ────────────────────────────────────────────────
  const DEPTH_RULES: Record<number, Array<{key: string; val: string; keyColor?: string}>> = {
    1: [
      { key: "ENEMIES",   val: "MOVE 1 STEP EVERY 2 PLAYER MOVES" },
      { key: "COINS",     val: "+1 PT — SPAWNS 1 ENEMY" },
      { key: "AMMONITE",  val: "+10 PTS — SPAWNS BIG 2×2 ENEMY", keyColor: "#9b59e0" },
      { key: "DESCEND",   val: "REACH 100 PTS" },
    ],
    2: [
      { key: "ENEMIES",   val: "MOVE 1 STEP EVERY 2 PLAYER MOVES" },
      { key: "COINS",     val: "+1 PT — SPAWNS 1 ENEMY" },
      { key: "CORAL",     val: "+5 PTS — CONVERTS TO BARRIER — SPAWNS 1 ENEMY", keyColor: "#daa070" },
      { key: "BARRIERS",  val: "PERMANENT IMPASSABLE WALLS" },
      { key: "ON ENTRY",  val: "ENEMIES RESET TO 5 FARTHEST FROM YOU" },
      { key: "DESCEND",   val: "REACH 200 PTS" },
    ],
    3: [
      { key: "STATUS",    val: "THIS DEPTH IS NOT YET CHARTED." },
      { key: "LEVIATHAN", val: "A 3×3 MEGA ENEMY — MOVE RATE TBD", keyColor: "#9d6fe0" },
      { key: "SHELL",     val: "PIECE AND PARAMETERS TBD" },
    ],
  };

  function buildRulesHTML(depth: number): string {
    const meta = DEPTH_META[depth] ?? DEPTH_META[1];
    const rows = DEPTH_RULES[depth] ?? [];
    const html = rows.map(r => {
      const kc = r.keyColor ?? meta.color;
      return `<div class="depth-rule-row"><span class="depth-rule-key" style="color:${kc}">${r.key}</span><span class="depth-rule-val">${r.val}</span></div>`;
    }).join("");
    return `<div class="depth-rules-section-label">► RULES</div>${html}`;
  }

  // ── Open / Close ─────────────────────────────────────────────────
  const MINI_OPEN_CAPTIONS: Record<number, string> = {
    1: "FIND THE PURPLE AMMONITE",
    2: "THE CORAL SHELL BLOCKS THE PATH...",
    3: "DEPTH 3 IS UNCHARTED TERRITORY...",
  };

  function openDepthInfo(depth: number) {
    miniDepth = depth;
    miniElapsed = 0; miniPlaying = false; miniDone = false;
    if (miniRaf) { cancelAnimationFrame(miniRaf); miniRaf = null; }

    const meta = DEPTH_META[depth] ?? DEPTH_META[1];
    (document.getElementById("depthInfoBadge") as HTMLElement).textContent = `DEPTH ${depth}`;
    (document.getElementById("depthInfoBadge") as HTMLElement).style.color = meta.color;
    (document.getElementById("depthInfoName") as HTMLElement).textContent = meta.name;
    (document.getElementById("depthInfoPanel") as HTMLElement).style.borderColor = meta.color;
    (document.getElementById("depthInfoRules") as HTMLElement).innerHTML = buildRulesHTML(depth);

    // Apply depth color to scene ctrl buttons
    ["depthScenePlay","depthScenePause","depthSceneReset"].forEach(id => {
      const el = document.getElementById(id) as HTMLElement;
      el.style.borderColor = meta.color;
      el.style.color = meta.color;
    });

    updateMovePips(0);
    renderMiniScene(depth, 0);
    setMiniCaption(MINI_OPEN_CAPTIONS[depth] ?? "");
    syncMiniControls();
    document.getElementById("depthInfoOverlay")!.classList.add("visible");
  }

  function closeDepthInfo() {
    if (miniRaf) { cancelAnimationFrame(miniRaf); miniRaf = null; }
    miniPlaying = false;
    document.getElementById("depthInfoOverlay")!.classList.remove("visible");
  }

  function syncMiniControls() {
    const play  = document.getElementById("depthScenePlay")!  as HTMLButtonElement;
    const pause = document.getElementById("depthScenePause")! as HTMLButtonElement;
    const reset = document.getElementById("depthSceneReset")! as HTMLButtonElement;
    if (miniDone) {
      play.style.display = "none"; pause.style.display = "none"; reset.style.display = "inline-flex";
    } else if (miniPlaying) {
      play.style.display = "none"; pause.style.display = "inline-flex"; reset.style.display = "none";
    } else {
      play.style.display = "inline-flex"; pause.style.display = "none";
      reset.style.display = miniElapsed > 0 ? "inline-flex" : "none";
    }
  }

  // ── Button wiring ────────────────────────────────────────────────
  hudDepthBtn.addEventListener("click", () => openDepthInfo(currentDepth));
  document.getElementById("depthInfoClose")!.addEventListener("click", closeDepthInfo);
  document.getElementById("depthInfoOverlay")!.addEventListener("click", (e) => {
    if (e.target === e.currentTarget) closeDepthInfo();
  });

  document.getElementById("depthScenePlay")!.addEventListener("click", () => {
    if (miniDone) return;
    miniPlaying = true; miniLastTick = performance.now();
    miniRaf = requestAnimationFrame(miniTick);
    syncMiniControls();
  });

  document.getElementById("depthScenePause")!.addEventListener("click", () => {
    if (!miniPlaying) return;
    miniPlaying = false;
    if (miniRaf) { cancelAnimationFrame(miniRaf); miniRaf = null; }
    syncMiniControls();
  });

  document.getElementById("depthSceneReset")!.addEventListener("click", () => {
    if (miniRaf) { cancelAnimationFrame(miniRaf); miniRaf = null; }
    miniElapsed = 0; miniPlaying = false; miniDone = false;
    updateMovePips(0);
    renderMiniScene(miniDepth, 0);
    setMiniCaption(MINI_OPEN_CAPTIONS[miniDepth] ?? "");
    syncMiniControls();
  });

  // ===== Dev Panel =====
  (function buildDevPanel() {
    const container = document.getElementById("devJumpBtns")!;
    const depths = [
      { label: "DEPTH 1", depth: 1, color: "#48cae4" },
      { label: "DEPTH 2", depth: 2, color: "#daa070" },
      { label: "DEPTH 3", depth: 3, color: "#9d6fe0" },
    ];
    depths.forEach(({ label, depth, color }) => {
      const btn = document.createElement("button");
      btn.textContent = label;
      btn.style.borderColor = color;
      btn.style.color = color;
      btn.addEventListener("click", () => {
        clearSave();
        initAtDepth(depth);
        showScreen("game");
      });
      container.appendChild(btn);
    });
  })();

  // ===== Startup =====  →  SharkThiefApp.swift

  // Draw splash shark
  const splashCanvas = document.getElementById(
    "splashSharkCanvas",
  ) as HTMLCanvasElement;
  if (splashCanvas) {
    const splashCtx = splashCanvas.getContext("2d")!;
    drawSharkOnCtx(splashCtx, 0, 0, splashCanvas.width, "right");
  }

  // Animate menu shark — breathing scale + vertical bob + tail wag
  const menuSharkCanvas = document.getElementById(
    "menuSharkCanvas",
  ) as HTMLCanvasElement;
  if (menuSharkCanvas) {
    const menuCtx = menuSharkCanvas.getContext("2d")!;
    const mw = menuSharkCanvas.width;
    const mh = menuSharkCanvas.height;
    let mt = 0;
    function menuSharkFrame() {
      mt += 0.032;
      menuCtx.clearRect(0, 0, mw, mh);
      menuCtx.save();
      // Breathing: subtle scale pulse centred on canvas
      const breathe = 1 + 0.028 * Math.sin(mt * 1.3);
      menuCtx.translate(mw / 2, mh / 2);
      menuCtx.scale(breathe, breathe);
      menuCtx.translate(-mw / 2, -mh / 2);
      // Gentle vertical float
      menuCtx.translate(0, Math.sin(mt * 0.75) * 3);
      // Tail lobes counter-oscillate at a different frequency
      const tailWag = Math.sin(mt * 2.4) * 0.85;
      drawSharkOnCtx(menuCtx, 0, 0, mw, "right", tailWag);
      menuCtx.restore();
      requestAnimationFrame(menuSharkFrame);
    }
    requestAnimationFrame(menuSharkFrame);
  }

  // Init main menu state (best score + save/depth buttons)
  refreshMenuState();
</script>

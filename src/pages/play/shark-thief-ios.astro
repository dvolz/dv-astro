    try {
      const res = await fetch(`/api/scores?map=${currentMap}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name, score }),
      });
      if (!res.ok) {
        submitStatus.textContent = "FAILED — TRY AGAIN";
        submitScoreBtn.disabled = false;
        return;
      }
      const scores = await res.json();
      const submitted = scores.find(
        (s: any) => s.name === name && s.score === score && s.date,
      );
      lastSubmittedDate = submitted?.date || null;
      renderLeaderboard(scores);
      lastSubmittedDate = null;
      submitStatus.textContent = "SCORE SUBMITTED!";

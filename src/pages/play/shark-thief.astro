---
import BaseLayout from '../../layouts/BaseLayout.astro'
import BlogDetails from '../../components/BlogDetails.astro'

export const blogData = {
	title: 'Shark Thief',
	author: 'David Volz',
	description:
		"A browser game built from a kid's prompt — sharks, bad guys, and yellow squares.",
	image: {
		url: 'https://docs.astro.build/assets/arc.webp',
		alt: 'The Astro logo on a dark background with a purple gradient arc.',
	},
	pubDate: '2026-3-14',
	tags: ['javascript', 'code', 'fluff'],
	featured: true,
	display: true,
}

const showTypographyHero = true
const fullWidthBody = true
---

<style lang="scss">
	/* ── Game ── */
	.game-wrapper {
		max-width: 80rem;
		margin: 0 auto;
		padding: 0 2rem;
		text-align: center;
		overflow-x: hidden;
	}
	.game-hud {
		display: flex;
		justify-content: center;
		gap: 3rem;
		margin: 0 0 1.5rem;
		font-family: var(--a-font);
		font-size: 1.6rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		span span {
			color: #5dade2;
			font-size: 2rem;
			font-weight: 800;
			letter-spacing: 0.04em;
		}
	}
	.game-canvas-wrapper {
		display: inline-block;
		border: 2px solid var(--text-color);
		border-radius: 0.4rem;
		line-height: 0;
	}
	canvas {
		display: block;
		max-width: 100%;
		height: auto;
		image-rendering: pixelated;
		touch-action: none;
	}
	.game-instructions {
		margin: 0 auto 2.5rem;
		max-width: 44rem;
		padding: 1.6rem 2rem;
		border: 1px solid rgba(128, 128, 128, 0.15);
		border-radius: 0.6rem;
		text-align: left;
		line-height: 1.8;
		font-size: 1.4rem;
	}
	.game-instructions .how-to-play {
		font-family: var(--a-font);
		font-weight: 700;
		font-size: 1.2rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		opacity: 0.5;
		margin: 0 0 0.6rem;
	}
	.game-instructions ol {
		margin: 0;
		padding-left: 2rem;
		list-style: decimal;
	}
	.game-instructions li {
		margin-bottom: 0.3rem;
		font-family: var(--p-font);
	}
	.game-instructions li strong {
		font-weight: 700;
	}
	.game-instructions .controls-note {
		margin: 0.8rem 0 0;
		font-size: 1.2rem;
		opacity: 0.55;
		font-family: var(--a-font);
	}

	/* ── Game Over Overlay ── */
	.game-over-overlay {
		position: absolute;
		inset: 0;
		display: none;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		background: rgba(0, 0, 0, 0.85);
		z-index: 10;
		border-radius: 0.4rem;
	}
	.game-over-overlay.visible {
		display: flex;
	}
	.game-over-overlay h2 {
		font-family: var(--a-font);
		font-size: 4rem;
		color: #e74c3c;
		margin: 0 0 0.5rem;
	}
	.game-over-overlay .final-score {
		font-family: var(--a-font);
		font-size: 2rem;
		color: #fff;
		margin: 0 0 2rem;
	}
	.game-over-overlay .game-over-buttons {
		display: flex;
		gap: 1.5rem;
	}
	.game-over-overlay button,
	.game-over-overlay a {
		font-family: var(--a-font);
		font-size: 1.6rem;
		font-weight: 600;
		padding: 0.8rem 2.5rem;
		border: 1px solid #fff;
		border-radius: 0.6rem;
		background: none;
		color: #fff;
		cursor: pointer;
		text-decoration: none;
		transition: all 0.3s ease;
		&:hover {
			background: #fff;
			color: #000;
		}
	}

	.game-canvas-container {
		position: relative;
		display: inline-block;
		max-width: 100%;
	}

	/* ── DOS-style prompt ── */
	.prompt-terminal {
		max-width: 60rem;
		margin: 0 auto 3rem;
		border: 1px solid rgba(93, 173, 226, 0.3);
		border-radius: 0.6rem;
		overflow: hidden;
		background: #0c1421;
		box-shadow: 0 0 24px rgba(93, 173, 226, 0.06);
	}
	.prompt-titlebar {
		background: rgba(93, 173, 226, 0.12);
		border-bottom: 1px solid rgba(93, 173, 226, 0.2);
		padding: 0.5rem 1.2rem;
		display: flex;
		align-items: center;
		gap: 0.6rem;
	}
	.prompt-dot {
		width: 0.8rem;
		height: 0.8rem;
		border-radius: 50%;
		&:nth-child(1) {
			background: #e74c3c;
		}
		&:nth-child(2) {
			background: #f39c12;
		}
		&:nth-child(3) {
			background: #2ecc71;
		}
	}
	.prompt-titlebar span:last-child {
		font-family: var(--a-font);
		font-size: 1rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: rgba(93, 173, 226, 0.6);
		margin-left: auto;
	}
	.prompt-body {
		padding: 1.6rem 2rem;
		font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', 'Menlo', monospace;
		font-size: 1.3rem;
		line-height: 1.7;
		color: #a8c7e2;
	}
	.prompt-label {
		color: #5dade2;
		font-weight: 700;
	}
	.prompt-cursor {
		display: inline-block;
		width: 0.7rem;
		height: 1.4rem;
		background: #5dade2;
		margin-left: 0.3rem;
		vertical-align: text-bottom;
		animation: blink 1s step-end infinite;
	}
	@keyframes blink {
		50% {
			opacity: 0;
		}
	}

	/* ── Name Input on Game Over ── */
	.submit-prompt {
		margin: 0 0 1.2rem;
	}
	.submit-prompt button {
		font-family: var(--a-font);
		font-size: 1.5rem;
		font-weight: 600;
		padding: 0.6rem 2rem;
		border: 1px solid #5dade2;
		border-radius: 0.4rem;
		background: none;
		color: #5dade2;
		cursor: pointer;
		transition: all 0.3s ease;
		&:hover {
			background: #5dade2;
			color: #000;
		}
	}
	.name-input-row {
		display: none;
		gap: 0.8rem;
		margin: 0 0 1.5rem;
		&.visible {
			display: flex;
		}
	}
	.name-input-row input {
		font-family: var(--a-font);
		font-size: 1.5rem;
		padding: 0.6rem 1rem;
		border: 1px solid #fff;
		border-radius: 0.4rem;
		background: rgba(255, 255, 255, 0.1);
		color: #fff;
		width: 14rem;
		outline: none;
		&::placeholder {
			color: rgba(255, 255, 255, 0.5);
		}
	}
	.name-input-row button {
		font-family: var(--a-font);
		font-size: 1.4rem;
		font-weight: 600;
		padding: 0.6rem 1.5rem;
		border: 1px solid #fff;
		border-radius: 0.4rem;
		background: none;
		color: #fff;
		cursor: pointer;
		transition: all 0.3s ease;
		&:hover {
			background: #fff;
			color: #000;
		}
		&:disabled {
			opacity: 0.4;
			cursor: default;
		}
	}
	.submit-status {
		font-size: 1.3rem;
		color: #5dade2;
		margin: 0 0 1rem;
		min-height: 1.6rem;
	}

	/* ── Mobile D-Pad ── */
	.dpad {
		display: none;
		margin: 1.5rem auto 0;
		width: 30rem;
		-webkit-user-select: none;
		user-select: none;
		touch-action: none;
	}
	@media (pointer: coarse) {
		.dpad {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			grid-template-rows: repeat(3, 1fr);
			gap: 0.4rem;
		}
	}
	.dpad-btn {
		appearance: none;
		width: 100%;
		aspect-ratio: 1;
		border: 2px solid var(--text-color);
		border-radius: 50%;
		background: transparent;
		color: var(--text-color);
		line-height: 1;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.2s ease;
		-webkit-tap-highlight-color: transparent;
		touch-action: none;
		min-height: 8rem;
		min-width: 8rem;
		svg {
			width: 2.6rem;
			height: 2.6rem;
			fill: none;
			stroke: var(--text-color);
			stroke-width: 2.5;
			stroke-linejoin: round;
			stroke-linecap: round;
			transition:
				fill 0.15s ease,
				stroke 0.15s ease;
		}
		&.pressed,
		&:active {
			transform: scale(0.92);
			svg {
				fill: var(--highlight-secondary);
				stroke: var(--highlight-secondary);
			}
		}
	}
	.dpad-up {
		grid-column: 2;
		grid-row: 1;
	}
	.dpad-left {
		grid-column: 1;
		grid-row: 2;
	}
	.dpad-right {
		grid-column: 3;
		grid-row: 2;
	}
	.dpad-down {
		grid-column: 2;
		grid-row: 3;
	}
	.dpad-center {
		grid-column: 2;
		grid-row: 2;
		border: none;
		background: none;
		pointer-events: none;
	}
	.touch-hint {
		display: none;
	}
	@media (pointer: coarse) {
		.touch-hint {
			display: inline;
		}
	}
</style>

<style is:global lang="scss">
	$subtle: rgba(128, 128, 128, 0.15);

	.leaderboard {
		max-width: 72rem;
		margin: 3rem auto 0;
		padding: 0 2rem;
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
	}
	.leaderboard h3 {
		font-family: var(--a-font);
		font-size: 2.2rem;
		font-weight: 800;
		text-align: center;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		margin: 0 0 1.6rem;
		opacity: 0.75;
	}
	.leaderboard table {
		width: 100%;
		min-width: 44rem;
		border-collapse: collapse;
		table-layout: fixed;
		border: 1px solid $subtle;
		border-radius: 0.6rem;
		overflow: hidden;
	}

	/* ── All cells get subtle borders ── */
	.leaderboard th,
	.leaderboard td {
		padding: 0.8rem 1rem;
		border: 1px solid $subtle;
		vertical-align: middle;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	/* ── Header row ── */
	.leaderboard thead th {
		font-family: var(--a-font);
		font-weight: 600;
		font-size: 1rem;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--text-color);
		opacity: 0.5;
		background: rgba(128, 128, 128, 0.06);
		border-bottom: 2px solid $subtle;
		white-space: nowrap;
	}

	/* ── Row striping ── */
	.leaderboard tbody tr {
		transition: background 0.15s ease;
	}
	.leaderboard tbody tr:nth-child(even) {
		background: rgba(128, 128, 128, 0.04);
	}
	.leaderboard tbody tr:hover {
		background: rgba(128, 128, 128, 0.09);
	}

	/* ── Rank column ── */
	.leaderboard th:nth-child(1),
	.leaderboard td:nth-child(1) {
		width: 5.5rem;
		text-align: center;
		font-family: var(--a-font);
		font-weight: 800;
		font-size: 1.4rem;
		opacity: 0.4;
		overflow: visible;
	}
	/* Top 3 medal styling */
	.leaderboard tbody tr:nth-child(1) td:nth-child(1),
	.leaderboard tbody tr:nth-child(2) td:nth-child(1),
	.leaderboard tbody tr:nth-child(3) td:nth-child(1) {
		opacity: 1;
	}
	.medal {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3rem;
		height: 3rem;
		border-radius: 50%;
		font-family: var(--a-font);
		font-weight: 900;
		font-size: 1.4rem;
		line-height: 1;
		box-shadow: inset 0 -2px 4px rgba(0, 0, 0, 0.15);
	}
	.medal-gold {
		background: linear-gradient(145deg, #f7dc6f, #d4a017);
		color: #5c4300;
		border: 2px solid #c9960c;
	}
	.medal-silver {
		background: linear-gradient(145deg, #d5d5d5, #a0a0a0);
		color: #4a4a4a;
		border: 2px solid #909090;
	}
	.medal-bronze {
		background: linear-gradient(145deg, #dea06e, #b87333);
		color: #5a3510;
		border: 2px solid #a0612a;
	}

	/* ── Name column ── */
	.leaderboard th:nth-child(2),
	.leaderboard td:nth-child(2) {
		text-align: left;
		font-family: var(--p-font);
		font-size: 1.5rem;
		font-weight: 600;
		letter-spacing: 0.01em;
	}

	/* ── Score column ── */
	.leaderboard th:nth-child(3),
	.leaderboard td:nth-child(3) {
		width: 9rem;
		text-align: center;
		font-family: var(--a-font);
		font-weight: 800;
		font-size: 1.6rem;
		letter-spacing: 0.04em;
		color: #5dade2;
	}

	/* ── Date column ── */
	.leaderboard th:nth-child(4),
	.leaderboard td:nth-child(4) {
		width: 16rem;
		text-align: right;
		font-family: var(--a-font);
		font-size: 1.15rem;
		font-weight: 400;
		color: var(--text-color);
		opacity: 0.5;
		white-space: nowrap;
		font-style: italic;
	}

	.leaderboard .empty-board {
		text-align: center;
		opacity: 0.4;
		padding: 2.5rem 0;
		font-family: var(--p-font);
		font-style: italic;
		font-size: 1.4rem;
	}

	/* ── Highlight row (submitted score) ── */
	.leaderboard tr.highlight {
		background: rgba(93, 173, 226, 0.1) !important;
		animation: highlight-flash 2s ease-out;
		td {
			opacity: 1;
		}
		td:nth-child(2) {
			color: #5dade2;
		}
		td:nth-child(3) {
			color: #3498db;
			font-weight: 900;
		}
	}
	@keyframes highlight-flash {
		0% {
			background: rgba(93, 173, 226, 0.28);
		}
		100% {
			background: rgba(93, 173, 226, 0.08);
		}
	}
</style>

<BaseLayout
	pageTitle={blogData.title}
	{showTypographyHero}
	description={blogData.description}
	fullWidthBody={fullWidthBody}>
	<div class="details-width">
		<BlogDetails {...blogData} />
	</div>

	<div class="game-wrapper">
		<div class="prompt-terminal">
			<div class="prompt-titlebar">
				<span class="prompt-dot"></span>
				<span class="prompt-dot"></span>
				<span class="prompt-dot"></span>
				<span>prompt.txt</span>
			</div>
			<div class="prompt-body">
				<span class="prompt-label">son@home ~$</span> describe your game<br />
				<br />
				Screen with a shark you can move using arrow keys or WASD. You start in a
				random spot on a 30 by 30 unit room. Each unit is a random color. By clicking
				the button, you go one space. A smaller yellow square appears in 5% of the
				squares and spawns randomly 1 in 1000 of the time in each square every time
				the shark moves. The &apos;bad guy&apos; is a black square that moves 1 square
				towards you every 2 times you move. When you go on a square with the smaller
				yellow square, another &apos;bad guy&apos; spawns in a random square to get
				you. If the &apos;bad guy&apos; gets to you, you&apos;re out. The game has
				a high score counter for the number of yellow squares you get. When you&apos;re
				out it says &apos;YOU DIED&apos; and has a play again option, or a home option.<span
					class="prompt-cursor"></span>
			</div>
		</div>

		<div class="game-instructions">
			<p class="how-to-play">How to Play</p>
			<ol>
				<li><strong>Move</strong> your shark around the board</li>
				<li><strong>Collect</strong> the yellow squares to score points</li>
				<li><strong>Avoid</strong> the black squares — they chase you</li>
				<li>Each pickup spawns a new enemy — survive as long as you can</li>
			</ol>
			<p class="controls-note">
				Arrow keys or WASD to move<span class="touch-hint">
					· D-pad on mobile</span
				>
			</p>
		</div>

		<div class="game-hud">
			<span>Score: <span id="score">0</span></span>
			<span>High Score: <span id="highScore">0</span></span>
		</div>

		<div class="game-canvas-container">
			<canvas id="gameCanvas" width="600" height="600"></canvas>
			<div class="game-over-overlay" id="gameOverOverlay">
				<h2>YOU DIED</h2>
				<p class="final-score">Score: <span id="finalScore">0</span></p>
				<div class="submit-prompt" id="submitPrompt">
					<button id="wantToSubmitBtn">Submit Score?</button>
				</div>
				<div class="name-input-row" id="nameInputRow">
					<input
						type="text"
						id="playerName"
						placeholder="Your name"
						maxlength="20"
					/>
					<button id="submitScoreBtn">Submit</button>
				</div>
				<p class="submit-status" id="submitStatus"></p>
				<div class="game-over-buttons">
					<button id="playAgainBtn">Play Again</button>
					<a href="/">Home</a>
				</div>
			</div>
		</div>

		<div class="dpad" id="dpad">
			<button class="dpad-btn dpad-up" data-dir="up" aria-label="Move up"
				><svg viewBox="0 0 24 24"><path d="M12 5 L22 19 L2 19 Z"></path></svg
				></button
			>
			<button class="dpad-btn dpad-left" data-dir="left" aria-label="Move left"
				><svg viewBox="0 0 24 24"><path d="M5 12 L19 2 L19 22 Z"></path></svg
				></button
			>
			<div class="dpad-center"></div>
			<button
				class="dpad-btn dpad-right"
				data-dir="right"
				aria-label="Move right"
				><svg viewBox="0 0 24 24"><path d="M19 12 L5 2 L5 22 Z"></path></svg
				></button
			>
			<button class="dpad-btn dpad-down" data-dir="down" aria-label="Move down"
				><svg viewBox="0 0 24 24"><path d="M12 19 L2 5 L22 5 Z"></path></svg
				></button
			>
		</div>
	</div>

	<div class="leaderboard" id="leaderboard">
		<h3>Leaderboard</h3>
		<table>
			<thead><tr><th>#</th><th>Name</th><th>Score</th><th>Date</th></tr></thead>
			<tbody id="leaderboardBody">
				<tr><td colspan="4" class="empty-board">Loading…</td></tr>
			</tbody>
		</table>
	</div>
</BaseLayout>

<script>
	const GRID = 30
	const canvas = document.getElementById('gameCanvas') as HTMLCanvasElement
	const ctx = canvas.getContext('2d')!
	const CELL = canvas.width / GRID

	const scoreEl = document.getElementById('score')!
	const highScoreEl = document.getElementById('highScore')!
	const finalScoreEl = document.getElementById('finalScore')!
	const overlay = document.getElementById('gameOverOverlay')!
	const playAgainBtn = document.getElementById('playAgainBtn')!
	const submitScoreBtn = document.getElementById(
		'submitScoreBtn'
	)! as HTMLButtonElement
	const playerNameInput = document.getElementById(
		'playerName'
	)! as HTMLInputElement
	const submitStatus = document.getElementById('submitStatus')!
	const nameInputRow = document.getElementById('nameInputRow')!
	const leaderboardBody = document.getElementById('leaderboardBody')!

	let highScore = parseInt(localStorage.getItem('sharkHighScore') || '0', 10)
	highScoreEl.textContent = String(highScore)

	// ── State ──
	interface Enemy {
		x: number
		y: number
	}

	let colors: string[][] = []
	let pickups: boolean[][] = []
	let enemies: Enemy[] = []
	let shark = { x: 0, y: 0 }
	let sharkDir = 'right' // tracks last movement direction
	let score = 0
	let moveCount = 0
	let gameOver = false

	// Curated palette — distinct hues with consistent lightness,
	// chosen so none clash with yellow pickups, black enemies, or the blue shark.
	const TILE_COLORS = [
		'#7ca6b3', // steel blue
		'#8fae7e', // sage green
		'#b58dac', // muted plum
		'#c49880', // warm tan
		'#6d9e9e', // teal
		'#a3887e', // mauve brown
		'#8e9fc0', // periwinkle
		'#9caa6c', // olive
		'#b08f9f', // dusty rose
		'#7b9a84', // fern
	]

	function randomTileColor(): string {
		return TILE_COLORS[Math.floor(Math.random() * TILE_COLORS.length)]
	}

	function init() {
		score = 0
		moveCount = 0
		gameOver = false
		scoreEl.textContent = '0'
		overlay.classList.remove('visible')

		// Random colors
		colors = Array.from({ length: GRID }, () =>
			Array.from({ length: GRID }, () => randomTileColor())
		)

		// Pickups — 5% on init
		pickups = Array.from({ length: GRID }, () =>
			Array.from({ length: GRID }, () => Math.random() < 0.05)
		)

		// Shark starts at random spot
		shark.x = Math.floor(Math.random() * GRID)
		shark.y = Math.floor(Math.random() * GRID)

		// Make sure shark doesn't start on a pickup
		pickups[shark.y][shark.x] = false

		// One initial enemy
		enemies = [spawnEnemy()]

		draw()
	}

	function spawnEnemy(): Enemy {
		const MIN_DIST = 5
		let ex: number, ey: number
		do {
			ex = Math.floor(Math.random() * GRID)
			ey = Math.floor(Math.random() * GRID)
		} while (
			Math.abs(ex - shark.x) + Math.abs(ey - shark.y) < MIN_DIST ||
			enemies.some((e) => e.x === ex && e.y === ey)
		)
		return { x: ex, y: ey }
	}

	// ── Drawing ──

	function draw() {
		// Grid cells
		for (let r = 0; r < GRID; r++) {
			for (let c = 0; c < GRID; c++) {
				ctx.fillStyle = colors[r][c]
				ctx.fillRect(c * CELL, r * CELL, CELL, CELL)
			}
		}

		// Pickups (smaller yellow squares with dark outline for contrast)
		const pad = CELL * 0.22
		for (let r = 0; r < GRID; r++) {
			for (let c = 0; c < GRID; c++) {
				if (pickups[r][c]) {
					const px = c * CELL + pad
					const py = r * CELL + pad
					const ps = CELL - pad * 2
					// Dark outline
					ctx.fillStyle = '#7a6200'
					ctx.fillRect(px - 1, py - 1, ps + 2, ps + 2)
					// Yellow fill
					ctx.fillStyle = '#f1c40f'
					ctx.fillRect(px, py, ps, ps)
				}
			}
		}

		// Enemies (dark squares with red outline for visibility)
		for (const e of enemies) {
			ctx.fillStyle = '#c0392b'
			ctx.fillRect(e.x * CELL - 1, e.y * CELL - 1, CELL + 2, CELL + 2)
			ctx.fillStyle = '#1a1a1a'
			ctx.fillRect(e.x * CELL, e.y * CELL, CELL, CELL)
		}

		// Shark 🦈 — draw a simple shark shape
		drawShark(shark.x, shark.y)
	}

	function drawShark(cx: number, cy: number) {
		const x = cx * CELL
		const y = cy * CELL
		const w = CELL
		const h = CELL

		ctx.save()

		// Flip/rotate shark to face movement direction
		const centerX = x + w / 2
		const centerY = y + h / 2
		ctx.translate(centerX, centerY)
		switch (sharkDir) {
			case 'right':
				// default orientation, no transform
				break
			case 'left':
				ctx.scale(-1, 1) // mirror horizontally
				break
			case 'down':
				ctx.rotate(Math.PI / 2)
				break
			case 'up':
				ctx.rotate(-Math.PI / 2)
				break
		}
		ctx.translate(-centerX, -centerY)

		// Glow / highlight behind the shark
		ctx.shadowColor = '#ffffff'
		ctx.shadowBlur = 12

		// White outline for contrast on any background
		ctx.strokeStyle = '#fff'
		ctx.lineWidth = 1

		// Body
		ctx.fillStyle = '#2980b9'
		ctx.beginPath()
		ctx.ellipse(x + w / 2, y + h / 2, w * 0.45, h * 0.35, 0, 0, Math.PI * 2)
		ctx.fill()
		ctx.stroke()

		// Reset shadow so fins/tail don't double-glow
		ctx.shadowBlur = 0

		// Dorsal fin
		ctx.fillStyle = '#1a5276'
		ctx.beginPath()
		ctx.moveTo(x + w * 0.4, y + h * 0.08)
		ctx.lineTo(x + w * 0.48, y + h * 0.38)
		ctx.lineTo(x + w * 0.62, y + h * 0.35)
		ctx.closePath()
		ctx.fill()
		ctx.stroke()

		// Tail
		ctx.fillStyle = '#1a5276'
		ctx.beginPath()
		ctx.moveTo(x + w * 0.05, y + h * 0.35)
		ctx.lineTo(x - w * 0.1, y + h * 0.15)
		ctx.lineTo(x - w * 0.1, y + h * 0.7)
		ctx.lineTo(x + w * 0.05, y + h * 0.55)
		ctx.closePath()
		ctx.fill()
		ctx.stroke()

		// Belly (lighter underside)
		ctx.fillStyle = '#d6eaf8'
		ctx.beginPath()
		ctx.ellipse(x + w / 2, y + h * 0.58, w * 0.32, h * 0.12, 0, 0, Math.PI)
		ctx.fill()

		// Mouth line
		ctx.strokeStyle = '#1a5276'
		ctx.lineWidth = 1
		ctx.beginPath()
		ctx.moveTo(x + w * 0.55, y + h * 0.58)
		ctx.lineTo(x + w * 0.85, y + h * 0.52)
		ctx.stroke()

		// Eye
		ctx.fillStyle = '#fff'
		ctx.beginPath()
		ctx.arc(x + w * 0.65, y + h * 0.38, w * 0.09, 0, Math.PI * 2)
		ctx.fill()
		ctx.strokeStyle = '#1a5276'
		ctx.lineWidth = 1
		ctx.stroke()
		ctx.fillStyle = '#000'
		ctx.beginPath()
		ctx.arc(x + w * 0.67, y + h * 0.38, w * 0.045, 0, Math.PI * 2)
		ctx.fill()

		ctx.restore()
	}

	// ── Game Logic ──

	function moveShark(dx: number, dy: number) {
		if (gameOver) return

		const nx = shark.x + dx
		const ny = shark.y + dy
		if (nx < 0 || nx >= GRID || ny < 0 || ny >= GRID) return

		shark.x = nx
		shark.y = ny
		moveCount++

		// Track facing direction
		if (dx === 1) sharkDir = 'right'
		else if (dx === -1) sharkDir = 'left'
		else if (dy === 1) sharkDir = 'down'
		else if (dy === -1) sharkDir = 'up'

		// Check pickup
		if (pickups[ny][nx]) {
			pickups[ny][nx] = false
			score++
			scoreEl.textContent = String(score)
			// Spawn a new enemy
			enemies.push(spawnEnemy())
		}

		// Spawn new pickups — 1/4000 chance per cell
		for (let r = 0; r < GRID; r++) {
			for (let c = 0; c < GRID; c++) {
				if (!pickups[r][c] && Math.random() < 0.00025) {
					pickups[r][c] = true
				}
			}
		}

		// Enemies move every 2 player moves
		if (moveCount % 2 === 0) {
			for (const e of enemies) {
				const diffX = shark.x - e.x
				const diffY = shark.y - e.y
				let nx = e.x
				let ny = e.y
				if (Math.abs(diffX) >= Math.abs(diffY)) {
					nx += Math.sign(diffX)
				} else {
					ny += Math.sign(diffY)
				}
				// Only move if no other enemy is already on that square
				const occupied = enemies.some(
					(other) => other !== e && other.x === nx && other.y === ny
				)
				if (!occupied) {
					e.x = nx
					e.y = ny
				}
			}
		}

		// Check death
		for (const e of enemies) {
			if (e.x === shark.x && e.y === shark.y) {
				endGame()
				return
			}
		}

		draw()
	}

	function endGame() {
		gameOver = true
		draw()
		if (score > highScore) {
			highScore = score
			localStorage.setItem('sharkHighScore', String(highScore))
			highScoreEl.textContent = String(highScore)
		}
		finalScoreEl.textContent = String(score)

		// Reset submit UI — show prompt button, hide name input
		submitPrompt.style.display = score > 0 ? 'block' : 'none'
		nameInputRow.classList.remove('visible')
		submitScoreBtn.disabled = false
		submitStatus.textContent = ''
		const savedName = localStorage.getItem('sharkPlayerName') || ''
		playerNameInput.value = savedName

		overlay.classList.add('visible')
	}

	// Player opts in to submit
	wantToSubmitBtn.addEventListener('click', () => {
		submitPrompt.style.display = 'none'
		nameInputRow.classList.add('visible')
		playerNameInput.focus()
	})

	// ── Leaderboard ──

	const MOCK_SCORES = [
		{ name: 'SharkMaster', score: 18, date: '2026-03-14T09:23:00Z' },
		{ name: 'FinFrenzy', score: 14, date: '2026-03-13T22:15:00Z' },
		{ name: 'OceanKing', score: 11, date: '2026-03-14T14:02:00Z' },
		{ name: 'DeepDiver', score: 9, date: '2026-03-12T18:45:00Z' },
		{ name: 'WaveCatcher', score: 7, date: '2026-03-14T11:30:00Z' },
		{ name: 'CoralQueen', score: 5, date: '2026-03-11T20:10:00Z' },
		{ name: 'TideRunner', score: 4, date: '2026-03-13T16:55:00Z' },
		{ name: 'ReefRaider', score: 3, date: '2026-03-10T08:40:00Z' },
	]

	async function fetchLeaderboard() {
		try {
			const res = await fetch('/api/scores')
			if (!res.ok) throw new Error('Failed to fetch')
			const scores = await res.json()
			renderLeaderboard(scores.length > 0 ? scores : MOCK_SCORES)
		} catch {
			renderLeaderboard(MOCK_SCORES)
		}
	}

	function formatDate(iso: string): string {
		try {
			const d = new Date(iso)
			const date = d.toLocaleDateString('en-US', {
				month: 'short',
				day: 'numeric',
				year: 'numeric',
			})
			const time = d.toLocaleTimeString('en-US', {
				hour: 'numeric',
				minute: '2-digit',
			})
			return `${date} · ${time}`
		} catch {
			return ''
		}
	}

	let lastSubmittedDate: string | null = null

	function renderLeaderboard(
		scores: { name: string; score: number; date?: string }[]
	) {
		if (scores.length === 0) {
			leaderboardBody.innerHTML =
				'<tr><td colspan="4" class="empty-board">No scores yet — be the first!</td></tr>'
			return
		}
		leaderboardBody.innerHTML = scores
			.map((s, i) => {
				const isHighlight = lastSubmittedDate && s.date === lastSubmittedDate
				const cls = isHighlight ? ' class="highlight"' : ''
				const dateStr = s.date ? formatDate(s.date) : ''
				const medalClasses = ['medal-gold', 'medal-silver', 'medal-bronze']
				const rankDisplay =
					i < 3
						? `<span class="medal ${medalClasses[i]}">${i + 1}</span>`
						: `${i + 1}`
				return `<tr${cls}><td>${rankDisplay}</td><td>${s.name}</td><td>${s.score}</td><td>${dateStr}</td></tr>`
			})
			.join('')

		// Scroll the highlighted row into view
		if (lastSubmittedDate) {
			const row = leaderboardBody.querySelector('.highlight')
			row?.scrollIntoView({ behavior: 'smooth', block: 'center' })
		}
	}

	submitScoreBtn.addEventListener('click', async () => {
		const name = playerNameInput.value.trim()
		if (!name) {
			submitStatus.textContent = 'Enter your name first!'
			return
		}
		submitScoreBtn.disabled = true
		submitStatus.textContent = 'Submitting…'
		localStorage.setItem('sharkPlayerName', name)

		try {
			const res = await fetch('/api/scores', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify({ name, score }),
			})
			if (!res.ok) throw new Error('Submit failed')
			const scores = await res.json()
			// Find the entry we just submitted (most recent with matching name/score)
			const submitted = scores.find(
				(s: { name: string; score: number; date?: string }) =>
					s.name === name && s.score === score && s.date
			)
			lastSubmittedDate = submitted?.date || null
			renderLeaderboard(scores)
			lastSubmittedDate = null
			submitStatus.textContent = 'Score submitted!'
			nameInputRow.classList.remove('visible')
		} catch {
			submitStatus.textContent = 'Failed to submit — try again'
			submitScoreBtn.disabled = false
		}
	})

	// Allow Enter key to submit
	playerNameInput.addEventListener('keydown', (e) => {
		if (e.key === 'Enter') submitScoreBtn.click()
	})

	// ── Controls ──

	document.addEventListener('keydown', (e) => {
		// Don't intercept keys when typing in an input
		if (
			e.target instanceof HTMLInputElement ||
			e.target instanceof HTMLTextAreaElement
		)
			return

		switch (e.key) {
			case 'ArrowUp':
			case 'w':
			case 'W':
				e.preventDefault()
				moveShark(0, -1)
				break
			case 'ArrowDown':
			case 's':
			case 'S':
				e.preventDefault()
				moveShark(0, 1)
				break
			case 'ArrowLeft':
			case 'a':
			case 'A':
				e.preventDefault()
				moveShark(-1, 0)
				break
			case 'ArrowRight':
			case 'd':
			case 'D':
				e.preventDefault()
				moveShark(1, 0)
				break
		}
	})

	// ── D-pad controls ──

	document.querySelectorAll('.dpad-btn').forEach((btn) => {
		const el = btn as HTMLElement

		const press = () => el.classList.add('pressed')
		const release = () => el.classList.remove('pressed')

		const handler = (e: Event) => {
			e.preventDefault()
			press()
			setTimeout(release, 150)
			switch (el.dataset.dir) {
				case 'up':
					moveShark(0, -1)
					break
				case 'down':
					moveShark(0, 1)
					break
				case 'left':
					moveShark(-1, 0)
					break
				case 'right':
					moveShark(1, 0)
					break
			}
		}
		btn.addEventListener('touchstart', handler, { passive: false })
		btn.addEventListener('click', handler)
	})

	playAgainBtn.addEventListener('click', () => init())

	// Go!
	fetchLeaderboard()
	init()

	// Auto-scroll game into view on touch devices
	if ('ontouchstart' in window) {
		setTimeout(() => {
			const hud = document.querySelector('.game-hud')
			if (hud) hud.scrollIntoView({ behavior: 'smooth', block: 'start' })
		}, 300)
	}
</script>

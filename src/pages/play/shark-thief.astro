	// ── Controls ──

	document.addEventListener('keydown', (e) => {
		// Don't intercept keys when typing in an input
		if (
			e.target instanceof HTMLInputElement ||
			e.target instanceof HTMLTextAreaElement
		)
			return

		switch (e.key) {
			case 'ArrowUp':
			case 'w':
			case 'W':
				e.preventDefault()
				moveShark(0, -1)
				break
			case 'ArrowDown':
			case 's':
			case 'S':
				e.preventDefault()
				moveShark(0, 1)
				break
			case 'ArrowLeft':
			case 'a':
			case 'A':
				e.preventDefault()
				moveShark(-1, 0)
				break
			case 'ArrowRight':
			case 'd':
			case 'D':
				e.preventDefault()
				moveShark(1, 0)
				break
		}
	})

	// ── D-pad controls ──

	function execDir(dir: string) {
		switch (dir) {
			case 'up':
				moveShark(0, -1)
				break
			case 'down':
				moveShark(0, 1)
				break
			case 'left':
				moveShark(-1, 0)
				break
			case 'right':
				moveShark(1, 0)
				break
		}
	}

	document.querySelectorAll('.dpad-btn').forEach((btn) => {
		const el = btn as HTMLElement
		let repeatTimer: ReturnType<typeof setInterval> | null = null

		const press = () => el.classList.add('pressed')
		const release = () => {
			el.classList.remove('pressed')
			if (repeatTimer) {
				clearInterval(repeatTimer)
				repeatTimer = null
			}
		}

		const startMove = (e: Event) => {
			e.preventDefault()
			press()
			const dir = el.dataset.dir!
			// Haptic feedback
			if (navigator.vibrate) navigator.vibrate(12)
			execDir(dir)
			// Auto-repeat after 200ms delay, then every 100ms
			repeatTimer = setTimeout(() => {
				repeatTimer = setInterval(() => {
					if (navigator.vibrate) navigator.vibrate(8)
					execDir(dir)
				}, 100)
			}, 200) as unknown as ReturnType<typeof setInterval>
		}

		const stopMove = () => release()

		btn.addEventListener('touchstart', startMove, { passive: false })
		btn.addEventListener('touchend', stopMove)
		btn.addEventListener('touchcancel', stopMove)
		btn.addEventListener('click', (e) => {
			e.preventDefault()
			if (navigator.vibrate) navigator.vibrate(12)
			execDir(el.dataset.dir!)
			press()
			setTimeout(release, 150)
		})
	})

	playAgainBtn.addEventListener('click', () => init())

	// ── Map selector ──
	const mapBtns = document.querySelectorAll('.map-btn')
	const MAP_LABELS: Record<MapSize, string> = {
		small: 'Small',
		medium: 'Medium',
	}

	function switchMap(map: MapSize) {
		currentMap = map
		GRID = MAP_GRIDS[map]
		CELL = canvas.width / GRID

		// Update button active state
		mapBtns.forEach((b) => {
			b.classList.toggle('active', (b as HTMLElement).dataset.map === map)
		})

		// Update leaderboard label
		leaderboardMapLabel.textContent = MAP_LABELS[map]

		// Load high score for this map
		highScore = parseInt(localStorage.getItem(highScoreKey()) || '0', 10)
		highScoreEl.textContent = String(highScore)

		// Fetch this map's leaderboard
		fetchLeaderboard()

		// Restart game
		init()
	}

	mapBtns.forEach((btn) => {
		btn.addEventListener('click', () => {
			const map = (btn as HTMLElement).dataset.map as MapSize
			if (map !== currentMap) switchMap(map)
		})
	})

	// Go!
	fetchLeaderboard()
	init()

	// Auto-scroll game into view on touch devices
	if ('ontouchstart' in window) {
		setTimeout(() => {
			const hud = document.querySelector('.game-hud')
			if (hud) hud.scrollIntoView({ behavior: 'smooth', block: 'start' })
		}, 300)
	}
</script>

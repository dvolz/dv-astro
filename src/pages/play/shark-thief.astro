---
import BaseLayout from '../../layouts/BaseLayout.astro'
import BlogDetails from '../../components/BlogDetails.astro'

export const blogData = {
	title: 'Shark Thief',
	author: 'David Volz',
	description:
		"A browser game built from a kid's prompt — sharks, bad guys, and yellow squares.",
	image: {
		url: 'https://docs.astro.build/assets/arc.webp',
		alt: 'The Astro logo on a dark background with a purple gradient arc.',
	},
	pubDate: '2026-3-14',
	tags: ['javascript', 'code', 'fluff'],
	featured: true,
	display: true,
}

const showTypographyHero = true
const fullWidthBody = true
---

<style lang="scss">
	/* ── Game ── */
	.game-wrapper {
		max-width: 96rem;
		margin: 0 auto;
		padding: 0 2rem;
		text-align: center;
		overflow-x: hidden;
	}
	@media (max-width: 640px) {
		.game-wrapper {
			padding: 0 0.5rem;
		}
	}
	.game-hud {
		display: flex;
		justify-content: center;
		gap: 3rem;
		margin: 0 0 1.5rem;
		font-family: var(--a-font);
		font-size: 1.6rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		span span {
			color: #5dade2;
			font-size: 2rem;
			font-weight: 800;
			letter-spacing: 0.04em;
		}
	}
	.game-canvas-wrapper {
		display: inline-block;
		border: 2px solid var(--text-color);
		border-radius: 0.4rem;
		line-height: 0;
	}
	.colorblind-toggle {
		display: flex;
		justify-content: center;
		margin: 0 0 1rem;
	}
	.colorblind-toggle button {
		font-family: var(--a-font);
		font-size: 1.2rem;
		font-weight: 600;
		padding: 0.4rem 1.2rem;
		border: 1px solid rgba(128, 128, 128, 0.3);
		border-radius: 0.4rem;
		background: none;
		color: var(--text-color);
		cursor: pointer;
		transition: all 0.2s ease;
		opacity: 0.6;
	}
	.colorblind-toggle button:hover {
		opacity: 1;
	}
	.colorblind-toggle button.active {
		background: var(--highlight-secondary);
		color: #fff;
		border-color: var(--highlight-secondary);
		opacity: 1;
	}
	canvas {
		display: block;
		max-width: 100%;
		height: auto;
		touch-action: none;
	}
	.game-instructions {
		margin: 0 auto 2.5rem;
		max-width: 44rem;
		padding: 1.6rem 2rem;
		border: 1px solid rgba(128, 128, 128, 0.15);
		border-radius: 0.6rem;
		text-align: left;
		line-height: 1.8;
		font-size: 1.4rem;
	}
	.game-instructions .how-to-play {
		font-family: var(--a-font);
		font-weight: 700;
		font-size: 1.2rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		opacity: 0.5;
		margin: 0 0 0.6rem;
	}
	.game-instructions ol {
		margin: 0;
		padding-left: 2rem;
		list-style: decimal;
	}
	.game-instructions li {
		margin-bottom: 0.3rem;
		font-family: var(--p-font);
	}
	.game-instructions li strong {
		font-weight: 700;
	}
	.game-instructions .controls-note {
		margin: 0.8rem 0 0;
		font-size: 1.2rem;
		opacity: 0.55;
		font-family: var(--a-font);
	}

	/* ── Map Selector ── */
	.map-selector {
		display: flex;
		justify-content: center;
		flex-wrap: wrap;
		gap: 1rem;
		margin: 0 0 2rem;
	}
	.map-btn {
		font-family: var(--a-font);
		font-size: 1.3rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 0.7rem 1.8rem;
		border: 2px solid var(--text-color);
		border-radius: 0.5rem;
		background: none;
		color: var(--text-color);
		cursor: pointer;
		transition: all 0.2s ease;
		opacity: 0.5;
	}
	.map-btn:hover {
		opacity: 0.75;
	}
	.map-btn.active {
		opacity: 1;
		border-color: var(--highlight-secondary);
		color: var(--highlight-secondary);
		background: rgba(74, 151, 184, 0.08);
	}
	.map-btn .map-size {
		display: block;
		font-size: 1rem;
		font-weight: 400;
		opacity: 0.55;
		margin-top: 0.2rem;
		letter-spacing: 0.04em;
	}

	/* ── Game Over Overlay ── */
	.game-over-overlay {
		position: absolute;
		inset: 0;
		display: none;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		background: rgba(0, 0, 0, 0.85);
		z-index: 10;
		border-radius: 0.4rem;
	}
	.game-over-overlay.visible {
		display: flex;
	}
	.game-over-overlay h2 {
		font-family: var(--a-font);
		font-size: 4rem;
		color: #e74c3c;
		margin: 0 0 0.5rem;
	}
	.game-over-overlay .final-score {
		font-family: var(--a-font);
		font-size: 2rem;
		color: #fff;
		margin: 0 0 2rem;
	}
	.game-over-overlay .game-over-buttons {
		display: flex;
		gap: 1.5rem;
	}
	.game-over-overlay button,
	.game-over-overlay a {
		font-family: var(--a-font);
		font-size: 1.6rem;
		font-weight: 600;
		padding: 0.8rem 2.5rem;
		border: 1px solid #fff;
		border-radius: 0.6rem;
		background: none;
		color: #fff;
		cursor: pointer;
		text-decoration: none;
		transition: all 0.3s ease;
		&:hover {
			background: #fff;
			color: #000;
		}
	}

	.game-canvas-container {
		position: relative;
		display: inline-block;
		max-width: 100%;
	}

	/* ── Name Input on Game Over ── */
	.submit-prompt {
		margin: 0 0 1.2rem;
	}
	.submit-prompt button {
		font-family: var(--a-font);
		font-size: 1.5rem;
		font-weight: 600;
		padding: 0.6rem 2rem;
		border: 1px solid #5dade2;
		border-radius: 0.4rem;
		background: none;
		color: #5dade2;
		cursor: pointer;
		transition: all 0.3s ease;
		&:hover {
			background: #5dade2;
			color: #000;
		}
	}
	.name-input-row {
		display: none;
		gap: 0.8rem;
		margin: 0 0 1.5rem;
		&.visible {
			display: flex;
		}
	}
	.name-input-row input {
		font-family: var(--a-font);
		font-size: 1.5rem;
		padding: 0.6rem 1rem;
		border: 1px solid #fff;
		border-radius: 0.4rem;
		background: rgba(255, 255, 255, 0.1);
		color: #fff;
		width: 14rem;
		outline: none;
		&::placeholder {
			color: rgba(255, 255, 255, 0.5);
		}
	}
	.name-input-row button {
		font-family: var(--a-font);
		font-size: 1.4rem;
		font-weight: 600;
		padding: 0.6rem 1.5rem;
		border: 1px solid #fff;
		border-radius: 0.4rem;
		background: none;
		color: #fff;
		cursor: pointer;
		transition: all 0.3s ease;
		&:hover {
			background: #fff;
			color: #000;
		}
		&:disabled {
			opacity: 0.4;
			cursor: default;
		}
	}
	.submit-status {
		font-size: 1.3rem;
		color: #5dade2;
		margin: 0 0 1rem;
		min-height: 1.6rem;
	}

	/* ── Mobile D-Pad ── */
	.dpad {
		display: none;
		margin: 1.5rem auto 0;
		width: 30rem;
		-webkit-user-select: none;
		user-select: none;
		touch-action: none;
	}
	@media (pointer: coarse) {
		.dpad {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			grid-template-rows: repeat(3, 1fr);
			gap: 0.4rem;
		}
	}
	.dpad-btn {
		appearance: none;
		width: 100%;
		aspect-ratio: 1;
		border: 2px solid var(--text-color);
		border-radius: 50%;
		background: transparent;
		color: var(--text-color);
		line-height: 1;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: transform 0.1s ease;
		-webkit-tap-highlight-color: transparent;
		touch-action: none;
		min-height: 8rem;
		min-width: 8rem;
		svg {
			width: 2.6rem;
			height: 2.6rem;
			fill: none;
			stroke: var(--text-color);
			stroke-width: 2.5;
			stroke-linejoin: round;
			stroke-linecap: round;
			transition:
				fill 0.1s ease,
				stroke 0.1s ease;
		}
		&.pressed,
		&:active {
			transform: scale(0.92);
			svg {
				fill: var(--highlight-secondary);
				stroke: var(--highlight-secondary);
			}
		}
	}
	.dpad-up {
		grid-column: 2;
		grid-row: 1;
	}
	.dpad-left {
		grid-column: 1;
		grid-row: 2;
	}
	.dpad-right {
		grid-column: 3;
		grid-row: 2;
	}
	.dpad-down {
		grid-column: 2;
		grid-row: 3;
	}
	.dpad-center {
		grid-column: 2;
		grid-row: 2;
		border: none;
		background: none;
		pointer-events: none;
	}
	.touch-hint {
		display: none;
	}
	@media (pointer: coarse) {
		.touch-hint {
			display: inline;
		}
	}
</style>

<style is:global lang="scss">
	$subtle: rgba(128, 128, 128, 0.15);

	.leaderboard {
		max-width: 72rem;
		margin: 3rem auto 0;
		padding: 0 2rem;
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
	}
	.leaderboard h3 {
		font-family: var(--a-font);
		font-size: 2.2rem;
		font-weight: 800;
		text-align: center;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		margin: 0 0 1.6rem;
		opacity: 0.75;
	}
	.leaderboard table {
		width: 100%;
		min-width: 44rem;
		border-collapse: collapse;
		table-layout: fixed;
		border: 1px solid $subtle;
		border-radius: 0.6rem;
		overflow: hidden;
	}

	/* ── All cells get subtle borders ── */
	.leaderboard th,
	.leaderboard td {
		padding: 0.8rem 1rem;
		border: 1px solid $subtle;
		vertical-align: middle;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	/* ── Header row ── */
	.leaderboard thead th {
		font-family: var(--a-font);
		font-weight: 600;
		font-size: 1rem;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: var(--text-color);
		opacity: 0.5;
		background: rgba(128, 128, 128, 0.06);
		border-bottom: 2px solid $subtle;
		white-space: nowrap;
	}

	/* ── Row striping ── */
	.leaderboard tbody tr {
		transition: background 0.15s ease;
	}
	.leaderboard tbody tr:nth-child(even) {
		background: rgba(128, 128, 128, 0.04);
	}
	.leaderboard tbody tr:hover {
		background: rgba(128, 128, 128, 0.09);
	}

	/* ── Rank column ── */
	.leaderboard th:nth-child(1),
	.leaderboard td:nth-child(1) {
		width: 5.5rem;
		text-align: center;
		font-family: var(--a-font);
		font-weight: 800;
		font-size: 1.4rem;
		opacity: 0.4;
		overflow: visible;
	}
	/* Top 3 medal styling */
	.leaderboard tbody tr:nth-child(1) td:nth-child(1),
	.leaderboard tbody tr:nth-child(2) td:nth-child(1),
	.leaderboard tbody tr:nth-child(3) td:nth-child(1) {
		opacity: 1;
	}
	.medal {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 3rem;
		height: 3rem;
		border-radius: 50%;
		font-family: var(--a-font);
		font-weight: 900;
		font-size: 1.4rem;
		line-height: 1;
		box-shadow: inset 0 -2px 4px rgba(0, 0, 0, 0.15);
	}
	.medal-gold {
		background: linear-gradient(145deg, #f7dc6f, #d4a017);
		color: #5c4300;
		border: 2px solid #c9960c;
	}
	.medal-silver {
		background: linear-gradient(145deg, #d5d5d5, #a0a0a0);
		color: #4a4a4a;
		border: 2px solid #909090;
	}
	.medal-bronze {
		background: linear-gradient(145deg, #dea06e, #b87333);
		color: #5a3510;
		border: 2px solid #a0612a;
	}

	/* ── Name column ── */
	.leaderboard th:nth-child(2),
	.leaderboard td:nth-child(2) {
		text-align: left;
		font-family: var(--p-font);
		font-size: 1.5rem;
		font-weight: 600;
		letter-spacing: 0.01em;
	}

	/* ── Score column ── */
	.leaderboard th:nth-child(3),
	.leaderboard td:nth-child(3) {
		width: 9rem;
		text-align: center;
		font-family: var(--a-font);
		font-weight: 800;
		font-size: 1.6rem;
		letter-spacing: 0.04em;
		color: #5dade2;
	}

	/* ── Date column ── */
	.leaderboard th:nth-child(4),
	.leaderboard td:nth-child(4) {
		width: 16rem;
		text-align: right;
		font-family: var(--a-font);
		font-size: 1.15rem;
		font-weight: 400;
		color: var(--text-color);
		opacity: 0.5;
		white-space: nowrap;
		font-style: italic;
	}

	.leaderboard .empty-board {
		text-align: center;
		opacity: 0.4;
		padding: 2.5rem 0;
		font-family: var(--p-font);
		font-style: italic;
		font-size: 1.4rem;
	}

	/* ── Highlight row (submitted score) ── */
	.leaderboard tr.highlight {
		background: rgba(93, 173, 226, 0.1) !important;
		animation: highlight-flash 2s ease-out;
		td {
			opacity: 1;
		}
		td:nth-child(2) {
			color: #5dade2;
		}
		td:nth-child(3) {
			color: #3498db;
			font-weight: 900;
		}
	}
	@keyframes highlight-flash {
		0% {
			background: rgba(93, 173, 226, 0.28);
		}
		100% {
			background: rgba(93, 173, 226, 0.08);
		}
	}
</style>

<BaseLayout
	pageTitle={blogData.title}
	{showTypographyHero}
	description={blogData.description}
	fullWidthBody={fullWidthBody}>
	<Fragment slot="head">
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no"
		/>
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta
			name="apple-mobile-web-app-status-bar-style"
			content="black-translucent"
		/>
		<meta name="apple-mobile-web-app-title" content="Shark Thief" />
		<link rel="apple-touch-icon" href="/images/shark-icon-180.png" />
		<link rel="manifest" href="/manifest-shark.json" />
	</Fragment>
	<div class="details-width">
		<BlogDetails {...blogData} />
	</div>

	<div class="game-wrapper">
		<div class="game-instructions">
			<p class="how-to-play">How to Play</p>
			<ol>
				<li><strong>Move</strong> your shark around the board</li>
				<li><strong>Collect</strong> the yellow squares to score points</li>
				<li>
					<strong>Rare purple coins</strong> are worth 15 points — but spawn a big
					red enemy
				</li>
				<li><strong>Avoid</strong> the dark squares — they chase you</li>
				<li>Each pickup spawns a new enemy — survive as long as you can</li>
			</ol>
			<p class="controls-note">
				Arrow keys or WASD to move<span class="touch-hint">
					· D-pad on mobile</span
				>
				· Switching map size resets the game
			</p>
		</div>

		<div class="map-selector">
			<button class="map-btn" data-map="small" data-grid="20">
				Small<span class="map-size">20 × 20</span>
			</button>
			<button class="map-btn active" data-map="medium" data-grid="30">
				Medium<span class="map-size">30 × 30</span>
			</button>
		</div>

		<div class="colorblind-toggle">
			<button id="colorblindBtn" title="Toggle colorblind-friendly grid"
				>Colorblind Mode</button
			>
		</div>

		<div class="game-hud">
			<span>Score: <span id="score">0</span></span>
			<span>High Score: <span id="highScore">0</span></span>
		</div>

		<div class="game-canvas-container">
			<canvas id="gameCanvas" width="700" height="700"></canvas>
			<div class="game-over-overlay" id="gameOverOverlay">
				<h2>YOU DIED</h2>
				<p class="final-score">Score: <span id="finalScore">0</span></p>
				<div class="submit-prompt" id="submitPrompt">
					<button id="wantToSubmitBtn">Submit Score?</button>
				</div>
				<div class="name-input-row" id="nameInputRow">
					<input
						type="text"
						id="playerName"
						placeholder="Your name"
						maxlength="20"
					/>
					<button id="submitScoreBtn">Submit</button>
				</div>
				<p class="submit-status" id="submitStatus"></p>
				<div class="game-over-buttons">
					<button id="playAgainBtn">Play Again</button>
					<a href="/">Home</a>
				</div>
			</div>
		</div>

		<div class="dpad" id="dpad">
			<button class="dpad-btn dpad-up" data-dir="up" aria-label="Move up"
				><svg viewBox="0 0 24 24"><path d="M12 5 L22 19 L2 19 Z"></path></svg
				></button
			>
			<button class="dpad-btn dpad-left" data-dir="left" aria-label="Move left"
				><svg viewBox="0 0 24 24"><path d="M5 12 L19 2 L19 22 Z"></path></svg
				></button
			>
			<div class="dpad-center"></div>
			<button
				class="dpad-btn dpad-right"
				data-dir="right"
				aria-label="Move right"
				><svg viewBox="0 0 24 24"><path d="M19 12 L5 2 L5 22 Z"></path></svg
				></button
			>
			<button class="dpad-btn dpad-down" data-dir="down" aria-label="Move down"
				><svg viewBox="0 0 24 24"><path d="M12 19 L2 5 L22 5 Z"></path></svg
				></button
			>
		</div>
	</div>

	<div class="leaderboard" id="leaderboard">
		<h3>Leaderboard — <span id="leaderboardMapLabel">Medium</span></h3>
		<table>
			<thead><tr><th>#</th><th>Name</th><th>Score</th><th>Date</th></tr></thead>
			<tbody id="leaderboardBody">
				<tr><td colspan="4" class="empty-board">Loading…</td></tr>
			</tbody>
		</table>
	</div>
</BaseLayout>

<script>
	const canvas = document.getElementById('gameCanvas') as HTMLCanvasElement
	const ctx = canvas.getContext('2d')!

	// ── Map config ──
	type MapSize = 'small' | 'medium'
	const MAP_GRIDS: Record<MapSize, number> = {
		small: 20,
		medium: 30,
	}
	let currentMap: MapSize = 'medium'
	let GRID = MAP_GRIDS[currentMap]
	let CELL = canvas.width / GRID

	const scoreEl = document.getElementById('score')!
	const highScoreEl = document.getElementById('highScore')!
	const finalScoreEl = document.getElementById('finalScore')!
	const overlay = document.getElementById('gameOverOverlay')!
	const playAgainBtn = document.getElementById('playAgainBtn')!
	const submitScoreBtn = document.getElementById(
		'submitScoreBtn'
	)! as HTMLButtonElement
	const playerNameInput = document.getElementById(
		'playerName'
	)! as HTMLInputElement
	const submitStatus = document.getElementById('submitStatus')!
	const nameInputRow = document.getElementById('nameInputRow')!
	const leaderboardBody = document.getElementById('leaderboardBody')!
	const leaderboardMapLabel = document.getElementById('leaderboardMapLabel')!
	const submitPrompt = document.getElementById('submitPrompt')!
	const wantToSubmitBtn = document.getElementById('wantToSubmitBtn')!

	function highScoreKey(): string {
		if (currentMap === 'medium') return 'sharkHighScore'
		return `sharkHighScore-${currentMap}`
	}

	let highScore = parseInt(localStorage.getItem(highScoreKey()) || '0', 10)
	highScoreEl.textContent = String(highScore)

	// ── State ──
	interface Enemy {
		x: number
		y: number
	}

	let colors: string[][] = []
	let pickups: boolean[][] = []
	let superPickups: boolean[][] = []
	let enemies: Enemy[] = []
	let bigEnemies: { x: number; y: number }[] = []
	let shark = { x: 0, y: 0 }
	let sharkDir = 'right' // tracks last movement direction
	let score = 0
	let moveCount = 0
	let gameOver = false

	// Smooth shark animation
	let sharkVisualX = 0
	let sharkVisualY = 0
	let sharkFromX = 0
	let sharkFromY = 0
	let animStartTime = 0
	const ANIM_DURATION = 80 // ms

	function startSharkAnim() {
		sharkFromX = sharkVisualX
		sharkFromY = sharkVisualY
		animStartTime = performance.now()
		requestAnimationFrame(tickAnim)
	}

	function tickAnim(now: number) {
		const t = Math.min(1, (now - animStartTime) / ANIM_DURATION)
		const ease = 1 - (1 - t) * (1 - t) // ease-out quad
		sharkVisualX = sharkFromX + (shark.x - sharkFromX) * ease
		sharkVisualY = sharkFromY + (shark.y - sharkFromY) * ease
		draw()
		if (t < 1) requestAnimationFrame(tickAnim)
	}

	// Curated palette — distinct hues with consistent lightness,
	// chosen so none clash with yellow pickups, black enemies, or the blue shark.
	const TILE_COLORS = [
		'#7ca6b3', // steel blue
		'#8fae7e', // sage green
		'#b58dac', // muted plum
		'#c49880', // warm tan
		'#6d9e9e', // teal
		'#a3887e', // mauve brown
		'#8e9fc0', // periwinkle
		'#9caa6c', // olive
		'#b08f9f', // dusty rose
		'#7b9a84', // fern
	]

	function randomTileColor(): string {
		return TILE_COLORS[Math.floor(Math.random() * TILE_COLORS.length)]
	}

	function init() {
		score = 0
		moveCount = 0
		gameOver = false
		scoreEl.textContent = '0'
		overlay.classList.remove('visible')

		// Random colors
		colors = Array.from({ length: GRID }, () =>
			Array.from({ length: GRID }, () => randomTileColor())
		)

		// Pickups — 5% on init
		pickups = Array.from({ length: GRID }, () =>
			Array.from({ length: GRID }, () => Math.random() < 0.05)
		)

		// 15-point coins: 1 in 800 of normal pickups become super pickups
		superPickups = Array.from({ length: GRID }, (_, r) =>
			Array.from({ length: GRID }, (_, c) => {
				if (pickups[r][c] && Math.random() < 1 / 800) {
					pickups[r][c] = false
					return true
				}
				return false
			})
		)

		bigEnemies = []

		// Shark starts at random spot
		shark.x = Math.floor(Math.random() * GRID)
		shark.y = Math.floor(Math.random() * GRID)

		// Make sure shark doesn't start on a pickup
		pickups[shark.y][shark.x] = false
		superPickups[shark.y][shark.x] = false

		// Snap visual position
		sharkVisualX = shark.x
		sharkVisualY = shark.y

		// One initial enemy
		enemies = [spawnEnemy()]

		draw()
	}

	function spawnEnemy(): Enemy {
		const MIN_DIST = 5
		let ex: number, ey: number
		do {
			ex = Math.floor(Math.random() * GRID)
			ey = Math.floor(Math.random() * GRID)
		} while (
			Math.abs(ex - shark.x) + Math.abs(ey - shark.y) < MIN_DIST ||
			enemies.some((e) => e.x === ex && e.y === ey)
		)
		return { x: ex, y: ey }
	}

	function spawnBigEnemy(): { x: number; y: number } {
		const MIN_DIST = 5
		let ex: number, ey: number
		do {
			ex = Math.floor(Math.random() * (GRID - 1))
			ey = Math.floor(Math.random() * (GRID - 1))
		} while (
			Math.min(
				Math.abs(ex - shark.x) + Math.abs(ey - shark.y),
				Math.abs(ex + 1 - shark.x) + Math.abs(ey - shark.y),
				Math.abs(ex - shark.x) + Math.abs(ey + 1 - shark.y),
				Math.abs(ex + 1 - shark.x) + Math.abs(ey + 1 - shark.y)
			) < MIN_DIST
		)
		return { x: ex, y: ey }
	}

	// ── Drawing ──

	let colorblindMode = localStorage.getItem('sharkColorblind') === 'true'
	const colorblindBtn = document.getElementById(
		'colorblindBtn'
	)! as HTMLButtonElement
	if (colorblindMode) colorblindBtn.classList.add('active')

	colorblindBtn.addEventListener('click', () => {
		colorblindMode = !colorblindMode
		localStorage.setItem('sharkColorblind', String(colorblindMode))
		colorblindBtn.classList.toggle('active', colorblindMode)
		draw()
	})

	// Redraw when theme changes so colors update (grid lines, enemy colors)
	new MutationObserver(() => {
		draw()
	}).observe(document.documentElement, {
		attributes: true,
		attributeFilter: ['class'],
	})

	function draw() {
		if (colorblindMode) {
			// Clear to transparent, draw single grid lines using the theme text color
			ctx.clearRect(0, 0, canvas.width, canvas.height)
			const textColor = getComputedStyle(document.body)
				.getPropertyValue('--text-color')
				.trim()
			ctx.strokeStyle = textColor || '#332e2e'
			ctx.lineWidth = 1
			ctx.beginPath()
			for (let i = 0; i <= GRID; i++) {
				const pos = i === GRID ? canvas.width - 0.5 : Math.round(i * CELL) + 0.5
				ctx.moveTo(pos, 0)
				ctx.lineTo(pos, canvas.height)
				ctx.moveTo(0, pos)
				ctx.lineTo(canvas.width, pos)
			}
			ctx.stroke()
		} else {
			// Background fill — prevents white seams between cells on scaled displays
			ctx.fillStyle = '#5b7b7b'
			ctx.fillRect(0, 0, canvas.width, canvas.height)

			// Grid cells
			for (let r = 0; r < GRID; r++) {
				for (let c = 0; c < GRID; c++) {
					ctx.fillStyle = colors[r][c]
					ctx.fillRect(c * CELL, r * CELL, CELL, CELL)
				}
			}
		}

		// Pickups (smaller yellow squares with dark outline for contrast)
		const pad = CELL * 0.22
		for (let r = 0; r < GRID; r++) {
			for (let c = 0; c < GRID; c++) {
				if (pickups[r][c]) {
					const px = c * CELL + pad
					const py = r * CELL + pad
					const ps = CELL - pad * 2
					// Dark outline
					ctx.fillStyle = '#7a6200'
					ctx.fillRect(px - 1, py - 1, ps + 2, ps + 2)
					// Yellow fill
					ctx.fillStyle = '#f1c40f'
					ctx.fillRect(px, py, ps, ps)
				}
			}
		}

		// Super pickups (15-point coins — purple with label)
		for (let r = 0; r < GRID; r++) {
			for (let c = 0; c < GRID; c++) {
				if (superPickups[r][c]) {
					const px = c * CELL + pad
					const py = r * CELL + pad
					const ps = CELL - pad * 2
					// Dark outline
					ctx.fillStyle = '#4a0060'
					ctx.fillRect(px - 1, py - 1, ps + 2, ps + 2)
					// Purple fill
					ctx.fillStyle = '#9b59b6'
					ctx.fillRect(px, py, ps, ps)
					// "15" label when cells are large enough
					if (CELL >= 16) {
						ctx.fillStyle = '#fff'
						ctx.font = `bold ${Math.max(8, CELL * 0.35)}px sans-serif`
						ctx.textAlign = 'center'
						ctx.textBaseline = 'middle'
						ctx.fillText('15', c * CELL + CELL / 2, r * CELL + CELL / 2)
					}
				}
			}
		}

		// Enemies — white in colorblind+dark mode, black otherwise
		const enemyWhite =
			colorblindMode && document.documentElement.classList.contains('dark')
		for (const e of enemies) {
			ctx.fillStyle = enemyWhite ? '#8b3a3a' : '#c0392b'
			ctx.fillRect(e.x * CELL - 1, e.y * CELL - 1, CELL + 2, CELL + 2)
			ctx.fillStyle = enemyWhite ? '#fff7f2' : '#1a1a1a'
			ctx.fillRect(e.x * CELL, e.y * CELL, CELL, CELL)
		}

		// Big enemies (2×2 red squares)
		for (const be of bigEnemies) {
			const bx = be.x * CELL
			const by = be.y * CELL
			const bw = CELL * 2
			// Dark outline
			ctx.fillStyle = '#6b0000'
			ctx.fillRect(bx - 1, by - 1, bw + 2, bw + 2)
			// Red fill
			ctx.fillStyle = '#e74c3c'
			ctx.fillRect(bx, by, bw, bw)
		}

		// Shark 🦈 — draw a simple shark shape
		drawShark(sharkVisualX, sharkVisualY)
	}

	function drawShark(cx: number, cy: number) {
		const x = cx * CELL
		const y = cy * CELL
		const w = CELL
		const h = CELL

		ctx.save()

		// Flip/rotate shark to face movement direction
		const centerX = x + w / 2
		const centerY = y + h / 2
		ctx.translate(centerX, centerY)
		switch (sharkDir) {
			case 'right':
				// default orientation, no transform
				break
			case 'left':
				ctx.scale(-1, 1) // mirror horizontally
				break
			case 'down':
				ctx.rotate(Math.PI / 2)
				break
			case 'up':
				ctx.rotate(-Math.PI / 2)
				break
		}
		ctx.translate(-centerX, -centerY)

		// Glow / highlight behind the shark
		ctx.shadowColor = '#ffffff'
		ctx.shadowBlur = 12

		// White outline for contrast on any background
		ctx.strokeStyle = '#fff'
		ctx.lineWidth = 1

		// Body
		ctx.fillStyle = '#2980b9'
		ctx.beginPath()
		ctx.ellipse(x + w / 2, y + h / 2, w * 0.45, h * 0.35, 0, 0, Math.PI * 2)
		ctx.fill()
		ctx.stroke()

		// Reset shadow so fins/tail don't double-glow
		ctx.shadowBlur = 0

		// Dorsal fin
		ctx.fillStyle = '#1a5276'
		ctx.beginPath()
		ctx.moveTo(x + w * 0.4, y + h * 0.08)
		ctx.lineTo(x + w * 0.48, y + h * 0.38)
		ctx.lineTo(x + w * 0.62, y + h * 0.35)
		ctx.closePath()
		ctx.fill()
		ctx.stroke()

		// Tail
		ctx.fillStyle = '#1a5276'
		ctx.beginPath()
		ctx.moveTo(x + w * 0.05, y + h * 0.35)
		ctx.lineTo(x - w * 0.1, y + h * 0.15)
		ctx.lineTo(x - w * 0.1, y + h * 0.7)
		ctx.lineTo(x + w * 0.05, y + h * 0.55)
		ctx.closePath()
		ctx.fill()
		ctx.stroke()

		// Belly (lighter underside)
		ctx.fillStyle = '#d6eaf8'
		ctx.beginPath()
		ctx.ellipse(x + w / 2, y + h * 0.58, w * 0.32, h * 0.12, 0, 0, Math.PI)
		ctx.fill()

		// Mouth line
		ctx.strokeStyle = '#1a5276'
		ctx.lineWidth = 1
		ctx.beginPath()
		ctx.moveTo(x + w * 0.55, y + h * 0.58)
		ctx.lineTo(x + w * 0.85, y + h * 0.52)
		ctx.stroke()

		// Eye
		ctx.fillStyle = '#fff'
		ctx.beginPath()
		ctx.arc(x + w * 0.65, y + h * 0.38, w * 0.09, 0, Math.PI * 2)
		ctx.fill()
		ctx.strokeStyle = '#1a5276'
		ctx.lineWidth = 1
		ctx.stroke()
		ctx.fillStyle = '#000'
		ctx.beginPath()
		ctx.arc(x + w * 0.67, y + h * 0.38, w * 0.045, 0, Math.PI * 2)
		ctx.fill()

		ctx.restore()
	}

	// ── Game Logic ──

	function moveShark(dx: number, dy: number) {
		if (gameOver) return

		const nx = shark.x + dx
		const ny = shark.y + dy
		if (nx < 0 || nx >= GRID || ny < 0 || ny >= GRID) return

		shark.x = nx
		shark.y = ny
		moveCount++

		// Track facing direction
		if (dx === 1) sharkDir = 'right'
		else if (dx === -1) sharkDir = 'left'
		else if (dy === 1) sharkDir = 'down'
		else if (dy === -1) sharkDir = 'up'

		// Check pickup
		if (pickups[ny][nx]) {
			pickups[ny][nx] = false
			score++
			scoreEl.textContent = String(score)
			// Spawn a new enemy
			enemies.push(spawnEnemy())
		}

		// Check super pickup (15-point coin)
		if (superPickups[ny][nx]) {
			superPickups[ny][nx] = false
			score += 15
			scoreEl.textContent = String(score)
			// Spawn a 2×2 red enemy
			bigEnemies.push(spawnBigEnemy())
		}

		// Spawn new pickups — 1/4000 chance per cell
		for (let r = 0; r < GRID; r++) {
			for (let c = 0; c < GRID; c++) {
				if (!pickups[r][c] && !superPickups[r][c] && Math.random() < 0.00025) {
					if (Math.random() < 1 / 800) {
						superPickups[r][c] = true
					} else {
						pickups[r][c] = true
					}
				}
			}
		}

		// Enemies move every 2 player moves
		if (moveCount % 2 === 0) {
			for (const e of enemies) {
				const diffX = shark.x - e.x
				const diffY = shark.y - e.y
				let nx = e.x
				let ny = e.y
				if (Math.abs(diffX) >= Math.abs(diffY)) {
					nx += Math.sign(diffX)
				} else {
					ny += Math.sign(diffY)
				}
				// Only move if no other enemy is already on that square
				const occupied = enemies.some(
					(other) => other !== e && other.x === nx && other.y === ny
				)
				if (!occupied) {
					e.x = nx
					e.y = ny
				}
			}

			// Big enemies also chase the shark
			for (const be of bigEnemies) {
				const diffX = shark.x - be.x
				const diffY = shark.y - be.y
				if (Math.abs(diffX) >= Math.abs(diffY)) {
					be.x += Math.sign(diffX)
				} else {
					be.y += Math.sign(diffY)
				}
				// Clamp so the 2×2 block stays on the grid
				be.x = Math.max(0, Math.min(GRID - 2, be.x))
				be.y = Math.max(0, Math.min(GRID - 2, be.y))
			}
		}

		// Check death
		for (const e of enemies) {
			if (e.x === shark.x && e.y === shark.y) {
				endGame()
				return
			}
		}
		for (const be of bigEnemies) {
			if (
				shark.x >= be.x &&
				shark.x <= be.x + 1 &&
				shark.y >= be.y &&
				shark.y <= be.y + 1
			) {
				endGame()
				return
			}
		}

		startSharkAnim()
	}

	function endGame() {
		gameOver = true
		sharkVisualX = shark.x
		sharkVisualY = shark.y
		draw()
		if (score > highScore) {
			highScore = score
			localStorage.setItem(highScoreKey(), String(highScore))
			highScoreEl.textContent = String(highScore)
		}
		finalScoreEl.textContent = String(score)

		// Reset submit UI — show prompt button, hide name input
		submitPrompt.style.display = score > 0 ? 'block' : 'none'
		nameInputRow.classList.remove('visible')
		submitScoreBtn.disabled = false
		submitStatus.textContent = ''
		const savedName = localStorage.getItem('sharkPlayerName') || ''
		playerNameInput.value = savedName

		overlay.classList.add('visible')
	}

	// Player opts in to submit
	wantToSubmitBtn.addEventListener('click', () => {
		submitPrompt.style.display = 'none'
		nameInputRow.classList.add('visible')
		playerNameInput.focus()
	})

	// ── Leaderboard ──

	const MOCK_SCORES = [
		{ name: 'SharkMaster', score: 18, date: '2026-03-14T09:23:00Z' },
		{ name: 'FinFrenzy', score: 14, date: '2026-03-13T22:15:00Z' },
		{ name: 'OceanKing', score: 11, date: '2026-03-14T14:02:00Z' },

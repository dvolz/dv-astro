---
import BaseLayout from '../layouts/BaseLayout.astro'
import RecentItems from '../components/RecentItems.astro'

const pageTitle = 'Play'
const description = 'Play page that showcases experiments'
---

<BaseLayout pageTitle={pageTitle} description={description}>
	<div class="content">
		<p style="text-align: center;">
			Here is a collection of experiments and tools I've built for fun or to
			learn new skills.
		</p>
		<RecentItems category="play" />
	</div>
</BaseLayout>

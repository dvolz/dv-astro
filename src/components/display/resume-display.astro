---
const { title, url, description } = Astro.props
---

<style lang="scss">
	.resume-frame {
		position: relative;
		overflow: hidden;
	}
	.resume-lines {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		opacity: 0.12;
		pointer-events: none;
	}
	.resume-line {
		position: absolute;
		left: 0;
		width: 100%;
		height: 1px;
		background: var(--text-color);
	}
	.resume-display-title {
		position: relative;
		z-index: 1;
		font-family: var(--a-font);
		font-size: 2.5rem;
		font-weight: 700;
		margin: 0;
		color: var(--text-color);
	}
</style>

<a class="blogPost" href={url}>
	<div class="frame resume-frame">
		<div class="resume-lines">
			<div class="resume-line" style="top: 20%"></div>
			<div class="resume-line" style="top: 35%"></div>
			<div class="resume-line" style="top: 50%"></div>
			<div class="resume-line" style="top: 65%"></div>
			<div class="resume-line" style="top: 80%"></div>
		</div>
		<p class="resume-display-title">{title}</p>
	</div>
</a>

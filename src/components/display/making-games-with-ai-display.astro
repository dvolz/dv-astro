---
const { title, url, description } = Astro.props
---

<style lang="scss">
	.game-display-frame {
		position: relative;
		overflow: hidden;
	}
	.game-display-grid {
		position: absolute;
		inset: 0;
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		grid-template-rows: repeat(4, 1fr);
		gap: 2px;
		opacity: 0.18;
		pointer-events: none;
	}
	.game-display-cell {
		border-radius: 1px;
	}
	.game-display-title {
		position: relative;
		z-index: 1;
		font-family: var(--a-font);
		font-size: 2.5rem;
		font-weight: 700;
		margin: 0;
		color: var(--text-color);
	}
</style>

<a class="blogPost" href={url}>
	<div class="frame game-display-frame">
		<div class="game-display-grid">
			<div class="game-display-cell" style="background:#a8d8ea"></div>
			<div class="game-display-cell" style="background:#f6c9de"></div>
			<div class="game-display-cell" style="background:#d4e7a5"></div>
			<div class="game-display-cell" style="background:#f1c40f"></div>
			<div class="game-display-cell" style="background:#c9b1e8"></div>
			<div class="game-display-cell" style="background:#f5cba7"></div>
			<div class="game-display-cell" style="background:#f5cba7"></div>
			<div class="game-display-cell" style="background:#a8d8ea"></div>
			<div class="game-display-cell" style="background:#000"></div>
			<div class="game-display-cell" style="background:#d4e7a5"></div>
			<div class="game-display-cell" style="background:#f6c9de"></div>
			<div class="game-display-cell" style="background:#c9b1e8"></div>
			<div class="game-display-cell" style="background:#d4e7a5"></div>
			<div class="game-display-cell" style="background:#c9b1e8"></div>
			<div class="game-display-cell" style="background:#a8d8ea"></div>
			<div class="game-display-cell" style="background:#f6c9de"></div>
			<div class="game-display-cell" style="background:#f1c40f"></div>
			<div class="game-display-cell" style="background:#f5cba7"></div>
			<div class="game-display-cell" style="background:#f1c40f"></div>
			<div class="game-display-cell" style="background:#a8d8ea"></div>
			<div class="game-display-cell" style="background:#f6c9de"></div>
			<div class="game-display-cell" style="background:#c9b1e8"></div>
			<div class="game-display-cell" style="background:#d4e7a5"></div>
			<div class="game-display-cell" style="background:#000"></div>
		</div>
		<p class="game-display-title">{title}</p>
	</div>
</a>
